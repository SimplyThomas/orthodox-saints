<script>
  /* Share / cite: copy a plain citation + canonical URL to the clipboard, with
     a Web-Share fallback on devices that support it. (Mirrors the saint page.) */
  const share = document.querySelector<HTMLButtonElement>(".sv-share");
  const shareLabel = share?.querySelector<HTMLElement>(".sv-share-label");
  if (share && shareLabel) {
    const cite = share.dataset.cite || document.title;
    const url = location.href;
    share.addEventListener("click", async () => {
      const text = `${cite} ${url}`;
      try {
        if (navigator.share) {
          await navigator.share({ title: cite, url });
          return;
        }
        await navigator.clipboard.writeText(text);
        const prev = shareLabel.textContent;
        shareLabel.textContent = "Citation copied";
        window.setTimeout(() => {
          shareLabel.textContent = prev;
        }, 1600);
      } catch {
        /* user dismissed the share sheet, or clipboard denied — no-op */
      }
    });
  }
</script>
