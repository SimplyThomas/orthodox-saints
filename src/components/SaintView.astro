---
/* Full data-driven saint page — REDESIGN.
   A dark iconographic HERO carries identity, icon & feast up top; a quiet
   quick-actions bar collects the explore links + share; the BODY is a light
   record rail (the demoted taxonomy) beside a single flowing story column —
   intercessions ("Come to them for") promoted to the head of the story, the
   life and the saint's words next, and the reference apparatus (timeline,
   legacy, works, kin) as collapsible deep-dives below. Pure build-time render
   from the Saint record via toSaintView(). */
import type { Saint } from "../lib/types";
import { toSaintView } from "../lib/saintView";
import { saintAvatar } from "../lib/icons";
import { primaryRank } from "../lib/saints";
import { splitName } from "../lib/names";
import { esc, withBase } from "../lib/format";
import { loadProfileMap } from "../lib/saint-profiles";
import SaintProfile from "./SaintProfile.astro";
import { themeBySlug, relatedByThemes } from "../lib/themes";
import { groupBySlug, GROUP_TYPE_LABEL } from "../lib/groups";
import { SAINTS } from "../lib/data";

interface Props {
  saint: Saint;
}
const { saint } = Astro.props;
const m = toSaintView(saint);
const profile = (await loadProfileMap())[saint.id];

// Editorial review state — surfaced as a full-width band beneath the hero.
const isFlagged = profile?.status === "flagged";
const isDraft =
  !!profile?.status && profile.status !== "reviewed" && !isFlagged;
const flagReasons = profile?.flagReasons ?? [];

// "Companions & kin" (the design's unified human web): the curated profile
// `related` figures and the `family` members folded into one avatar grid, each
// resolved to its record where possible so it shows the real portrait/monogram,
// a relationship label, and name + epithet. De-duplicated by id/name; figures
// not in the dataset (e.g. an uncanonized brother) still show a monogram card.
// With no profile we derive companions by shared themes.
const byId = new Map(SAINTS.map((s) => [s.id, s]));
// Possessive for the section labels ("In his own words", "His companions & kin").
const possessive =
  saint.gender === "Male" ? "his" : saint.gender === "Female" ? "her" : "their";
const possessivePrefix =
  possessive.charAt(0).toUpperCase() + possessive.slice(1);
const stripHon = (n: string) => n.replace(/^(Saint|St\.?|Holy)\s+/i, "");
type Companion = {
  saint?: Saint;
  name: string;
  rel: string;
  href?: string;
  external?: string;
};
const companions: Companion[] = [];
const seenKin = new Set<string>();
const addKin = (f: {
  name: string;
  note?: string;
  href?: string;
  external?: string;
}) => {
  const id = f.href?.match(/OS-\d{4,}/)?.[0];
  const key = id || f.name;
  if (seenKin.has(key)) return;
  seenKin.add(key);
  companions.push({
    saint: id ? byId.get(id) : undefined,
    name: f.name,
    rel: f.note ?? "",
    href: f.href,
    external: f.external,
  });
};
if (profile && (profile.related?.length || profile.family)) {
  (profile.related ?? []).forEach(addKin);
  (profile.family?.figures ?? []).forEach(addKin);
} else {
  relatedByThemes(saint, SAINTS, 6).forEach((s) =>
    addKin({ name: s.name, note: primaryRank(s), href: "saint/" + s.id }),
  );
}
const kinIntro = profile?.family?.intro;
const kinLabel = `${possessivePrefix} companions & kin`;

// Group-taxonomy memberships (data/saint_groups.csv) → "Commemorated with"
// links to each group's landing page. Joined into the record by build.py.
const memberGroups = saint.groups ?? [];

// Works (by the saint) and Further Reading (about the saint). A profile's rich
// lists supersede the plain CSV-derived ones; otherwise the CSV search-link
// lists are shown.
const worksList = profile?.works?.length ? profile.works : null;
const hasWorks = !!worksList || m.works.length > 0;
const readingGroups = profile?.reading?.length ? profile.reading : null;
const hasReading = !!readingGroups || m.about.length > 0;

const hasTimeline = !!profile?.timeline?.length;
const hasLegacy = !!profile?.sections?.length;
const hasCompanions = companions.length > 0;
const hasCommemorated = memberGroups.length > 0;
const hasAfter =
  hasTimeline ||
  hasLegacy ||
  hasWorks ||
  hasReading ||
  hasCommemorated ||
  hasCompanions ||
  !!m.notes ||
  !!m.sources;

// The large hero icon. A real portrait fills a plain rounded rectangle (the
// design's icon-slot) — NOT the arched monogram clip, whose path() coordinates
// are fixed near 120×150px. The monogram tier is a viewBox SVG, so it scales.
let portrait: string;
if (saint.image) {
  const raw = String(saint.image).replace(/['"\\)\s<>]/g, "");
  const url = esc(/^(https?:)?\/\//.test(raw) ? raw : withBase(raw));
  portrait = `<div class="sv-icon-img" style="background:#16304c center top/cover no-repeat url('${url}')"></div>`;
} else {
  portrait = saintAvatar(saint, 286, 358, { type: primaryRank(saint) });
}
const showCredit =
  !!saint.image && !!(m.imageCredit || m.imageLicense || m.imagePermission);
const knownFor = m.virtues.length > 0 || m.vocation.length > 0;
const citation = `${m.honorificName}. Cloud of Witnesses.`;

// "In their own words" — a curated profile `quotes` array (multiple, verbatim
// PD) wins; otherwise the single sourced quote from saint_quotes.csv. Gender
// picks the possessive for the section label.
const quoteList = profile?.quotes?.length
  ? profile.quotes.map((q) => ({
      text: q.text,
      cite: [q.work, q.locus].filter(Boolean).join(", "),
      source: q.source,
      translation: q.translation,
    }))
  : m.quote
    ? [m.quote]
    : [];
const wordsLabel = `In ${possessive} own words`;
---

<div
  class="saintview sv2"
  id="saint-detail"
  data-id={saint.id}
  data-name={saint.name}
>
  {/* ══════════════ HERO ══════════════ */}
  <section class="sv-hero">
    <div class="sv-hero-inner">
      {/* breadcrumb */}
      <nav class="sv-hero-crumb" aria-label="Breadcrumb">
        <a href={withBase("search")} class="sv-back-link">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M14 6l-6 6 6 6"></path></svg
          >
          <span class="sv-back-label">Back to the saints</span>
        </a>
        <span class="sv-sep">/</span>
        <span class="sv-crumb">{m.crumb}</span>
        <span class="sv-sep">/</span>
        <span class="sv-here">{m.honorificName}</span>
      </nav>

      <div class="sv-hero-grid">
        {/* framed icon + credit */}
        <div class="sv-hero-icon">
          <div class="sv-icon-frame">
            <div class="sv-icon-inner" set:html={portrait} />
          </div>
          {
            /* Permission images link "Original icon" to the specific vendor
               page (imageSource) per the grant. m.imageVendorHome (the vendor's
               icon homepage) is also available, reserved for a future
               vendor-homepage link. */
            showCredit &&
              (m.imagePermission ? (
                <div class="sv-icon-cap">
                  {m.imageAttribution}
                  {m.imageSource && (
                    <>
                      {" "}
                      Original icon:{" "}
                      <a
                        href={m.imageSource}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        View on {m.imageVendor}
                      </a>
                    </>
                  )}
                </div>
              ) : (
                <div class="sv-icon-cap">
                  <span class="sv-icon-cap-eb">Icon</span> ·{" "}
                  {m.imageSource ? (
                    <a
                      href={m.imageSource}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {m.imageCredit || "source"}
                    </a>
                  ) : (
                    m.imageCredit
                  )}
                  {m.imageLicense && (
                    <span class="sv-icon-lic">{m.imageLicense}</span>
                  )}
                </div>
              ))
          }
        </div>

        {/* identity */}
        <div class="sv-hero-id">
          <div class="sv-hero-tagrow">
            <span class={`tag ${m.typeSlug} sv-tag-gold`}><i></i>{m.type}</span>
            {m.eyebrow && <span class="eyebrow on-blue">{m.eyebrow}</span>}
          </div>

          <h1 class="sv-name">
            {m.title}{m.epithet && <span class="sv-epithet"> {m.epithet}</span>}
          </h1>
          {profile?.lifespan && <p class="sv-lifespan">{profile.lifespan}</p>}
          {
            m.also.length > 0 && (
              <div class="sv-also">Also known as {m.also.join(" · ")}</div>
            )
          }

          <div class="sv-hero-rule"></div>

          {m.brief && <p class="sv-lead">{m.brief}</p>}

          <div class="sv-feast">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--gold-soft)"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="16" rx="2"></rect>
              <path d="M3 9h18M8 3v4M16 3v4"></path>
            </svg>
            <div class="sv-feast-main">
              <div class="sv-feast-label">Feast Day</div>
              <div class="sv-feast-date">{m.feast}</div>
            </div>
            {m.feastNote && <div class="sv-feast-note">{m.feastNote}</div>}
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════ REVIEW STATE BAND ══════════════ */}
  {
    (isFlagged || isDraft) && (
      <div
        class={`sv-state ${isFlagged ? "sv-state--flag" : "sv-state--draft"}`}
        role={isFlagged ? "alert" : "status"}
      >
        <div class="sv-state-inner">
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            class="sv-state-ico"
            aria-hidden="true"
          >
            <path
              d="M10 1.5 19 18 1 18 Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linejoin="round"
            />
            <rect
              x="9.1"
              y="7"
              width="1.8"
              height="5.4"
              rx=".9"
              fill="currentColor"
            />
            <circle cx="10" cy="15" r="1.05" fill="currentColor" />
          </svg>
          <span class="sv-state-label">{isFlagged ? "Flagged" : "Draft"}</span>
          <span class="sv-state-div" />
          <div class="sv-state-body">
            {isFlagged ? (
              flagReasons.length > 0 ? (
                <ul class="sv-state-list">
                  {flagReasons.map((r) => (
                    <li>
                      {r.claim && <span class="sv-state-claim">{r.claim}</span>}
                      {r.claim && r.detail ? " — " : ""}
                      {r.detail}
                    </li>
                  ))}
                </ul>
              ) : (
                "Flagged for review — this entry may contain errors or unverified claims."
              )
            ) : (
              "Draft — pending review. Not yet verified for publication."
            )}
          </div>
        </div>
      </div>
    )
  }

  {/* ══════════════ QUICK ACTIONS ══════════════ */}
  <div class="sv-actions">
    <div class="sv-actions-inner">
      {
        m.links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--ghost sv-explore-link"
          >
            {l.label}
            <svg
              width="11"
              height="11"
              viewBox="0 0 14 14"
              fill="none"
              stroke="var(--celest)"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 10 10 4M5 4h5v5" />
            </svg>
          </a>
        ))
      }
      <div class="sv-actions-spacer"></div>
      <button type="button" class="btn btn--gold sv-share" data-cite={citation}>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--byz-ink)"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <path d="m8.6 13.5 6.8 4M15.4 6.5l-6.8 4"></path>
        </svg>
        <span class="sv-share-label">Share / cite</span>
      </button>
    </div>
  </div>

  {/* ══════════════ BODY ══════════════ */}
  <div class="sv-body">
    {/* ── RECORD RAIL (the demoted taxonomy) ── */}
    <aside class="sv-rail">
      {
        m.facts.length > 0 && (
          <div class="sv-glance">
            <div class="eyebrow">At a glance</div>
            <dl>
              {m.facts.map(([k, v]) => (
                <div class="sv-fact">
                  <dt>{k}</dt>
                  <dd>{v}</dd>
                </div>
              ))}
            </dl>
          </div>
        )
      }

      {
        knownFor && (
          <div class="sv-knownfor">
            <div class="eyebrow">Known for</div>
            {m.virtues.length > 0 && (
              <div class="sv-virtues">{m.virtues.join(" · ")}</div>
            )}
            {m.vocation.length > 0 && (
              <div class="sv-vocation">{m.vocation.join(" · ")}</div>
            )}
          </div>
        )
      }

      {
        profile?.patronage && profile.patronage.length > 0 && (
          <div class="sv-rail-block sv-patron">
            <div class="eyebrow">Patron of</div>
            <div class="sv-rail-chips">
              {profile.patronage.map((p) => (
                <span class="sv-rail-chip">{p}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        m.experience.length > 0 && (
          <div class="sv-rail-block">
            <div class="eyebrow">Walked through</div>
            <p class="sv-rail-note">A companion to those who have known…</p>
            <div class="sv-rail-chips">
              {m.experience.map((e) => (
                <span class="sv-rail-chip sv-rail-chip--life">{e}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        saint.themes && saint.themes.length > 0 && (
          <div class="sv-rail-block sv-themes">
            <div class="eyebrow">Browse by theme</div>
            <div class="sv-rail-chips">
              {saint.themes.map((slug) => {
                const t = themeBySlug.get(slug);
                return t ? (
                  <a
                    class="sv-theme sv-rail-chip"
                    href={withBase("search?theme=" + slug)}
                  >
                    {t.label}
                  </a>
                ) : null;
              })}
            </div>
          </div>
        )
      }
    </aside>

    {/* ── STORY COLUMN ── */}
    <main class="sv-main">
      {
        profile?.liturgicalTitle && (
          <div class="sv-littitle">
            <div class="eyebrow sv-littitle-label">Commemorated as</div>
            <p class="sv-littitle-text">{profile.liturgicalTitle}</p>
          </div>
        )
      }

      {/* come to them for — the finder's engine, promoted */}
      {
        m.intercessions.length > 0 && (
          <section class="sv-section sv-invoked">
            <div class="sv-secthead">
              <span class="eyebrow">Come to them for</span>
            </div>
            <div class="sv-invoked-grid">
              {m.intercessions.map((it) => (
                <div class="sv-invoked-card">{it}</div>
              ))}
            </div>
          </section>
        )
      }

      {/* life (rendered by SaintProfile when a rich profile exists) */}
      {profile && <SaintProfile profile={profile} />}
      {
        !profile && m.brief && (
          <section class="sv-section sv-lifefallback">
            <div class="sv-secthead">
              <span class="eyebrow">Their life</span>
            </div>
            <p class="sv-bodytext">{m.brief}</p>
          </section>
        )
      }

      {/* customs */}
      {
        m.customs && (
          <section class="sv-section">
            <div class="sv-customs">
              <div class="eyebrow">Customs &amp; Traditions</div>
              <p>{m.customs}</p>
            </div>
          </section>
        )
      }

      {/* in their own words — a collapsible of verbatim PD quotes */}
      {
        quoteList.length > 0 && (
          <details class="sv-deep sv-words">
            <summary class="sv-deep-sum">
              <span class="eyebrow sv-deep-eb">{wordsLabel}</span>
              {quoteList.length > 1 && (
                <span class="sv-deep-ct">{quoteList.length} quotes</span>
              )}
              <span class="sv-deep-rule" />
              <span class="sv-deep-state">
                <span class="sv-deep-show">Read</span>
                <span class="sv-deep-hide">Hide</span>
              </span>
              <svg
                class="sv-chev"
                width="15"
                height="15"
                viewBox="0 0 16 16"
                fill="none"
                stroke="var(--gold-deep)"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 6l4 4 4-4" />
              </svg>
            </summary>
            <div class="sv-words-list">
              {quoteList.map((q) => (
                <figure class="sv-words-quote">
                  <span class="sv-words-mark" aria-hidden="true">
                    &ldquo;
                  </span>
                  <div>
                    <blockquote>{q.text}</blockquote>
                    {(q.cite || q.source) && (
                      <figcaption>
                        <span class="sv-words-rule" aria-hidden="true" />
                        {q.source ? (
                          <a
                            href={q.source}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            {q.cite || "Source"}
                          </a>
                        ) : (
                          q.cite
                        )}
                        {q.translation && (
                          <span class="sv-quote-trans"> · {q.translation}</span>
                        )}
                      </figcaption>
                    )}
                  </div>
                </figure>
              ))}
            </div>
          </details>
        )
      }

      {/* ── reference apparatus (deep-dives + kin) ── */}
      {
        hasAfter && (
          <div class="sv-after">
            <div class="sv-after-inner">
              {hasTimeline && (
                <details class="sv-deep">
                  <summary class="sv-deep-sum">
                    <span class="eyebrow sv-deep-eb sv-tl-title">Timeline</span>
                    <span class="sv-deep-ct">
                      {profile!.timeline!.length} moments
                    </span>
                    <span class="sv-deep-rule" />
                    <span class="sv-deep-state">
                      <span class="sv-deep-show">Read</span>
                      <span class="sv-deep-hide">Hide</span>
                    </span>
                    <svg
                      class="sv-chev"
                      width="15"
                      height="15"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="var(--gold-deep)"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M4 6l4 4 4-4" />
                    </svg>
                  </summary>
                  <ol class="sv-timeline">
                    {profile!.timeline!.map((t) => (
                      <li>
                        <span class="sv-when">{t.when}</span>
                        <strong class="sv-tl-event">{t.title}</strong>
                        {t.body && <span class="sv-tbody">{t.body}</span>}
                      </li>
                    ))}
                  </ol>
                </details>
              )}

              {hasLegacy && (
                <details class="sv-deep">
                  <summary class="sv-deep-sum">
                    <h2 class="sv-deep-eb sv-legacy-title">
                      Contributions &amp; Legacy
                    </h2>
                    <span class="sv-deep-ct">
                      {profile!.sections!.length} contributions
                    </span>
                    <span class="sv-deep-rule" />
                    <span class="sv-deep-state">
                      <span class="sv-deep-show">Read</span>
                      <span class="sv-deep-hide">Hide</span>
                    </span>
                    <svg
                      class="sv-chev"
                      width="15"
                      height="15"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="var(--gold-deep)"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M4 6l4 4 4-4" />
                    </svg>
                  </summary>
                  <div class="sv-legacy-grid">
                    {profile!.sections!.map((s) => (
                      <article class="sv-legacy-card">
                        <h3>{s.heading}</h3>
                        {s.body.map((p) => (
                          <p>{p}</p>
                        ))}
                      </article>
                    ))}
                  </div>
                </details>
              )}

              {(hasWorks || hasReading) && (
                <details class="sv-deep">
                  <summary class="sv-deep-sum">
                    <span class="eyebrow sv-deep-eb">
                      Works &amp; Further Reading
                    </span>
                    <span class="sv-deep-rule" />
                    <span class="sv-deep-state">
                      <span class="sv-deep-show">Read</span>
                      <span class="sv-deep-hide">Hide</span>
                    </span>
                    <svg
                      class="sv-chev"
                      width="15"
                      height="15"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="var(--gold-deep)"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M4 6l4 4 4-4" />
                    </svg>
                  </summary>
                  <div class="sv-wr-grid">
                    {hasWorks && (
                      <section class="sv-works-after">
                        <h2>Notable Works</h2>
                        <ul class="sv-worklist-after">
                          {worksList
                            ? worksList.map((w) => (
                                <li>
                                  <em>{w.title}</em>
                                  {w.desc && (
                                    <span class="sv-work-desc">
                                      {" "}
                                      — {w.desc}
                                    </span>
                                  )}
                                </li>
                              ))
                            : m.works.map((w) => (
                                <li>
                                  <a
                                    href={w.u}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                  >
                                    {w.t}
                                  </a>
                                </li>
                              ))}
                        </ul>
                      </section>
                    )}
                    {hasReading && (
                      <section class="sv-reading">
                        <h2>Further Reading</h2>
                        {readingGroups ? (
                          <div class="sv-reading-groups">
                            {readingGroups.map((g) => (
                              <div class="sv-read-group">
                                <div class="sv-read-head">{g.heading}</div>
                                <ul class="sv-read-list">
                                  {g.items.map((it) => (
                                    <li>
                                      <em>{it.title}</em>
                                      {it.author && (
                                        <span class="sv-read-by">
                                          {" "}
                                          — {it.author}
                                        </span>
                                      )}
                                    </li>
                                  ))}
                                </ul>
                              </div>
                            ))}
                          </div>
                        ) : (
                          <ul class="sv-read-list">
                            {m.about.map((w) => (
                              <li>
                                <a
                                  href={w.u}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                >
                                  {w.t}
                                </a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </section>
                    )}
                  </div>
                </details>
              )}

              {hasCommemorated && (
                <details class="sv-deep sv-comm">
                  <summary class="sv-deep-sum">
                    <span class="eyebrow sv-deep-eb">Commemorated with</span>
                    {memberGroups.length > 1 && (
                      <span class="sv-deep-ct">
                        {memberGroups.length} commemorations
                      </span>
                    )}
                    <span class="sv-deep-rule" />
                    <span class="sv-deep-state">
                      <span class="sv-deep-show">Read</span>
                      <span class="sv-deep-hide">Hide</span>
                    </span>
                    <svg
                      class="sv-chev"
                      width="15"
                      height="15"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="var(--gold-deep)"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M4 6l4 4 4-4" />
                    </svg>
                  </summary>
                  <div class="sv-comm-list">
                    {memberGroups.map((g) => {
                      const full = groupBySlug.get(g.slug);
                      const meta = full?.feast
                        ? `Commemorated together · ${full.feast}`
                        : GROUP_TYPE_LABEL[g.type] || g.type;
                      return (
                        <a
                          class="sv-comm-row"
                          href={withBase("group/" + g.slug)}
                        >
                          <div class="sv-comm-main">
                            <div class="sv-comm-name">{g.name}</div>
                            <div class="sv-comm-meta">{meta}</div>
                          </div>
                          <svg
                            class="sv-comm-glyph"
                            width="14"
                            height="14"
                            viewBox="0 0 14 14"
                            fill="none"
                            stroke="var(--celest)"
                            stroke-width="1.7"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                          >
                            <path d="M4 10 10 4M5 4h5v5" />
                          </svg>
                        </a>
                      );
                    })}
                  </div>
                </details>
              )}

              {hasCompanions && (
                <section class="sv-section sv-related">
                  <div class="sv-secthead">
                    <span class="eyebrow">{kinLabel}</span>
                  </div>
                  {kinIntro && <p class="sv-kin-intro">{kinIntro}</p>}
                  <div class="sv-relrow">
                    {companions.map((card) => {
                      const nm = card.saint ? splitName(card.saint.name) : null;
                      const av = card.saint
                        ? saintAvatar(card.saint, 74, 92, {
                            type: primaryRank(card.saint),
                          })
                        : saintAvatar({ name: stripHon(card.name) }, 74, 92);
                      const body = (
                        <>
                          <div class="sv-relav" set:html={av} />
                          {card.rel && <div class="sv-relrel">{card.rel}</div>}
                          <div class="sv-relname">
                            {nm ? nm.title : stripHon(card.name)}
                            {nm?.epithet && (
                              <span class="sv-relep">{nm.epithet}</span>
                            )}
                          </div>
                        </>
                      );
                      return card.href ? (
                        <a class="sv-relcard" href={withBase(card.href)}>
                          {body}
                        </a>
                      ) : card.external ? (
                        <a
                          class="sv-relcard"
                          href={card.external}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {body}
                        </a>
                      ) : (
                        <div class="sv-relcard">{body}</div>
                      );
                    })}
                  </div>
                </section>
              )}

              {m.notes && (
                <section class="sv-section sv-notes-sec">
                  <div class="sv-secthead">
                    <span class="eyebrow">Notes</span>
                  </div>
                  <p class="sv-notes-text">{m.notes}</p>
                </section>
              )}

              {m.sources && (
                <div class="sv-after-sources">Sources: {m.sources}</div>
              )}
            </div>
          </div>
        )
      }
    </main>
  </div>
</div>

<script>
  /* Context-aware back link: a saint reached from the Saints of America page
     should send the reader back there, not to the default /search list. We key
     off the real navigation referrer (same-origin only). */
  const link = document.querySelector<HTMLAnchorElement>(".sv-back-link");
  const label = link?.querySelector<HTMLElement>(".sv-back-label");
  if (link && label && document.referrer) {
    try {
      const ref = new URL(document.referrer);
      if (
        ref.origin === location.origin &&
        /\/america\/?$/.test(ref.pathname)
      ) {
        const def = link.getAttribute("href") || "/search";
        link.setAttribute("href", def.replace(/search\/?$/, "america"));
        label.textContent = "Back to Saints of America";
      }
    } catch {
      /* malformed referrer — keep the default link */
    }
  }

  /* Share / cite: copy a plain citation + canonical URL to the clipboard, with
     a Web-Share fallback on devices that support it. */
  const share = document.querySelector<HTMLButtonElement>(".sv-share");
  const shareLabel = share?.querySelector<HTMLElement>(".sv-share-label");
  if (share && shareLabel) {
    const cite = share.dataset.cite || document.title;
    const url = location.href;
    share.addEventListener("click", async () => {
      const text = `${cite} ${url}`;
      try {
        if (navigator.share) {
          await navigator.share({ title: cite, url });
          return;
        }
        await navigator.clipboard.writeText(text);
        const prev = shareLabel.textContent;
        shareLabel.textContent = "Citation copied";
        window.setTimeout(() => {
          shareLabel.textContent = prev;
        }, 1600);
      } catch {
        /* user dismissed the share sheet, or clipboard denied — no-op */
      }
    });
  }

  /* Accordion: the collapsible deep-dives start closed (markup ships without
     `open`); opening one closes any other that is open, so at most one is
     expanded at a time. */
  const deeps = Array.from(
    document.querySelectorAll<HTMLDetailsElement>("details.sv-deep"),
  );
  for (const d of deeps) {
    d.addEventListener("toggle", () => {
      if (!d.open) return;
      for (const other of deeps) {
        if (other !== d && other.open) other.open = false;
      }
    });
  }
</script>
