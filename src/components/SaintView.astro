<script>
  /* Context-aware back link: a saint reached from the Saints of America page
     should send the reader back there, not to the default /search list. We key
     off the real navigation referrer (same-origin only). */
  const link = document.querySelector<HTMLAnchorElement>(".sv-back-link");
  const label = link?.querySelector<HTMLElement>(".sv-back-label");
  if (link && label && document.referrer) {
    try {
      const ref = new URL(document.referrer);
      if (
        ref.origin === location.origin &&
        /\/america\/?$/.test(ref.pathname)
      ) {
        const def = link.getAttribute("href") || "/search";
        link.setAttribute("href", def.replace(/search\/?$/, "america"));
        label.textContent = "Back to Saints of America";
      }
    } catch {
      /* malformed referrer — keep the default link */
    }
  }

  /* Share / cite: copy a plain citation + canonical URL to the clipboard, with
     a Web-Share fallback on devices that support it. */
  const share = document.querySelector<HTMLButtonElement>(".sv-share");
  const shareLabel = share?.querySelector<HTMLElement>(".sv-share-label");
  if (share && shareLabel) {
    const cite = share.dataset.cite || document.title;
    const url = location.href;
    share.addEventListener("click", async () => {
      const text = `${cite} ${url}`;
      try {
        if (navigator.share) {
          await navigator.share({ title: cite, url });
          return;
        }
        await navigator.clipboard.writeText(text);
        const prev = shareLabel.textContent;
        shareLabel.textContent = "Citation copied";
        window.setTimeout(() => {
          shareLabel.textContent = prev;
        }, 1600);
      } catch {
        /* user dismissed the share sheet, or clipboard denied — no-op */
      }
    });
  }

  /* Accordion: the collapsible deep-dives start closed (markup ships without
     `open`); opening one closes any other that is open, so at most one is
     expanded at a time. */
  const deeps = Array.from(
    document.querySelectorAll<HTMLDetailsElement>("details.sv-deep"),
  );
  for (const d of deeps) {
    d.addEventListener("toggle", () => {
      if (!d.open) return;
      for (const other of deeps) {
        if (other !== d && other.open) other.open = false;
      }
    });
  }

  /* Depictions carousel: scroll-snap track with gold prev/next arrows that fade
     in/out at the edges. Progressive enhancement — without JS the track still
     scrolls natively (trackpad / touch). Mirrors the america-carousel island. */
  const deps = document.querySelector<HTMLElement>(".sv-deps");
  if (deps) {
    const track = deps.querySelector<HTMLElement>(".sv-deps-track");
    const prev = deps.querySelector<HTMLButtonElement>(".sv-deps-arrow.prev");
    const next = deps.querySelector<HTMLButtonElement>(".sv-deps-arrow.next");
    if (track && prev && next) {
      const update = () => {
        prev.classList.toggle("show", track.scrollLeft > 6);
        next.classList.toggle(
          "show",
          track.scrollLeft + track.clientWidth < track.scrollWidth - 6,
        );
      };
      // Advance by a full page of whole cards (derived from the live card width
      // + gap), so each press reveals brand-new cards and lands on a card edge.
      const page = (dir: number) => {
        const card = track.querySelector<HTMLElement>(".sv-dep");
        const gap = parseFloat(getComputedStyle(track).columnGap) || 20;
        const cardW = card
          ? card.getBoundingClientRect().width
          : track.clientWidth;
        const stride = cardW + gap;
        const perView = Math.max(1, Math.round(track.clientWidth / stride));
        track.scrollBy({ left: dir * perView * stride, behavior: "smooth" });
      };
      prev.addEventListener("click", () => page(-1));
      next.addEventListener("click", () => page(1));
      track.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
      update();
    }
  }
</script>
