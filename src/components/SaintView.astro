---
/* Full data-driven saint page (the Claude Design "SaintViewA" — a deep-blue
   icon rail carrying the icon + demoted taxonomy, an ivory column carrying the
   human story). Replaces the old quick-look modal card. Pure build-time render
   from the Saint record via toSaintView(); Astro auto-escapes interpolations. */
import type { Saint } from "../lib/types";
import { toSaintView } from "../lib/saintView";
import { saintAvatar } from "../lib/icons";
import { primaryRank } from "../lib/saints";
import { esc, withBase } from "../lib/format";
import { SAINT_PROFILES } from "../lib/saint-profiles";
import SaintProfile from "./SaintProfile.astro";
import { themeBySlug, relatedByThemes } from "../lib/themes";
import { SAINTS } from "../lib/data";

interface Props {
  saint: Saint;
}
const { saint } = Astro.props;
const m = toSaintView(saint);
const profile = SAINT_PROFILES[saint.id];

// Curated related (from a rich profile) wins; otherwise derive by shared themes.
const derivedRelated =
  profile && profile.related && profile.related.length
    ? []
    : relatedByThemes(saint, SAINTS, 6);

// The large rail icon. A real portrait fills a plain rounded rectangle (the
// design's icon-slot) — NOT the arched monogram clip, whose path() coordinates
// are fixed near 120×150px and would only fill a corner at this size. The
// monogram tier is a viewBox SVG, so it scales to any size cleanly.
let portrait: string;
if (saint.image) {
  const raw = String(saint.image).replace(/['"\\)\s<>]/g, "");
  const url = esc(/^(https?:)?\/\//.test(raw) ? raw : withBase(raw));
  portrait = `<div class="sv-icon-img" style="background:#efe3cb center/cover no-repeat url('${url}')"></div>`;
} else {
  portrait = saintAvatar(saint, 286, 358, { type: primaryRank(saint) });
}
const showCredit = !!saint.image && !!(m.imageCredit || m.imageLicense);
const knownFor = m.virtues.length > 0 || m.vocation.length > 0;
const hasWorks =
  (m.works.length > 0 || m.about.length > 0) &&
  !(profile && (profile.works || profile.reading));
const linkGlyph = {
  hymn: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--byz)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l11-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="17" cy="16" r="3"/></svg>`,
  icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--byz)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"/><circle cx="12" cy="9" r="2.4"/><path d="M7 19c1.4-3 8.6-3 10 0"/></svg>`,
  video: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--byz)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m10 9 5 3-5 3z" fill="var(--byz)" stroke="none"/></svg>`,
};
---

<div
  class="saintview"
  id="saint-detail"
  data-id={saint.id}
  data-name={saint.name}
>
  {/* breadcrumb back bar */}
  <div class="sv-back">
    <a href={withBase("search")} class="sv-back-link">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"><path d="M14 6l-6 6 6 6"></path></svg
      >
      <span class="sv-back-label">Back to the saints</span>
    </a>
    <span class="sv-sep">/</span>
    <span class="sv-crumb">{m.crumb}</span>
    <span class="sv-sep">/</span>
    <span class="sv-here">{m.honorificName}</span>
  </div>

  <div class="sv-grid">
    {/* ── ICON RAIL ── */}
    <aside class="sv-rail">
      <div class="sv-icon-frame">
        <div class="sv-icon-inner" set:html={portrait} />
      </div>
      {
        showCredit && (
          <div class="sv-icon-cap">
            Icon ·{" "}
            {m.imageSource ? (
              <a href={m.imageSource} target="_blank" rel="noopener noreferrer">
                {m.imageCredit || "source"}
              </a>
            ) : (
              m.imageCredit
            )}
            {m.imageLicense && (
              <span class="sv-icon-lic"> · {m.imageLicense}</span>
            )}
          </div>
        )
      }

      <div class="rule sv-rail-rule"><span class="dot"></span></div>

      <div class="sv-rail-tag">
        <span class={`tag ${m.typeSlug} sv-tag-gold`}><i></i>{m.type}</span>
      </div>

      <div class="sv-feast">
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--gold-soft)"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="5" width="18" height="16" rx="2"></rect>
          <path d="M3 9h18M8 3v4M16 3v4"></path>
        </svg>
        <div>
          <div class="sv-feast-label">Feast Day</div>
          <div class="sv-feast-date">{m.feast}</div>
          {m.feastNote && <div class="sv-feast-note">{m.feastNote}</div>}
        </div>
      </div>

      {
        m.facts.length > 0 && (
          <div class="sv-glance">
            <div class="eyebrow on-blue">At a glance</div>
            <dl>
              {m.facts.map(([k, v]) => (
                <div class="sv-fact">
                  <dt>{k}</dt>
                  <dd>{v}</dd>
                </div>
              ))}
            </dl>
          </div>
        )
      }

      {
        knownFor && (
          <div class="sv-knownfor">
            <div class="eyebrow on-blue">Known for</div>
            {m.virtues.length > 0 && (
              <div class="sv-virtues">{m.virtues.join(" · ")}</div>
            )}
            {m.vocation.length > 0 && (
              <div class="sv-vocation">{m.vocation.join(" · ")}</div>
            )}
          </div>
        )
      }
    </aside>

    {/* ── CONTENT ── */}
    <main class="sv-main">
      {m.eyebrow && <div class="eyebrow sv-eyebrow">{m.eyebrow}</div>}
      <h1 class="sv-name">
        {m.title}{m.epithet && <span class="sv-epithet"> {m.epithet}</span>}
      </h1>
      {
        m.also.length > 0 && (
          <div class="sv-also">Also known as {m.also.join(" · ")}</div>
        )
      }

      {
        m.address && (
          <div class="sv-address">
            <p>{m.address}</p>
          </div>
        )
      }

      {m.brief && <p class="sv-lead">{m.brief}</p>}

      {profile && <SaintProfile profile={profile} />}

      {
        saint.themes && saint.themes.length > 0 && (
          <section class="sv-section sv-themes">
            <div class="eyebrow">Themes</div>
            <div class="sv-theme-row">
              {saint.themes.map((slug) => {
                const t = themeBySlug.get(slug);
                return t ? (
                  <a
                    class="sv-theme tag intercession"
                    href={withBase("themes/" + slug)}
                  >
                    {t.label}
                  </a>
                ) : null;
              })}
            </div>
          </section>
        )
      }

      {
        m.intercessions.length > 0 && (
          <section class="sv-section">
            <div class="eyebrow">Come to them for · Intercessions</div>
            <div class="sv-intercessions">
              {m.intercessions.map((it) => (
                <div class="sv-int-card">{it}</div>
              ))}
            </div>
          </section>
        )
      }

      {
        m.experience.length > 0 && (
          <section class="sv-section">
            <div class="eyebrow">Life experience</div>
            <div class="sv-exp">
              {m.experience.map((e) => (
                <span class="tag intercession">{e}</span>
              ))}
            </div>
          </section>
        )
      }

      {
        m.quote && (
          <section class="sv-section">
            <div class="eyebrow">In their own words</div>
            <figure class="sv-quote">
              <span class="sv-quote-mark" aria-hidden="true">
                &ldquo;
              </span>
              <div>
                <blockquote>{m.quote.text}</blockquote>
                {(m.quote.cite || m.quote.source) && (
                  <figcaption>
                    <span class="sv-quote-rule" aria-hidden="true" />
                    {m.quote.source ? (
                      <a
                        href={m.quote.source}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {m.quote.cite || "Source"}
                      </a>
                    ) : (
                      m.quote.cite
                    )}
                    {m.quote.translation && (
                      <span class="sv-quote-trans">
                        {" "}
                        · {m.quote.translation}
                      </span>
                    )}
                  </figcaption>
                )}
              </div>
            </figure>
          </section>
        )
      }

      {
        m.customs && (
          <section class="sv-section">
            <div class="sv-customs">
              <div class="eyebrow">Customs &amp; Traditions</div>
              <p>{m.customs}</p>
            </div>
          </section>
        )
      }

      {
        m.notes && (
          <section class="sv-section sv-notes">
            <div class="eyebrow">Notes</div>
            <p>{m.notes}</p>
          </section>
        )
      }

      {
        hasWorks && (
          <section class="sv-section sv-works">
            <div>
              <div class="eyebrow">Works by the Saint</div>
              <div class="sv-worklist">
                {m.works.length > 0 ? (
                  m.works.map((w) => (
                    <a
                      class="sv-work"
                      href={w.u}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <svg
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="var(--gold-deep)"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v16H6.5A2.5 2.5 0 0 0 4 20.5z" />
                        <path d="M4 20.5A2.5 2.5 0 0 1 6.5 18H20" />
                      </svg>
                      <span>{w.t}</span>
                    </a>
                  ))
                ) : (
                  <div class="sv-work-empty">No surviving written works.</div>
                )}
              </div>
            </div>
            <div>
              <div class="eyebrow">Works about the Saint</div>
              <div class="sv-worklist">
                {m.about.length > 0 ? (
                  m.about.map((w) => (
                    <a
                      class="sv-work"
                      href={w.u}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <span>{w.t}</span>
                    </a>
                  ))
                ) : (
                  <div class="sv-work-empty">
                    Lives &amp; studies to be added.
                  </div>
                )}
              </div>
            </div>
          </section>
        )
      }

      {
        (m.links.length > 0 || m.sources) && (
          <section class="sv-links">
            {m.links.map((l) => (
              <a
                href={l.href}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--ghost sv-linkbtn"
              >
                <Fragment set:html={linkGlyph[l.kind]} />
                {l.label}
                <svg
                  width="11"
                  height="11"
                  viewBox="0 0 14 14"
                  fill="none"
                  stroke="var(--celest)"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M4 10 10 4M5 4h5v5" />
                </svg>
              </a>
            ))}
          </section>
        )
      }

      {
        derivedRelated.length > 0 && (
          <section class="sv-section sv-related">
            <div class="eyebrow">Related saints</div>
            <ul class="sv-related-list">
              {derivedRelated.map((s) => (
                <li>
                  <a href={withBase("saint/" + s.id)}>{s.name}</a>
                  <span class="sv-related-rank"> · {primaryRank(s)}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {m.sources && <div class="sv-sources">Sources: {m.sources}</div>}
    </main>
  </div>
</div>

<script>
  /* Context-aware back link: a saint reached from the Saints of America page
     should send the reader back there, not to the default /search list. We key
     off the real navigation referrer (same-origin only), so the link reflects
     where the visitor actually came from — no URL params, and direct/search
     arrivals keep the default. The america href is derived from the existing
     base-prefixed href so it survives any future base-path change. */
  const link = document.querySelector<HTMLAnchorElement>(".sv-back-link");
  const label = link?.querySelector<HTMLElement>(".sv-back-label");
  if (link && label && document.referrer) {
    try {
      const ref = new URL(document.referrer);
      if (
        ref.origin === location.origin &&
        /\/america\/?$/.test(ref.pathname)
      ) {
        const def = link.getAttribute("href") || "/search";
        link.setAttribute("href", def.replace(/search\/?$/, "america"));
        label.textContent = "Back to Saints of America";
      }
    } catch {
      /* malformed referrer — keep the default link */
    }
  }
</script>
