---
/* Full data-driven saint page — REDESIGN.
   A dark iconographic HERO carries identity, icon & feast up top; a quiet
   quick-actions bar collects the explore links + share; the BODY is a light
   record rail (the demoted taxonomy) beside a single flowing story column —
   intercessions ("Come to them for") promoted to the head of the story, the
   life and the saint's words next, and the reference apparatus (timeline,
   legacy, works, kin) as collapsible deep-dives below. Pure build-time render
   from the Saint record via toSaintView(). */
import type { Saint } from "../lib/types";
import { toSaintView } from "../lib/saintView";
import { saintAvatar, reviewedDove } from "../lib/icons";
import { primaryRank } from "../lib/saints";
import { splitName } from "../lib/names";
import { esc, withBase } from "../lib/format";
import { loadProfileMap } from "../lib/saint-profiles";
import SaintProfile from "./SaintProfile.astro";
import SaintRoster from "./SaintRoster.astro";
import { themeBySlug, relatedThemeLinks } from "../lib/themes";
import { groupBySlug, GROUP_TYPE_LABEL } from "../lib/groups";
import { SAINTS } from "../lib/data";

interface Props {
  saint: Saint;
}
const { saint } = Astro.props;
const m = toSaintView(saint);
const profile = (await loadProfileMap())[saint.id];

// Editorial review state — surfaced as a full-width band beneath the hero.
const isReviewed = profile?.status === "reviewed";
const isFlagged = profile?.status === "flagged";
const isDraft =
  !!profile?.status && profile.status !== "reviewed" && !isFlagged;
const flagReasons = profile?.flagReasons ?? [];

// The human web around a saint, split into distinct collapsibles:
//   • Family — immediate kin / documented relatives (profile.family)
//   • Companions & Contemporaries — documented personal relationships
//     (profile.companions)
//   • Related Saints — curated cross-linked saints (profile.related), followed
//     by auto-generated theme links ("More Bishops", …) as "Browse similar"
// Each figure is resolved to its record where possible so the card shows the
// real portrait/monogram, a relationship label, and name + epithet. A figure
// not in the dataset still shows a monogram card; a non-saint (commemorated:
// false) shows a quiet "not commemorated" marker and no link.
const byId = new Map(SAINTS.map((s) => [s.id, s]));
// Possessive for the section labels ("In his own words").
const possessive =
  saint.gender === "Male" ? "his" : saint.gender === "Female" ? "her" : "their";
const stripHon = (n: string) => n.replace(/^(Saint|St\.?|Holy)\s+/i, "");
type Figure = {
  saint?: Saint;
  name: string;
  rel: string;
  href?: string;
  external?: string;
  commemorated?: boolean;
};
// De-duplicate across both human grids (a sibling listed under Family is not
// repeated under Companions): one shared `seen` set, Family resolved first.
const seenFig = new Set<string>();
const toCard = (f: {
  name: string;
  note?: string;
  href?: string;
  external?: string;
  commemorated?: boolean;
}): Figure | null => {
  const id = f.href?.match(/OS-\d{4,}/)?.[0];
  const key = id || f.name;
  if (seenFig.has(key)) return null;
  seenFig.add(key);
  return {
    saint: id ? byId.get(id) : undefined,
    name: f.name,
    rel: f.note ?? "",
    href: f.href,
    external: f.external,
    commemorated: f.commemorated,
  };
};
const familyCards = (profile?.family?.figures ?? [])
  .map(toCard)
  .filter((c): c is Figure => c !== null);
// Companions resolved before related so the shared `seenFig` set keeps a figure
// in exactly one human grid (Family → Companions → Related, in that order).
const companionCards = (profile?.companions ?? [])
  .map(toCard)
  .filter((c): c is Figure => c !== null);
// Curated "Related Saints" — specific cross-linked saints (theological,
// typological, vocational, or successional links), distinct from the
// auto-generated theme links below. Supersedes the legacy `related`-as-
// companions fallback.
const relatedCards = (profile?.related ?? [])
  .map(toCard)
  .filter((c): c is Figure => c !== null);
const familyHeading = profile?.family?.heading;
const familyIntro = profile?.family?.intro;
const themeLinks = relatedThemeLinks(saint, 6);

// One avatar card (portrait/monogram + relationship label + name), shared by the
// Family and Companions grids. Returns an HTML string (rendered via <Fragment
// set:html>) so the markup lives in exactly one place.
const kinCard = (card: Figure): string => {
  const nm = card.saint ? splitName(card.saint.name) : null;
  const av = card.saint
    ? saintAvatar(card.saint, 74, 92, { type: primaryRank(card.saint) })
    : saintAvatar({ name: stripHon(card.name) }, 74, 92);
  const title = nm ? nm.title : stripHon(card.name);
  const inner =
    `<div class="sv-relav">${av}</div>` +
    (card.rel ? `<div class="sv-relrel">${esc(card.rel)}</div>` : "") +
    `<div class="sv-relname">${esc(title)}` +
    (nm?.epithet ? `<span class="sv-relep">${esc(nm.epithet)}</span>` : "") +
    "</div>" +
    (card.commemorated === false
      ? '<div class="sv-relnc">not commemorated</div>'
      : "");
  if (card.href)
    return `<a class="sv-relcard" href="${esc(withBase(card.href))}">${inner}</a>`;
  if (card.external)
    return `<a class="sv-relcard" href="${esc(card.external)}" target="_blank" rel="noopener noreferrer">${inner}</a>`;
  return `<div class="sv-relcard">${inner}</div>`;
};

// Group-taxonomy memberships (data/saint_groups.csv) → a small "Member of"
// section linking to each group's saint-profile (/saint/[groupId]). Joined into
// the record by build.py, each membership carrying the group's own OS-#### id.
const memberGroups = saint.groups ?? [];

// Works (by the saint) and Further Reading (about the saint). A profile's rich
// lists supersede the plain CSV-derived ones; otherwise the CSV search-link
// lists are shown.
const worksList = profile?.works?.length ? profile.works : null;
const hasWorks = !!worksList || m.works.length > 0;
const readingGroups = profile?.reading?.length ? profile.reading : null;
const hasReading = !!readingGroups || m.about.length > 0;

const hasTimeline = !!profile?.timeline?.length;
const hasLegacy = !!profile?.sections?.length;
const hasInfluence = !!profile?.influence?.places?.length;
const hasFamily = familyCards.length > 0;
const hasCompanions = companionCards.length > 0;
const hasRelated = relatedCards.length > 0;
const hasRelatedThemes = themeLinks.length > 0;
const hasCommemorated = memberGroups.length > 0;
const hasAfter =
  hasTimeline ||
  hasLegacy ||
  hasInfluence ||
  hasWorks ||
  hasReading ||
  hasCommemorated ||
  hasFamily ||
  hasCompanions ||
  hasRelated ||
  hasRelatedThemes ||
  !!m.notes ||
  !!m.sources;

// The large hero icon. A real portrait fills a plain rounded rectangle (the
// design's icon-slot) — NOT the arched monogram clip, whose path() coordinates
// are fixed near 120×150px. The monogram tier is a viewBox SVG, so it scales.
let portrait: string;
if (saint.image) {
  const raw = String(saint.image).replace(/['"\\)\s<>]/g, "");
  const url = esc(/^(https?:)?\/\//.test(raw) ? raw : withBase(raw));
  portrait = `<div class="sv-icon-img" style="background:#16304c center top/cover no-repeat url('${url}')"></div>`;
} else {
  portrait = saintAvatar(saint, 286, 358, { type: primaryRank(saint) });
}
const showCredit =
  !!saint.image && !!(m.imageCredit || m.imageLicense || m.imagePermission);

// "Depictions & Icons" carousel (data/saint_depictions.csv) — museum masters, PD
// originals, and vendor-permission icons available to commission/order. Each card
// links to its source; a permission card honors the grant by linking to the
// specific vendor icon page. The build already excluded any revoked-vendor cards.
const depictions = m.depictions;
const depImg = (raw: string) => {
  const clean = String(raw).replace(/['"\\)\s<>]/g, "");
  return esc(/^(https?:)?\/\//.test(clean) ? clean : withBase(clean));
};
const knownFor = m.virtues.length > 0 || m.vocation.length > 0;
const citation = `${m.honorificName}. Cloud of Witnesses.`;

// "In their own words" — a curated profile `quotes` array (multiple, verbatim
// PD) wins; otherwise the single sourced quote from saint_quotes.csv. Gender
// picks the possessive for the section label.
const quoteList = profile?.quotes?.length
  ? profile.quotes.map((q) => ({
      text: q.text,
      cite: [q.work, q.locus].filter(Boolean).join(", "),
      source: q.source,
      translation: q.translation,
    }))
  : m.quote
    ? [m.quote]
    : [];
const wordsLabel = `In ${possessive} own words`;
---

<div
  class="saintview sv2"
  id="saint-detail"
  data-id={saint.id}
  data-name={saint.name}
>
  {/* ══════════════ HERO ══════════════ */}
  <section class="sv-hero">
    <div class="sv-hero-inner">
      {/* breadcrumb */}
      <nav class="sv-hero-crumb" aria-label="Breadcrumb">
        <a href={withBase("search")} class="sv-back-link">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M14 6l-6 6 6 6"></path></svg
          >
          <span class="sv-back-label">Back to the saints</span>
        </a>
        <span class="sv-sep">/</span>
        <span class="sv-here">{m.honorificName}</span>
      </nav>

      <div class="sv-hero-grid">
        {/* framed icon + credit */}
        <div class="sv-hero-icon">
          <div class="sv-icon-frame">
            <div class="sv-icon-inner" set:html={portrait} />
          </div>
          {
            /* Permission images link "Original icon" to the specific vendor
               page (imageSource) per the grant. m.imageVendorHome (the vendor's
               icon homepage) is also available, reserved for a future
               vendor-homepage link. */
            showCredit &&
              (m.imagePermission ? (
                <div class="sv-icon-cap">
                  {m.imageAttribution}
                  {m.imageSource && (
                    <>
                      {" "}
                      Original icon:{" "}
                      <a
                        href={m.imageSource}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        View on {m.imageVendor}
                      </a>
                    </>
                  )}
                </div>
              ) : (
                <div class="sv-icon-cap">
                  <span class="sv-icon-cap-eb">Icon</span> ·{" "}
                  {m.imageSource ? (
                    <a
                      href={m.imageSource}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {m.imageCredit || "source"}
                    </a>
                  ) : (
                    m.imageCredit
                  )}
                  {m.imageLicense && (
                    <span class="sv-icon-lic">{m.imageLicense}</span>
                  )}
                </div>
              ))
          }
        </div>

        {/* identity */}
        <div class="sv-hero-id">
          <div class="sv-hero-tagrow">
            <span class={`tag ${m.typeSlug} sv-tag-gold`}><i></i>{m.type}</span>
            {m.eyebrow && <span class="eyebrow on-blue">{m.eyebrow}</span>}
          </div>

          <h1 class="sv-name">
            {m.title}{m.epithet && <span class="sv-epithet"> {m.epithet}</span>}
            {isReviewed && <Fragment set:html={reviewedDove(44)} />}
          </h1>
          {profile?.lifespan && <p class="sv-lifespan">{profile.lifespan}</p>}
          {
            m.also.length > 0 && (
              <div class="sv-also">Also known as {m.also.join(" · ")}</div>
            )
          }

          <div class="sv-hero-rule"></div>

          {m.brief && <p class="sv-lead">{m.brief}</p>}

          <div class="sv-feast">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--gold-soft)"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="16" rx="2"></rect>
              <path d="M3 9h18M8 3v4M16 3v4"></path>
            </svg>
            <div class="sv-feast-main">
              <div class="sv-feast-label">Feast Day</div>
              <div class="sv-feast-date">{m.feast}</div>
              {
                m.feastOld && (
                  <div class="sv-feast-oc">Old Calendar · {m.feastOld}</div>
                )
              }
            </div>
            {m.feastNote && <div class="sv-feast-note">{m.feastNote}</div>}
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ══════════════ QUICK ACTIONS ══════════════ */}
  <div class="sv-actions">
    <div class="sv-actions-inner">
      {
        m.links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--ghost sv-explore-link"
          >
            {l.label}
            <svg
              width="11"
              height="11"
              viewBox="0 0 14 14"
              fill="none"
              stroke="var(--celest)"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 10 10 4M5 4h5v5" />
            </svg>
          </a>
        ))
      }
      <div class="sv-actions-spacer"></div>
      <a
        href={withBase("corrections?subject=" + encodeURIComponent(m.name))}
        class="btn btn--ghost sv-correct-link"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--celest)"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 20h9"></path>
          <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
        </svg>
        <span class="sv-correct-label">Suggest a correction</span>
      </a>
      <button type="button" class="btn btn--gold sv-share" data-cite={citation}>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--byz-ink)"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <path d="m8.6 13.5 6.8 4M15.4 6.5l-6.8 4"></path>
        </svg>
        <span class="sv-share-label">Share / cite</span>
      </button>
    </div>
  </div>

  {/* ══════════════ REVIEW STATE BAND ══════════════ */}
  {
    (isFlagged || isDraft) && (
      <div
        class={`sv-state ${isFlagged ? "sv-state--flag" : "sv-state--draft"}`}
        role={isFlagged ? "alert" : "status"}
      >
        <div class="sv-state-inner">
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            class="sv-state-ico"
            aria-hidden="true"
          >
            <path
              d="M10 1.5 19 18 1 18 Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linejoin="round"
            />
            <rect
              x="9.1"
              y="7"
              width="1.8"
              height="5.4"
              rx=".9"
              fill="currentColor"
            />
            <circle cx="10" cy="15" r="1.05" fill="currentColor" />
          </svg>
          <span class="sv-state-label">{isFlagged ? "Flagged" : "Draft"}</span>
          <span class="sv-state-div" />
          <div class="sv-state-body">
            {isFlagged ? (
              flagReasons.length > 0 ? (
                <ul class="sv-state-list">
                  {flagReasons.map((r) => (
                    <li>
                      {r.claim && <span class="sv-state-claim">{r.claim}</span>}
                      {r.claim && r.detail ? " — " : ""}
                      {r.detail}
                    </li>
                  ))}
                </ul>
              ) : (
                "Flagged for review — this entry may contain errors or unverified claims."
              )
            ) : (
              "Draft — pending review. Not yet verified for publication."
            )}
          </div>
        </div>
      </div>
    )
  }

  {/* ══════════════ DEPICTIONS & ICONS CAROUSEL ══════════════ */}
  {
    depictions.length > 0 && (
      <section class="sv-deps" aria-label="Depictions and icons">
        <div class="sv-deps-inner">
          <div class="sv-deps-head">
            <div class="sv-deps-headings">
              <div class="eyebrow sv-deps-eb">Depictions &amp; Icons</div>
              <p class="sv-deps-sub">
                How the Church has written this image across the centuries —
                museum masters, hand-painted commissions, and icons you can
                order today.
              </p>
            </div>
            <div class="sv-deps-nav">
              <button
                type="button"
                class="sv-deps-arrow prev"
                aria-label="Previous depictions"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--gold-deep)"
                  stroke-width="1.9"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M14 6l-6 6 6 6" />
                </svg>
              </button>
              <button
                type="button"
                class="sv-deps-arrow next"
                aria-label="More depictions"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--gold-deep)"
                  stroke-width="1.9"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M10 6l6 6-6 6" />
                </svg>
              </button>
            </div>
          </div>

          <div class="sv-deps-track">
            {depictions.map((d) => {
              const inner = (
                <>
                  <div class="sv-dep-frame">
                    <div class="sv-dep-mat">
                      <div
                        class="sv-dep-img"
                        style={`background-image:url('${depImg(d.image)}')`}
                      />
                    </div>
                  </div>
                  <div class="sv-dep-meta">
                    {d.tag && (
                      <span class={`sv-dep-tag sv-dep-tag--${d.kind}`}>
                        {d.tag}
                      </span>
                    )}
                    <div class="sv-dep-title">
                      {d.title}
                      {d.era && <span class="sv-dep-era"> · {d.era}</span>}
                    </div>
                    {d.by && (
                      <div class="sv-dep-by">
                        <span>{d.by}</span>
                        {d.source && (
                          <svg
                            width="11"
                            height="11"
                            viewBox="0 0 14 14"
                            fill="none"
                            stroke="var(--celest)"
                            stroke-width="1.7"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                          >
                            <path d="M4 10 10 4M5 4h5v5" />
                          </svg>
                        )}
                      </div>
                    )}
                  </div>
                </>
              );
              return d.source ? (
                <a
                  href={d.source}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="sv-dep sv-dep--link"
                >
                  {inner}
                </a>
              ) : (
                <div class="sv-dep">{inner}</div>
              );
            })}
          </div>
        </div>
      </section>
    )
  }

  {/* ══════════════ BODY ══════════════ */}
  <div class="sv-body">
    {/* ── RECORD RAIL (the demoted taxonomy) ── */}
    <aside class="sv-rail">
      {
        m.facts.length > 0 && (
          <div class="sv-glance">
            <div class="eyebrow">At a glance</div>
            <dl>
              {m.facts.map(([k, v]) => (
                <div class="sv-fact">
                  <dt>{k}</dt>
                  <dd>{v}</dd>
                </div>
              ))}
            </dl>
          </div>
        )
      }

      {
        knownFor && (
          <div class="sv-knownfor">
            <div class="eyebrow">Known for</div>
            {m.virtues.length > 0 && (
              <div class="sv-virtues">{m.virtues.join(" · ")}</div>
            )}
            {m.vocation.length > 0 && (
              <div class="sv-vocation">{m.vocation.join(" · ")}</div>
            )}
          </div>
        )
      }

      {
        profile?.patronage && profile.patronage.length > 0 && (
          <div class="sv-rail-block sv-patron">
            <div class="eyebrow">Patron of</div>
            <div class="sv-rail-chips">
              {profile.patronage.map((p) => (
                <span class="sv-rail-chip">{p}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        m.experience.length > 0 && (
          <div class="sv-rail-block">
            <div class="eyebrow">Walked through</div>
            <p class="sv-rail-note">A companion to those who have known…</p>
            <div class="sv-rail-chips">
              {m.experience.map((e) => (
                <span class="sv-rail-chip sv-rail-chip--life">{e}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        saint.themes && saint.themes.length > 0 && (
          <div class="sv-rail-block sv-themes">
            <div class="eyebrow">Browse by theme</div>
            <div class="sv-rail-chips">
              {saint.themes.map((slug) => {
                const t = themeBySlug.get(slug);
                return t ? (
                  <a
                    class="sv-theme sv-rail-chip"
                    href={withBase("search?theme=" + slug)}
                  >
                    {t.label}
                  </a>
                ) : null;
              })}
            </div>
          </div>
        )
      }
    </aside>

    {/* ── STORY COLUMN ── */}
    <main class="sv-main">
      {
        profile?.liturgicalTitle && (
          <div class="sv-littitle">
            <div class="eyebrow sv-littitle-label">Commemorated as</div>
            <p class="sv-littitle-text">{profile.liturgicalTitle}</p>
          </div>
        )
      }

      {/* come to them for — the finder's engine, promoted */}
      {
        m.intercessions.length > 0 && (
          <section class="sv-section sv-invoked">
            <div class="sv-secthead">
              <span class="eyebrow">Come to them for</span>
            </div>
            <div class="sv-invoked-grid">
              {m.intercessions.map((it) => (
                <div class="sv-invoked-card">{it}</div>
              ))}
            </div>
          </section>
        )
      }

      {/* life (rendered by SaintProfile when a rich profile exists) */}
      {profile && <SaintProfile profile={profile} />}
      {
        !profile && m.brief && (
          <section class="sv-section sv-lifefallback">
            <div class="sv-secthead">
              <span class="eyebrow">Their life</span>
            </div>
            <p class="sv-bodytext">{m.brief}</p>
          </section>
        )
      }

      {/* customs */}
      {
        m.customs && (
          <section class="sv-section">
            <div class="sv-customs">
              <div class="eyebrow">Customs &amp; Traditions</div>
              <p>{m.customs}</p>
            </div>
          </section>
        )
      }

      {/* in their own words — a collapsible of verbatim PD quotes */}
      {
        quoteList.length > 0 && (
          <details class="sv-deep sv-words">
            <summary class="sv-deep-sum">
              <span class="eyebrow sv-deep-eb">{wordsLabel}</span>
              {quoteList.length > 1 && (
                <span class="sv-deep-ct">{quoteList.length} quotes</span>
              )}
              <span class="sv-deep-rule" />
