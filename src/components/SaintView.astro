---
/* Full data-driven saint page. A deep-blue icon rail carrying the icon, the
   demoted taxonomy, AND the reference apparatus (links, works, further reading);
   an ivory column carrying the human story — quote-led, with the most sought
   information (intercessions, themes) up top and the deep narrative below.
   Pure build-time render from the Saint record via toSaintView(). */
import type { Saint } from "../lib/types";
import { toSaintView } from "../lib/saintView";
import { saintAvatar } from "../lib/icons";
import { primaryRank } from "../lib/saints";
import { esc, withBase } from "../lib/format";
import { loadProfileMap } from "../lib/saint-profiles";
import SaintProfile from "./SaintProfile.astro";
import FigureList from "./FigureList.astro";
import { themeBySlug, relatedByThemes } from "../lib/themes";
import { SAINTS } from "../lib/data";

interface Props {
  saint: Saint;
}
const { saint } = Astro.props;
const m = toSaintView(saint);
const profile = (await loadProfileMap())[saint.id];

// Curated related figures (from a profile) win; otherwise derive by shared
// themes and present them through the same FigureList as the curated set.
const relatedFigures =
  profile && profile.related && profile.related.length
    ? profile.related
    : relatedByThemes(saint, SAINTS, 6).map((s) => ({
        name: s.name,
        note: primaryRank(s),
        href: "saint/" + s.id,
      }));

// Group-taxonomy memberships (data/saint_groups.csv) → "Commemorated with"
// links to each group's landing page. Joined into the record by build.py.
const memberGroups = saint.groups ?? [];

// Works (by the saint) and Further Reading (about the saint) both sit in the
// "after" region beneath the legacy band. A profile's rich lists supersede the
// plain CSV-derived ones; otherwise the CSV search-link lists are shown.
const worksList = profile?.works?.length ? profile.works : null;
const hasWorks = !!worksList || m.works.length > 0;
const readingGroups = profile?.reading?.length ? profile.reading : null;
const hasReading = !!readingGroups || m.about.length > 0;

// The large rail icon. A real portrait fills a plain rounded rectangle (the
// design's icon-slot) — NOT the arched monogram clip, whose path() coordinates
// are fixed near 120×150px and would only fill a corner at this size. The
// monogram tier is a viewBox SVG, so it scales to any size cleanly.
let portrait: string;
if (saint.image) {
  const raw = String(saint.image).replace(/['"\\)\s<>]/g, "");
  const url = esc(/^(https?:)?\/\//.test(raw) ? raw : withBase(raw));
  portrait = `<div class="sv-icon-img" style="background:#efe3cb center top/cover no-repeat url('${url}')"></div>`;
} else {
  portrait = saintAvatar(saint, 286, 358, { type: primaryRank(saint) });
}
const showCredit =
  !!saint.image && !!(m.imageCredit || m.imageLicense || m.imagePermission);
const knownFor = m.virtues.length > 0 || m.vocation.length > 0;
---

<div
  class="saintview"
  id="saint-detail"
  data-id={saint.id}
  data-name={saint.name}
>
  {/* breadcrumb back bar */}
  <div class="sv-back">
    <a href={withBase("search")} class="sv-back-link">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"><path d="M14 6l-6 6 6 6"></path></svg
      >
      <span class="sv-back-label">Back to the saints</span>
    </a>
    <span class="sv-sep">/</span>
    <span class="sv-crumb">{m.crumb}</span>
    <span class="sv-sep">/</span>
    <span class="sv-here">{m.honorificName}</span>
  </div>

  <div class="sv-grid">
    {/* ── ICON RAIL (icon · taxonomy · reference) ── */}
    <aside class="sv-rail">
      <div class="sv-icon-frame">
        <div class="sv-icon-inner" set:html={portrait} />
      </div>
      {
        /* Permission images link "Original icon" to the specific vendor page
           (imageSource) per the grant. m.imageVendorHome (the vendor's icon
           homepage) is also available, reserved for a future vendor-homepage link. */
        showCredit &&
          (m.imagePermission ? (
            <div class="sv-icon-cap">
              {m.imageAttribution}
              {m.imageSource && (
                <>
                  {" "}
                  Original icon:{" "}
                  <a
                    href={m.imageSource}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    View on {m.imageVendor}
                  </a>
                </>
              )}
            </div>
          ) : (
            <div class="sv-icon-cap">
              Icon ·{" "}
              {m.imageSource ? (
                <a
                  href={m.imageSource}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {m.imageCredit || "source"}
                </a>
              ) : (
                m.imageCredit
              )}
              {m.imageLicense && (
                <span class="sv-icon-lic"> · {m.imageLicense}</span>
              )}
            </div>
          ))
      }

      <div class="rule sv-rail-rule"><span class="dot"></span></div>

      <div class="sv-rail-tag">
        <span class={`tag ${m.typeSlug} sv-tag-gold`}><i></i>{m.type}</span>
      </div>

      <div class="sv-feast">
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--gold-soft)"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="5" width="18" height="16" rx="2"></rect>
          <path d="M3 9h18M8 3v4M16 3v4"></path>
        </svg>
        <div>
          <div class="sv-feast-label">Feast Day</div>
          <div class="sv-feast-date">{m.feast}</div>
          {m.feastNote && <div class="sv-feast-note">{m.feastNote}</div>}
        </div>
      </div>

      {
        (m.facts.length > 0 || m.intercessions.length > 0) && (
          <div class="sv-glance">
            <div class="eyebrow on-blue">At a glance</div>
            {m.facts.length > 0 && (
              <dl>
                {m.facts.map(([k, v]) => (
                  <div class="sv-fact">
                    <dt>{k}</dt>
                    <dd>{v}</dd>
                  </div>
                ))}
              </dl>
            )}
            {m.intercessions.length > 0 && (
              <div class="sv-glance-int">
                <div class="sv-glance-int-label">Come to them for</div>
                <div class="sv-rail-chips">
                  {m.intercessions.map((it) => (
                    <span class="sv-rail-chip">{it}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )
      }

      {
        knownFor && (
          <div class="sv-knownfor">
            <div class="eyebrow on-blue">Known for</div>
            {m.virtues.length > 0 && (
              <div class="sv-virtues">{m.virtues.join(" · ")}</div>
            )}
            {m.vocation.length > 0 && (
              <div class="sv-vocation">{m.vocation.join(" · ")}</div>
            )}
          </div>
        )
      }

      {
        saint.themes && saint.themes.length > 0 && (
          <div class="sv-rail-block sv-themes">
            <div class="eyebrow on-blue">Themes</div>
            <div class="sv-rail-chips">
              {saint.themes.map((slug) => {
                const t = themeBySlug.get(slug);
                return t ? (
                  <a
                    class="sv-theme sv-rail-chip"
                    href={withBase("search?theme=" + slug)}
                  >
                    {t.label}
                  </a>
                ) : null;
              })}
            </div>
          </div>
        )
      }

      {
        m.experience.length > 0 && (
          <div class="sv-rail-block">
            <div class="eyebrow on-blue">Life experience</div>
            <div class="sv-rail-chips">
              {m.experience.map((e) => (
                <span class="sv-rail-chip">{e}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        profile?.patronage && profile.patronage.length > 0 && (
          <div class="sv-rail-block sv-patron">
            <div class="eyebrow on-blue">Patronage</div>
            <div class="sv-rail-chips">
              {profile.patronage.map((p) => (
                <span class="sv-rail-chip">{p}</span>
              ))}
            </div>
          </div>
        )
      }
    </aside>

    {/* ── STORY COLUMN (quote-led; sought info up top; narrative below) ── */}
    <main class="sv-main">
      {m.eyebrow && <div class="eyebrow sv-eyebrow">{m.eyebrow}</div>}
      <h1 class="sv-name">
        {m.title}{m.epithet && <span class="sv-epithet"> {m.epithet}</span>}
      </h1>
      {
        profile?.liturgicalTitle && (
          <div class="sv-littitle">
            <div class="eyebrow sv-littitle-label">Commemorated as</div>
            <p class="sv-littitle-text">{profile.liturgicalTitle}</p>
          </div>
        )
      }
      {profile?.lifespan && <p class="sv-lifespan">{profile.lifespan}</p>}
      {
        m.also.length > 0 && (
          <div class="sv-also">Also known as {m.also.join(" · ")}</div>
        )
      }

      {m.brief && <p class="sv-lead">{m.brief}</p>}

      {
        m.quote && (
          <section class="sv-section sv-quotewrap">
            <figure class="sv-quote">
              <span class="sv-quote-mark" aria-hidden="true">
                &ldquo;
              </span>
              <div>
                <blockquote>{m.quote.text}</blockquote>
                {(m.quote.cite || m.quote.source) && (
                  <figcaption>
                    <span class="sv-quote-rule" aria-hidden="true" />
                    {m.quote.source ? (
                      <a
                        href={m.quote.source}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {m.quote.cite || "Source"}
                      </a>
                    ) : (
                      m.quote.cite
                    )}
                    {m.quote.translation && (
                      <span class="sv-quote-trans">
                        {" "}
                        · {m.quote.translation}
                      </span>
                    )}
                  </figcaption>
                )}
              </div>
            </figure>
          </section>
        )
      }

      {profile && <SaintProfile profile={profile} />}

      {
        m.customs && (
          <section class="sv-section">
            <div class="sv-customs">
              <div class="eyebrow">Customs &amp; Traditions</div>
              <p>{m.customs}</p>
            </div>
          </section>
        )
      }

      {
        m.links.length > 0 && (
          <section class="sv-section sv-explore">
            <div class="eyebrow">Explore</div>
            <div class="sv-explore-row">
              {m.links.map((l) => (
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn--ghost sv-explore-link"
                >
                  {l.label}
                  <svg
                    width="11"
                    height="11"
                    viewBox="0 0 14 14"
                    fill="none"
                    stroke="var(--celest)"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M4 10 10 4M5 4h5v5" />
                  </svg>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </main>
  </div>

  {
    /* ── Timeline — a full-width band beneath the columns, above the legacy ── */
  }
  {
    profile?.timeline?.length && (
      <section class="sv-tlband">
        <div class="sv-tlband-inner">
          <div class="sv-tl">
            <h2 class="sv-tl-title">Timeline</h2>
            <ol class="sv-timeline">
              {profile.timeline.map((t) => (
                <li>
                  <span class="sv-when">{t.when}</span>
                  <strong class="sv-tl-event">{t.title}</strong>
                  {t.body && <span class="sv-tbody">{t.body}</span>}
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>
    )
  }

  {
    /* ── Coloured panels beneath the columns (echoing the America carousels),
       all sharing one width: Contributions & Legacy = blue · Works = garnet ·
       Further Reading = forest · Family/Related/Notes = plum. ── */
  }
  {
    (profile?.sections?.length ||
      hasWorks ||
      hasReading ||
      profile?.family ||
      relatedFigures.length > 0 ||
      m.notes ||
      m.sources) && (
      <section class="sv-after">
        <div class="sv-after-inner">
          {profile?.sections && profile.sections.length > 0 && (
            <section class="sv-panel sv-panel--byz sv-legacy-panel">
              <h2 class="sv-legacy-title">Contributions &amp; Legacy</h2>
              <div class="sv-legacy-grid">
                {profile.sections.map((s) => (
                  <article class="sv-legacy-card">
                    <h3>{s.heading}</h3>
                    {s.body.map((p) => (
                      <p>{p}</p>
                    ))}
                  </article>
                ))}
              </div>
            </section>
          )}
          {hasWorks && (
            <section class="sv-panel sv-panel--garnet sv-works-after">
              <h2>Notable Works</h2>
              <ul class="sv-worklist-after">
                {worksList
                  ? worksList.map((w) => (
                      <li>
                        <em>{w.title}</em>
                        {w.desc && (
                          <span class="sv-work-desc"> — {w.desc}</span>
                        )}
                      </li>
                    ))
                  : m.works.map((w) => (
                      <li>
                        <a href={w.u} target="_blank" rel="noopener noreferrer">
                          {w.t}
                        </a>
                      </li>
                    ))}
              </ul>
            </section>
          )}
          {hasReading && (
            <section class="sv-panel sv-panel--forest sv-reading">
              <h2>Further Reading</h2>
              {readingGroups ? (
                <div class="sv-reading-groups">
                  {readingGroups.map((g) => (
                    <div class="sv-read-group">
                      <div class="sv-read-head">{g.heading}</div>
                      <ul class="sv-read-list">
                        {g.items.map((it) => (
                          <li>
                            <em>{it.title}</em>
                            {it.author && (
                              <span class="sv-read-by"> — {it.author}</span>
                            )}
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              ) : (
                <ul class="sv-read-list">
                  {m.about.map((w) => (
                    <li>
                      <a href={w.u} target="_blank" rel="noopener noreferrer">
                        {w.t}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </section>
          )}
          {(profile?.family ||
            relatedFigures.length > 0 ||
            memberGroups.length > 0 ||
            m.notes) && (
            <section class="sv-panel sv-panel--plum">
              <div class="sv-plum-grid">
                {memberGroups.length > 0 && (
                  <div class="sv-plum-block">
                    <h2>Commemorated With</h2>
                    <ul class="sv-group-list">
                      {memberGroups.map((g) => (
                        <li>
                          <a href={withBase("group/" + g.slug)}>{g.name}</a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {profile?.family && (
                  <div class="sv-plum-block">
                    <h2>{profile.family.heading}</h2>
                    {profile.family.intro && (
                      <p class="sv-fam-intro">{profile.family.intro}</p>
                    )}
                    <FigureList figures={profile.family.figures} light />
                  </div>
                )}
                {relatedFigures.length > 0 && (
                  <div class="sv-plum-block">
                    <h2>Related Saints</h2>
                    <FigureList figures={relatedFigures} light />
                  </div>
                )}
                {m.notes && (
                  <div class="sv-plum-block sv-plum-notes">
                    <h2>Notes</h2>
                    <p>{m.notes}</p>
                  </div>
                )}
              </div>
            </section>
          )}
          {m.sources && (
            <div class="sv-after-sources">Sources: {m.sources}</div>
          )}
        </div>
      </section>
    )
  }
</div>

<script>
  /* Context-aware back link: a saint reached from the Saints of America page
     should send the reader back there, not to the default /search list. We key
     off the real navigation referrer (same-origin only), so the link reflects
     where the visitor actually came from — no URL params, and direct/search
     arrivals keep the default. The america href is derived from the existing
     base-prefixed href so it survives any future base-path change. */
  const link = document.querySelector<HTMLAnchorElement>(".sv-back-link");
  const label = link?.querySelector<HTMLElement>(".sv-back-label");
  if (link && label && document.referrer) {
    try {
      const ref = new URL(document.referrer);
      if (
        ref.origin === location.origin &&
        /\/america\/?$/.test(ref.pathname)
      ) {
        const def = link.getAttribute("href") || "/search";
        link.setAttribute("href", def.replace(/search\/?$/, "america"));
        label.textContent = "Back to Saints of America";
      }
    } catch {
      /* malformed referrer — keep the default link */
    }
  }
</script>
