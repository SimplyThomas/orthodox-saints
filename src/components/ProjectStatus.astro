    ],
    upcomingLabel: "Section progress",
    checklist: [
      ["done", "The Nine Orders of Angels"],
      ["done", "Named Archangels in Orthodox Tradition"],
      ["done", "Guardian Angels"],
      ["done", "Biblical angelic events"],
      ["done", "Angels throughout Holy Scripture"],
