---
/* Homepage "Project Status" section — A Living Encyclopedia.
   A curated, museum-exhibit view of what's complete, in progress, and planned.
   Designed to live on the homepage long-term: edit the data arrays below
   (STATUS_CARDS, TIMELINE) and the layout follows.
   Ported from the Cloud of Witnesses design system (ProjectStatus.jsx). */
import EyebrowRule from "./EyebrowRule.astro";
import { withBase } from "../lib/format";

type CheckState = "done" | "wip" | "plan" | "todo";

/* ---- status vocabulary (colored diamond markers) ---- */
const PS_STATUS = {
  complete: {
    label: "Complete",
    color: "var(--byz-green)",
    bg: "rgba(31,94,84,.10)",
  },
  progress: {
    label: "In Progress",
    color: "var(--gold-deep)",
    bg: "rgba(212,175,55,.16)",
  },
  review: {
    label: "Under Review",
    color: "var(--celest)",
    bg: "rgba(74,111,150,.14)",
  },
  planned: {
    label: "Planned",
    color: "var(--ink-soft)",
    bg: "rgba(35,76,122,.07)",
  },
  low: { label: "Low Priority", color: "#5a5347", bg: "rgba(33,48,63,.07)" },
} as const;
type StatusKey = keyof typeof PS_STATUS;

interface StatusCard {
  id: string;
  icon: string;
  /* optional custom PNG under static/home-icons/; falls back to the `icon` SVG */
  iconImage?: string;
  status: StatusKey;
  title: string;
  span?: number;
  ribbon?: string;
  priority?: string;
  desc: string[];
  upcomingLabel?: string;
  checklist?: [CheckState, string][];
  collab?: { name: string; url?: string }[];
  milestone?: { label: string; text: string };
  futureGoals?: string[];
  note?: string | string[];
}

/* ---- the status cards ---- */
const STATUS_CARDS: StatusCard[] = [
  {
    id: "saints",
    icon: "book",
    iconImage: "home-icons/saint-database-icon.png",
    status: "progress",
    title: "Saint Database",
    span: 2,
    desc: [
      "Over 2,700 saints currently have profiles.",
      "We are systematically reviewing every saint page to expand biographies, improve historical accuracy, add citations, and correct errors.",
      "Progress updates are posted weekly.",
    ],
    checklist: [
      ["done", "2,700+ saint profiles"],
      ["done", "Core database complete"],
      ["done", "Search completed"],
      ["done", "Daily commemorations"],
      ["wip", "Biography expansion"],
    ],
    milestone: {
      label: "This week:",
      text: "The first 500 profiles have been reviewed and are being worked on.",
    },
    note: [
      "An issue was found within the group profiles and synaxes — progress is paused while we work through it and update information.",
      "Everything available on the public site has been verified; it is just a little sparse. This is a family project and slow going — thank you for your patience as we add to it.",
    ],
  },
  {
    id: "angels",
    icon: "wing",
    iconImage: "home-icons/heavenly-hosts-icon.png",
    status: "progress",
    priority: "High Priority",
    title: "The Heavenly Hosts",
    span: 2,
    ribbon: "In Progress",
    desc: [
      "One of the largest expansions of A Cloud of Witnesses is a comprehensive Orthodox encyclopedia dedicated to the holy angels and heavenly powers.",
