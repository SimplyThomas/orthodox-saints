---
/* A single feed card in the news river: framed plate, category tag, serif
   headline, date · location meta, summary, and a "read the account" cue. */
import type { NewsItem } from "../../lib/news";
import { NEWS_CAT } from "../../lib/news";
import { withBase } from "../../lib/format";
import NewsPlate from "./NewsPlate.astro";

interface Props {
  n: NewsItem;
  tone?: "blue" | "ivory";
}
const { n, tone = "blue" } = Astro.props;
const cat = NEWS_CAT[n.cat];
const haystack =
  `${n.headline} ${n.location} ${n.summary} ${n.saint.name} ${cat.name}`.toLowerCase();
---

<a
  class="news-feed-card"
  href={withBase(`news/${n.id}`)}
  data-cat={n.cat}
  data-catname={cat.name}
  data-search={haystack}
>
  <NewsPlate
    saint={n.saint}
    tone={tone}
    height={tone === "ivory" ? 168 : 196}
    avatar={tone === "ivory" ? 78 : 88}
    motif={n.cat === "apparitions" ? "cross" : "dome"}
    slug={n.location.toUpperCase()}
  />
  <div class="nfc-body">
    <span class="news-tag" style={`color:${cat.ink};background:${cat.bg}`}>
      <i></i>{cat.name}
    </span>
    <h3 class="nfc-h">{n.headline}</h3>
    <div class="news-meta">
      <span class="nm-item">
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><rect x="3" y="4.5" width="18" height="17" rx="2"></rect><path
            d="M3 9h18M8 2.5v4M16 2.5v4"></path></svg
        >{n.date}
      </span>
      <span class="nm-item">
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M12 21s7-6.4 7-11a7 7 0 1 0-14 0c0 4.6 7 11 7 11Z"
          ></path><circle cx="12" cy="10" r="2.4"></circle></svg
        >{n.location}
      </span>
    </div>
    <p class="nfc-sum">{n.summary}</p>
    <span class="nfc-read">
      Read the account
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg
      >
    </span>
  </div>
</a>
