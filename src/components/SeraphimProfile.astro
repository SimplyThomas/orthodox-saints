    font-family: var(--text);
    font-weight: 700;
    color: var(--byz-deep);
    font-size: 15px;
    letter-spacing: 0.02em;
  }
  .sr-tl-body h4 {
    margin: 2px 0 4px;
    font-size: 16px;
