    font-weight: 600;
  }
  .sr-tl-body p {
    font-size: 15.5px !important;
    line-height: 1.6 !important;
    margin: 0 !important;
  }
  .sr-tl-figures {
    margin-top: 8px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .sr-chip {
    font-family: var(--text);
    font-size: 12.5px;
    padding: 3px 10px;
    border-radius: 12px;
    background: #eaf0f6;
    color: var(--byz-deep);
    text-decoration: none;
    border: 1px solid #d3e0ec;
  }
  a.sr-chip:hover {
    background: var(--gold-soft);
  }
  .sr-chip--plain {
    background: transparent;
    color: var(--celest);
    border-style: dashed;
  }
  .sr-src {
    font-family: var(--text);
