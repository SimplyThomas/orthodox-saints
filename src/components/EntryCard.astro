---
// A member-card for the apocryphal-work directories, matching the archangels
// hub member cards (thumb | name + meaning + brief). Renders as a link when the
// being has its own page (a host record or related href), else a static card.
interface Props {
  name: string;
  meaning?: string;
  blurb?: string;
  href?: string | null;
  thumb?: string | null;
}
const { name, meaning, blurb, href, thumb } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  class:list={["member-card", { "member-card--static": !href }]}
  {...href ? { href } : {}}
>
  <span class="member-thumb">
    {
      thumb ? (
        <img src={thumb} alt={name} loading="lazy" />
      ) : (
        <span class="member-mono" aria-hidden="true">
          {name.charAt(0)}
        </span>
      )
    }
  </span>
  <span class="member-name">{name}</span>
  {meaning && <span class="member-meaning">{meaning}</span>}
  {blurb && <span class="member-brief">{blurb}</span>}
</Tag>

<style>
  .member-card {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto auto;
    column-gap: 0.7rem;
    align-items: center;
    padding: 0.8rem 0.9rem;
    border: 1px solid rgba(128, 128, 128, 0.28);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s,
      box-shadow 0.15s,
      transform 0.1s;
  }
  a.member-card:hover {
    border-color: var(--gold-deep);
    box-shadow: var(--shadow-card);
    transform: translateY(-1px);
  }
  .member-thumb {
    grid-row: 1 / 4;
    width: 3rem;
    height: 3rem;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(120% 120% at 30% 15%, #1d3e62, var(--byz-ink));
    flex: none;
  }
  .member-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .member-mono {
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--gold-soft);
  }
  .member-name {
    grid-column: 2;
    align-self: end;
    font-size: 1.08rem;
    font-weight: 600;
    color: var(--byz-deep);
  }
  .member-meaning {
    grid-column: 2;
    font-size: 0.76rem;
    font-style: italic;
    opacity: 0.7;
    line-height: 1.3;
  }
  .member-brief {
    grid-column: 2;
    font-size: 0.82rem;
    line-height: 1.4;
    opacity: 0.82;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
