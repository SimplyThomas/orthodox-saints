---
// The home "Today" band: a full-width "Saints commemorated today" card. It
// needs the visitor's real "today", so the island (cloud-band.client.ts)
// replaces the placeholder below once the card dataset fetch resolves.
---

<section class="cloud-band" id="cloud-band">
  <div class="cloud-stack">
    <div id="sotd">
      <div class="eyebrow" style="margin-bottom:14px">Today</div>
      <div
        class="sotd-card"
        style="min-height:220px;display:flex;align-items:center;justify-content:center"
      >
        <span class="stat sotd-loading"
          >Finding today&rsquo;s commemoration&hellip;</span
        >
      </div>
    </div>
  </div>
</section>
