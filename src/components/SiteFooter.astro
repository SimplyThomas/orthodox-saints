---
import { NAV } from "../lib/nav";

// Reverent dark colophon: brand block + navigation + connect, over a thin
// legal bar. The link columns mirror the primary nav (src/lib/nav.ts) — every
// dropdown group becomes a footer column — so the footer and header never
// drift. (Home is a direct link, reached via the brand wordmark above.)
const cols = NAV.filter((item) => item.children).map((item) => ({
  head: item.label,
  links: item.children!,
}));
const year = new Date().getFullYear();
---

<footer class="cw-footer">
  <div class="cw-footer-grid">
    <div class="cw-foot-brand">
      <span class="cw-foot-word">Cloud of Witnesses</span>
      <p class="cw-foot-blurb">
        A searchable communion of the saints &mdash; an open, freely given
        reference of the saints and the Church calendar.
      </p>
      <p class="cw-foot-verse">
        &ldquo;&hellip;since we are surrounded by so great a cloud of
        witnesses&hellip;&rdquo;
        <cite>Hebrews 12 : 1</cite>
      </p>
    </div>

    <div class="cw-foot-cols">
      {
        cols.map((c) => (
          <nav class="cw-foot-col" aria-label={c.head}>
            <div class="eyebrow on-blue">{c.head}</div>
            <div class="cw-foot-links">
              {c.links.map((l) => (
                <a href={l.href}>{l.label}</a>
              ))}
            </div>
          </nav>
        ))
      }

      <div class="cw-foot-col">
        <div class="eyebrow on-blue">Connect</div>
        <p class="cw-foot-note">
          For corrections, contributions, icons, or just to say hello &mdash; we
          would love to hear from you.
        </p>
        <a class="cw-foot-site" href="mailto:contact@orthodoxsaintfinder.com">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--celest-soft)"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="M3 7l9 6 9-6"></path>
          </svg>
          contact@orthodoxsaintfinder.com
        </a>
        <a
          class="cw-foot-site"
          href="https://orthodoxsaintfinder.com"
          rel="noopener"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--celest-soft)"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"
            ></path>
          </svg>
          orthodoxsaintfinder.com
        </a>
      </div>
    </div>
  </div>

  <div class="cw-footer-legal">
    <div class="cw-legal-bar">
      <span class="cw-copy">&copy; {year} CLOUD OF WITNESSES</span>
      <span class="cw-foot-flex"></span>
      <span class="cw-foot-maxim"
        >Maintained with love, coffee, and the prayers of the saints.</span
      >
    </div>
  </div>
</footer>
