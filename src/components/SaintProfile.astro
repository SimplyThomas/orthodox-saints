---
/* The IVORY story column's biography ("Life"). The timeline now lives in a
   full-width band (beside the quote) beneath the columns, rendered by SaintView;
   Contributions & Legacy, the after-region, and the rail reference are likewise
   SaintView's. So this component carries only the Life narrative. */
import type { SaintProfile } from "../lib/saint-profiles";

interface Props {
  profile: SaintProfile;
}
const { profile } = Astro.props;
const isFlagged = profile.status === "flagged";
// Anything not yet reviewed and not flagged is a plain draft.
const isDraft = profile.status && profile.status !== "reviewed" && !isFlagged;
const flagReasons = profile.flagReasons ?? [];
---

<div class="saint-profile">
  {
    isFlagged && (
      <div class="profile-flag-banner" role="alert">
        <p class="pfb-head">
          ⚑ Flagged — unresolved concern{flagReasons.length === 1 ? "" : "s"}{" "}
          from automated review against this saint's source record. Not for
          publication until resolved.
        </p>
        {flagReasons.length > 0 && (
          <ul class="pfb-list">
            {flagReasons.map((r) => (
              <li>
                {r.claim && <span class="pfb-claim">{r.claim}</span>}
                {r.claim && r.detail ? " — " : ""}
                {r.detail}
              </li>
            ))}
          </ul>
        )}
      </div>
    )
  }
  {
    isDraft && (
      <p class="profile-draft-banner" role="status">
        Draft — pending review. Not yet verified for publication.
      </p>
    )
  }
  {/* ── Life (expanded biography) ── */}
  <section class="sp-sec sp-life">
    <h2>Life</h2>
    <div class="sp-bio">
      {profile.overview.map((p) => <p>{p}</p>)}
    </div>
  </section>
</div>

<style>
  .saint-profile {
    margin-top: 0.5rem;
  }
  .sp-sec {
    margin: 1.4rem 0;
  }
  .sp-sec h2 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--byz-deep);
    margin: 0 0 0.7rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line-gold);
  }
  .sp-bio p {
    margin: 0 0 0.8rem;
    line-height: 1.65;
  }
  .sp-bio p:last-child {
    margin-bottom: 0;
  }
  .profile-draft-banner {
    margin: 0 0 1rem;
    padding: 0.5rem 0.75rem;
    border-left: 3px solid #b58900;
    background: #fdf6e3;
    color: #5c4a00;
    font-size: 0.9rem;
  }
  .profile-flag-banner {
    margin: 0 0 1rem;
    padding: 0.6rem 0.85rem;
    border-left: 3px solid #b00020;
    background: #fdecea;
    color: #6b1410;
    font-size: 0.9rem;
  }
  .profile-flag-banner .pfb-head {
    margin: 0;
    font-weight: 600;
  }
  .pfb-list {
    margin: 0.5rem 0 0;
    padding-left: 1.1rem;
  }
  .pfb-list li {
    margin: 0.35rem 0;
    line-height: 1.5;
  }
  .pfb-claim {
    font-weight: 600;
  }
</style>
