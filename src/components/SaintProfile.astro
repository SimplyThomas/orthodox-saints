---
/* Rich, optional encyclopedic article for a canonical saint. Rendered by
   SaintView only when SAINT_PROFILES[saint.id] exists. Reuses the saint-page
   visual idiom (ivory column, gold eyebrow rules) — additive to the existing view. */
import type { SaintProfile } from "../lib/saint-profiles";
import FigureList from "./FigureList.astro";

interface Props {
  profile: SaintProfile;
}
const { profile } = Astro.props;
---

<div class="saint-profile">
  {/* ── Life (expanded biography) ── */}
  <section class="sp-sec sp-life">
    <h2>Life</h2>
    <div class="sp-bio">
      {profile.overview.map((p) => <p>{p}</p>)}
    </div>
  </section>

  {/* ── Contributions / Legacy / "the Great" ── */}
  {
    profile.sections && profile.sections.length > 0 && (
      <section class="sp-sec sp-prose">
        {profile.sections.map((s) => (
          <article class="sp-block">
            <h3>{s.heading}</h3>
            {s.body.map((p) => (
              <p>{p}</p>
            ))}
          </article>
        ))}
      </section>
    )
  }

  {/* ── Timeline ── */}
  {
    profile.timeline && profile.timeline.length > 0 && (
      <section class="sp-sec sp-timeline-sec">
        <h2>Timeline</h2>
        <ul class="sp-timeline">
          {profile.timeline.map((t) => (
            <li>
              <span class="sp-when">{t.when}</span>
              <span class="sp-what">
                <strong>{t.title}</strong>
                {t.body && <span class="sp-tbody"> — {t.body}</span>}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {/* ── Holy Family ── */}
  {
    profile.family && (
      <section class="sp-sec sp-family">
        <h2>{profile.family.heading}</h2>
        {profile.family.intro && (
          <p class="sp-fam-intro">{profile.family.intro}</p>
        )}
        <FigureList figures={profile.family.figures} />
      </section>
    )
  }

  {/* ── Related Saints ── */}
  {
    profile.related && profile.related.length > 0 && (
      <section class="sp-sec sp-related">
        <h2>Related Saints</h2>
        <FigureList figures={profile.related} />
      </section>
    )
  }
</div>

<style>
  .saint-profile {
    margin-top: 1.6rem;
  }
  .sp-sec {
    margin: 1.8rem 0;
  }
  .sp-sec h2 {
    font-family: var(--serif);
    font-size: 1.35rem;
    color: var(--byz-deep);
    margin: 0 0 0.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line-gold);
  }
  .sp-bio p {
    margin: 0 0 0.85rem;
    line-height: 1.7;
  }
  .sp-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid var(--line-gold);
  }
  .sp-timeline li {
    display: flex;
    gap: 0.9rem;
    padding: 0.45rem 0 0.45rem 1rem;
  }
  .sp-when {
    flex: 0 0 4.5rem;
    font-family: var(--serif);
    font-weight: 600;
    color: var(--gold-deep);
  }
  .sp-what {
    flex: 1;
  }
  .sp-tbody {
    color: var(--ink-soft);
  }
  .sp-fam-intro {
    line-height: 1.7;
    margin: 0 0 0.6rem;
  }
  .sp-prose .sp-block {
    margin: 0 0 1.1rem;
  }
  .sp-prose h3 {
    font-family: var(--serif);
    font-size: 1.15rem;
    color: var(--byz);
    margin: 0 0 0.35rem;
  }
  .sp-prose p {
    margin: 0 0 0.6rem;
    line-height: 1.7;
  }
</style>
