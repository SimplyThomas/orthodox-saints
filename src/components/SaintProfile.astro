---
/* The IVORY story column's biography ("Life"). The timeline now lives in a
   full-width band (beside the quote) beneath the columns, rendered by SaintView;
   Contributions & Legacy, the after-region, and the rail reference are likewise
   SaintView's. So this component carries only the Life narrative. */
import type { SaintProfile } from "../lib/saint-profiles";

interface Props {
  profile: SaintProfile;
}
const { profile } = Astro.props;
---

<div class="saint-profile">
  {/* ── Life (expanded biography) ── */}
  <section class="sp-sec sp-life">
    <h2>Life</h2>
    <div class="sp-bio">
      {profile.overview.map((p) => <p>{p}</p>)}
    </div>
  </section>
</div>

<style>
  .saint-profile {
    margin-top: 0.5rem;
  }
  .sp-sec {
    margin: 1.4rem 0;
  }
  .sp-sec h2 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--byz-deep);
    margin: 0 0 0.7rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line-gold);
  }
  .sp-bio p {
    margin: 0 0 0.8rem;
    line-height: 1.65;
  }
  .sp-bio p:last-child {
    margin-bottom: 0;
  }
</style>
