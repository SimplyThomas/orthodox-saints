---
/* Rich, optional encyclopedic narrative for a canonical saint. Rendered by
   SaintView only when SAINT_PROFILES[saint.id] exists, AFTER the quote/finder
   facets. Carries the LIFE STORY (biography, contributions & legacy, timeline,
   family); the reference apparatus (lifespan line, patronage, works, further
   reading) is rendered by SaintView in the icon rail, so it is not repeated here. */
import type { SaintProfile } from "../lib/saint-profiles";
import FigureList from "./FigureList.astro";

interface Props {
  profile: SaintProfile;
}
const { profile } = Astro.props;
---

<div class="saint-profile">
  {/* ── Life (expanded biography) ── */}
  <section class="sp-sec sp-life">
    <h2>Life</h2>
    <div class="sp-bio">
      {profile.overview.map((p) => <p>{p}</p>)}
    </div>
  </section>

  {
    /* ── Contributions / Legacy / "the Great" — a compact, scannable card grid ── */
  }
  {
    profile.sections && profile.sections.length > 0 && (
      <section class="sp-sec sp-prose">
        <h2>Contributions &amp; Legacy</h2>
        <div class="sp-prose-grid">
          {profile.sections.map((s) => (
            <article class="sp-block">
              <h3>{s.heading}</h3>
              {s.body.map((p) => (
                <p>{p}</p>
              ))}
            </article>
          ))}
        </div>
      </section>
    )
  }

  {/* ── Timeline ── */}
  {
    profile.timeline && profile.timeline.length > 0 && (
      <section class="sp-sec sp-timeline-sec">
        <h2>Timeline</h2>
        <ul class="sp-timeline">
          {profile.timeline.map((t) => (
            <li>
              <span class="sp-when">{t.when}</span>
              <span class="sp-what">
                <strong>{t.title}</strong>
                {t.body && <span class="sp-tbody"> — {t.body}</span>}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {/* ── Holy Family ── */}
  {
    profile.family && (
      <section class="sp-sec sp-family">
        <h2>{profile.family.heading}</h2>
        {profile.family.intro && (
          <p class="sp-fam-intro">{profile.family.intro}</p>
        )}
        <FigureList figures={profile.family.figures} />
      </section>
    )
  }

  {/* ── Related Saints (curated) ── */}
  {
    profile.related && profile.related.length > 0 && (
      <section class="sp-sec sp-related">
        <h2>Related Saints</h2>
        <FigureList figures={profile.related} />
      </section>
    )
  }
</div>

<style>
  .saint-profile {
    margin-top: 0.5rem;
  }
  .sp-sec {
    margin: 1.4rem 0;
  }
  .sp-sec h2 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--byz-deep);
    margin: 0 0 0.7rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line-gold);
  }
  .sp-bio p {
    margin: 0 0 0.8rem;
    line-height: 1.65;
  }
  .sp-bio p:last-child {
    margin-bottom: 0;
  }

  /* Contributions & Legacy: dense, scannable cards (was a long stack of prose) */
  .sp-prose-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.7rem;
  }
  .sp-block {
    margin: 0;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.75rem 0.9rem;
  }
  .sp-prose h3 {
    font-family: var(--serif);
    font-size: 1.04rem;
    color: var(--byz);
    margin: 0 0 0.3rem;
  }
  .sp-prose p {
    margin: 0 0 0.45rem;
    font-size: 0.93rem;
    line-height: 1.5;
    color: var(--ink);
  }
  .sp-prose p:last-child {
    margin-bottom: 0;
  }

  .sp-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid var(--line-gold);
  }
  .sp-timeline li {
    display: flex;
    gap: 0.9rem;
    padding: 0.4rem 0 0.4rem 1rem;
  }
  .sp-when {
    flex: 0 0 4.5rem;
    font-family: var(--serif);
    font-weight: 600;
    color: var(--gold-deep);
  }
  .sp-what {
    flex: 1;
  }
  .sp-tbody {
    color: var(--ink-soft);
  }
  .sp-fam-intro {
    line-height: 1.65;
    margin: 0 0 0.6rem;
  }
</style>
