---
/* The IVORY story column beside the rail: the saint's biography and timeline.
   Contributions & Legacy (full-width band) and the "after" matter — Holy Family,
   Related Saints, Customs, Notes — are rendered by SaintView beneath the columns;
   the reference apparatus (lifespan, patronage, works, reading) is in the rail.
   So none of those is repeated here. */
import type { SaintProfile } from "../lib/saint-profiles";

interface Props {
  profile: SaintProfile;
}
const { profile } = Astro.props;
---

<div class="saint-profile">
  {/* ── Life (expanded biography) ── */}
  <section class="sp-sec sp-life">
    <h2>Life</h2>
    <div class="sp-bio">
      {profile.overview.map((p) => <p>{p}</p>)}
    </div>
  </section>

  {/* ── Timeline ── */}
  {
    profile.timeline && profile.timeline.length > 0 && (
      <section class="sp-sec sp-timeline-sec">
        <h2>Timeline</h2>
        <ul class="sp-timeline">
          {profile.timeline.map((t) => (
            <li>
              <span class="sp-when">{t.when}</span>
              <span class="sp-what">
                <strong>{t.title}</strong>
                {t.body && <span class="sp-tbody"> — {t.body}</span>}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</div>

<style>
  .saint-profile {
    margin-top: 0.5rem;
  }
  .sp-sec {
    margin: 1.4rem 0;
  }
  .sp-sec h2 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--byz-deep);
    margin: 0 0 0.7rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line-gold);
  }
  .sp-bio p {
    margin: 0 0 0.8rem;
    line-height: 1.65;
  }
  .sp-bio p:last-child {
    margin-bottom: 0;
  }
  .sp-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid var(--line-gold);
  }
  .sp-timeline li {
    display: flex;
    gap: 0.9rem;
    padding: 0.4rem 0 0.4rem 1rem;
  }
  .sp-when {
    flex: 0 0 4.5rem;
    font-family: var(--serif);
    font-weight: 600;
    color: var(--gold-deep);
  }
  .sp-what {
    flex: 1;
  }
  .sp-tbody {
    color: var(--ink-soft);
  }
</style>
