---
/* Rich, optional encyclopedic narrative for a canonical saint — the part that
   sits in the IVORY story column beside the rail: biography, timeline, family.
   Contributions & Legacy is rendered separately by SaintView as a full-width
   band beneath both columns; the reference apparatus (lifespan, patronage,
   works, further reading) lives in the icon rail. So neither is repeated here. */
import type { SaintProfile } from "../lib/saint-profiles";
import FigureList from "./FigureList.astro";

interface Props {
  profile: SaintProfile;
}
const { profile } = Astro.props;
---

<div class="saint-profile">
  {/* ── Life (expanded biography) ── */}
  <section class="sp-sec sp-life">
    <h2>Life</h2>
    <div class="sp-bio">
      {profile.overview.map((p) => <p>{p}</p>)}
    </div>
  </section>

  {/* ── Timeline ── */}
  {
    profile.timeline && profile.timeline.length > 0 && (
      <section class="sp-sec sp-timeline-sec">
        <h2>Timeline</h2>
        <ul class="sp-timeline">
          {profile.timeline.map((t) => (
            <li>
              <span class="sp-when">{t.when}</span>
              <span class="sp-what">
                <strong>{t.title}</strong>
                {t.body && <span class="sp-tbody"> — {t.body}</span>}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {/* ── Holy Family ── */}
  {
    profile.family && (
      <section class="sp-sec sp-family">
        <h2>{profile.family.heading}</h2>
        {profile.family.intro && (
          <p class="sp-fam-intro">{profile.family.intro}</p>
        )}
        <FigureList figures={profile.family.figures} />
      </section>
    )
  }

  {/* ── Related Saints (curated) ── */}
  {
    profile.related && profile.related.length > 0 && (
      <section class="sp-sec sp-related">
        <h2>Related Saints</h2>
        <FigureList figures={profile.related} />
      </section>
    )
  }
</div>

<style>
  .saint-profile {
    margin-top: 0.5rem;
  }
  .sp-sec {
    margin: 1.4rem 0;
  }
  .sp-sec h2 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--byz-deep);
    margin: 0 0 0.7rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line-gold);
  }
  .sp-bio p {
    margin: 0 0 0.8rem;
    line-height: 1.65;
  }
  .sp-bio p:last-child {
    margin-bottom: 0;
  }
  .sp-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid var(--line-gold);
  }
  .sp-timeline li {
    display: flex;
    gap: 0.9rem;
    padding: 0.4rem 0 0.4rem 1rem;
  }
  .sp-when {
    flex: 0 0 4.5rem;
    font-family: var(--serif);
    font-weight: 600;
    color: var(--gold-deep);
  }
  .sp-what {
    flex: 1;
  }
  .sp-tbody {
    color: var(--ink-soft);
  }
  .sp-fam-intro {
    line-height: 1.65;
    margin: 0 0 0.6rem;
  }
</style>
