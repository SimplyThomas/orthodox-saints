---
import { saintIcon } from "../../lib/icons";

interface Props {
  w?: number;
  h?: number;
  tone?: "blue" | "gold";
  halo?: boolean;
  round?: boolean;
}
const {
  w = 120,
  h = 150,
  tone = "blue",
  halo = true,
  round = false,
} = Astro.props;
---

<Fragment set:html={saintIcon(w, h, tone, halo, round)} />
