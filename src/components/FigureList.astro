---
import type { RelatedFigure } from "../lib/ephraim";
import { withBase } from "../lib/format";
interface Props {
  figures: RelatedFigure[];
  /** light-on-dark variant, for use on the coloured panels */
  light?: boolean;
}
const { figures, light = false } = Astro.props;
---

<ul class:list={["sp-figs", { "sp-figs--light": light }]}>
  {
    figures.map((f) => (
      <li>
        {f.href ? (
          <a href={withBase(f.href)}>{f.name}</a>
        ) : f.external ? (
          <a href={f.external} target="_blank" rel="noopener noreferrer">
            {f.name}
          </a>
        ) : (
          <span>{f.name}</span>
        )}
        {f.note && <span class="sp-rel"> · {f.note}</span>}
      </li>
    ))
  }
</ul>

<style>
  .sp-figs {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sp-figs li {
    padding: 0.25rem 0;
  }
  .sp-figs a {
    color: var(--byz);
    text-decoration: none;
    font-weight: 600;
  }
  .sp-figs a:hover {
    color: var(--celest);
  }
  .sp-rel {
    color: var(--ink-soft);
  }
  /* light-on-dark, for the coloured panels */
  .sp-figs--light a {
    color: var(--gold-soft);
  }
  .sp-figs--light a:hover {
    color: var(--ivory);
  }
  .sp-figs--light .sp-rel {
    color: var(--celest-soft);
  }
</style>
