const RICH_IDS = Object.keys(IH_RICH);
const johnQuoteLede =
  '&ldquo;If we thus regulate our own houses, we shall be also fit for the management of the Church. For indeed a house is a little Church. Thus it is possible for us by becoming good husbands and wives, to surpass all others.&rdquo;<br/><span style="font-style:normal;font-size:14px;letter-spacing:.04em;color:var(--gold-deep)">&mdash; Saint John Chrysostom</span>';
---

<div class="cw ihp">
  {/* ---------- hero ---------- */}
  <section
    style="position:relative;text-align:center;padding:70px 56px 48px;overflow:hidden;background:var(--ivory)"
  >
    <div
      style="position:absolute;top:30px;left:50%;transform:translateX(-50%);width:500px;opacity:.07"
      set:html={domeMark(500, "var(--byz)")}
    />
    <div style="position:relative">
      <div class="eyebrow" style="margin-bottom:18px">
        Traditional Orthodox Icon Placement Guide
      </div>
      <h1
        style="font-size:78px;color:var(--byz-deep);line-height:0.98;margin-bottom:16px;font-weight:600"
      >
        Icons in the Home
      </h1>
      <p
        style="font-family:var(--serif);font-style:italic;font-size:27px;color:var(--celest);margin:0 0 28px"
      >
        Building a House of Prayer
      </p>
      <p
        style="font-size:19px;color:var(--ink);max-width:760px;margin:0 auto;line-height:1.7;text-align:center"
      >
        Orthodox Christians have long filled their homes with reminders of
        Christ, His Mother, the saints, and the Kingdom of God. While there are
        no universal rules governing which icons belong in each room, many
        beautiful traditions have developed over centuries. This guide explores
        common icon placements and the patron saints associated with different
        areas of the home.
      </p>
    </div>
  </section>

  {/* ---------- interactive house ---------- */}
  <section style="padding:52px 56px 60px;background:var(--paper)">
    <div
      set:html={ihHeading({
        eyebrow: "The House of Prayer",
        title: "The Little Church",
        lede: johnQuoteLede,
        max: 720,
      })}
    />
    <div
      class="ih-house"
      style="max-width:1080px;margin:0 auto"
      set:html={houseSvg()}
    />
    <p
      style="text-align:center;font-size:14px;color:var(--ink-soft);font-style:italic;font-family:var(--serif);margin-top:14px"
    >
      Hover a room to highlight it &middot; click to reveal its customs just
      below.
    </p>
    <div class="ih-cardwrap" style="max-width:1080px;margin:0 auto">
      {/* empty state */}
      <div
        class="ih-empty"
        style="margin-top:36px;padding:64px 44px;text-align:center;background:var(--ivory);border:1px dashed var(--line-gold);border-radius:12px"
      >
        <div
          style="opacity:.5;margin-bottom:18px;width:92px;margin-left:auto;margin-right:auto"
          set:html={domeMark(92, "var(--gold-deep)")}
        />
        <p
          style="font-family:var(--serif);font-style:italic;font-size:22px;color:var(--celest);margin:0 0 6px"
        >
          Choose a room from the house above
        </p>
        <p style="font-size:15.5px;color:var(--ink-soft);margin:0">
          Its customs, prayer, and patron saints will appear here.
        </p>
      </div>

      {/* entryway card */}
      <div
        class="ih-card-shell"
        data-card="entryway"
        hidden
        style="margin:36px auto 0;position:relative"
      >
        <div class="ih-caret"></div>
        <div
          class="ih-card"
          style="position:relative;background:var(--paper);border:1px solid var(--gold-deep);border-radius:12px;box-shadow:var(--shadow-card);padding:40px 44px 44px;overflow:hidden"
          set:html={entrywayCardHtml()}
        />
      </div>

      {/* rich cards */}
      {
        RICH_IDS.map((id) => (
          <div
            class="ih-card-shell"
            data-card={id}
            hidden
            style="margin:36px auto 0;position:relative"
          >
            <div class="ih-caret" />
            <div
              class="ih-card"
              style="position:relative;background:var(--paper);border:1px solid var(--gold-deep);border-radius:12px;box-shadow:var(--shadow-card);padding:40px 44px 44px;overflow:hidden"
              set:html={richCardHtml(IH_RICH[id])}
            />
          </div>
        ))
      }
    </div>
  </section>

  {
    /* ---------- patron saints by subject (homeschool / library only) ---------- */
  }
  <section
    class="ih-subjects"
    data-room-only="homeschool"
    hidden
    style="padding:60px 56px 64px;background:var(--paper)"
  >
    <div style="max-width:1080px;margin:0 auto">
      <div
        set:html={ihHeading({
          eyebrow: "For the school room",
          title: "Patron Saints by Subject",
          lede: "Many families ask a particular saint to pray over a particular study.",
          max: 620,
        })}
      />
      <div
        class="ih-grid3"
        style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px"
      >
        {
          IH_SUBJECTS.map((c) => {
            const s = resolveSaint(c.id);
            const inner = s
              ? saintAvatar(
                  { name: s.name, image: s.image, type: s.type },
                  50,
                  62,
                )
              : `<span style="display:flex;align-items:center;justify-content:center;width:50px;height:62px;border-radius:6px;background:var(--ivory-2);border:1px solid var(--line-gold)">${ihGlyph(c.glyph, 26, "var(--gold-deep)")}</span>`;
            const card = `<div class="ih-subject" style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:8px;padding:22px 24px;display:flex;align-items:center;gap:16px">${inner}<div><div class="eyebrow" style="margin-bottom:5px">${esc(c.subject)}</div><div style="font-family:var(--serif);font-size:22px;color:var(--byz-deep);line-height:1.08">${esc(c.saint)}</div></div></div>`;
            return s ? (
              <a
                href={withBase(`saint/${s.id}`)}
                style="text-decoration:none"
                set:html={card}
              />
            ) : (
              <div set:html={card} />
            );
          })
        }
      </div>
    </div>
  </section>

  {/* ---------- FAQ ---------- */}
  <section style="padding:64px 56px;background:var(--ivory)">
    <div style="max-width:880px;margin:0 auto">
      <div
        set:html={ihHeading({
          eyebrow: "Common questions",
          title: "Frequently Asked",
          lede: "Pastoral, practical, and never legalistic.",
          max: 620,
        })}
      />
      <div style="display:flex;flex-direction:column;gap:12px">
        {
          IH_FAQ.map((f, i) => (
            <div
              class="ih-faq-item"
              style="background:var(--paper);border:1px solid var(--line-gold);border-radius:8px;overflow:hidden"
            >
              <button
                type="button"
                class="ih-faq-q"
                aria-expanded={i === 0 ? "true" : "false"}
                style="width:100%;display:flex;align-items:center;justify-content:space-between;gap:16px;background:transparent;border:0;cursor:pointer;padding:20px 24px;text-align:left"
              >
                <span style="font-family:var(--serif);font-weight:600;font-size:22px;color:var(--byz-deep)">
                  {f.q}
                </span>
                <span style="flex:0 0 auto;display:flex;align-items:center;justify-content:center;width:26px;height:26px">
                  <svg
                    class="ih-faq-plus"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="var(--gold-deep)"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    aria-hidden="true"
                  >
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                </span>
              </button>
              <div
                class="ih-faq-a"
                hidden={i !== 0}
                style="padding:0 24px 22px"
              >
                <p style="font-size:17px;color:var(--ink);line-height:1.66;margin:0;text-align:left">
                  {f.a}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ---------- traditions (icon corner only) ---------- */}
  <section
    class="ih-traditions"
    data-room-only="icon-corner"
    hidden
    style="padding:64px 56px;background:var(--paper)"
  >
    <div style="max-width:1100px;margin:0 auto">
      <div
        set:html={ihHeading({
          eyebrow: "One faith, many homes",
          title: "Traditions Around the World",
          lede: "Icon-corner customs differ beautifully from land to land — all of them ways of making the home a place of prayer.",
        })}
      />
      <div
        class="ih-grid3"
        style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px"
      >
        {
          IH_TRADITIONS.map((t) => (
            <div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:10px;padding:26px 26px 28px;display:flex;flex-direction:column">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
                <span
                  style="width:42px;flex:0 0 auto"
                  set:html={domeMark(42, "var(--gold-deep)")}
                />
                <h3 style="font-size:26px;color:var(--byz-deep)">{t.place}</h3>
              </div>
              <div class="rule" style="margin-bottom:14px">
                <span class="dot" />
              </div>
              <p style="font-size:15.5px;color:var(--ink);line-height:1.62;margin:0;text-align:left">
                {t.text}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</div>

<style is:global>
  /* ----- "Icons in the Home" interactive house: hover / selected recolor -----
     The SVG renders in its rest ("off") state; hovering or selecting a room
     swaps furniture colours by overriding stroke/fill on tagged elements. */
  .ihp .ih-house svg {
    overflow: visible;
  }
  .ihp .ih-room {
    transition: transform 0.18s ease;
  }
  .ihp .ih-room.ih-lift:hover,
  .ihp .ih-room.ih-lift.sel {
    transform: translateY(-2px);
  }

  /* furniture colour tokens (off → on) */
  .ihp .ih-wood {
    stroke: var(--gold-deep);
  }
  .ihp .ih-wood-f {
    fill: var(--gold-deep);
  }
  .ihp .ih-blue {
    stroke: var(--celest);
  }
  .ihp .ih-blue-f {
    fill: var(--celest);
  }
  .ihp .ih-blade-f {
    fill: #cdd9e6;
  }
  .ihp .ih-body-f {
    fill: var(--byz);
  }
  .ihp .ih-glass-f {
    fill: var(--celest);
  }
  .ihp .ih-leaf {
    stroke: #6f9472;
  }
  .ihp .ih-leaf-f {
    fill: #8bb08f;
  }
  .ihp .ih-tree {
    fill-opacity: 0.6;
  }
  .ihp .ih-hood {
    fill-opacity: 0.3;
  }
  .ihp .ih-fly-f {
    fill: #c98b86;
  }

  .ihp .ih-room:hover .ih-wood,
  .ihp .ih-room.sel .ih-wood {
    stroke: var(--gold);
  }
  .ihp .ih-room:hover .ih-wood-f,
  .ihp .ih-room.sel .ih-wood-f {
    fill: var(--gold);
  }
  .ihp .ih-room:hover .ih-blue,
  .ihp .ih-room.sel .ih-blue {
    stroke: var(--byz-deep);
  }
  .ihp .ih-room:hover .ih-blue-f,
  .ihp .ih-room.sel .ih-blue-f {
    fill: var(--byz-deep);
  }
  .ihp .ih-room:hover .ih-blade-f,
  .ihp .ih-room.sel .ih-blade-f {
    fill: #cfe0ef;
  }
  .ihp .ih-room:hover .ih-body-f,
  .ihp .ih-room.sel .ih-body-f {
    fill: var(--byz-deep);
  }
  .ihp .ih-room:hover .ih-glass-f,
  .ihp .ih-room.sel .ih-glass-f {
    fill: var(--gold-soft);
  }
  .ihp .ih-room:hover .ih-leaf,
  .ihp .ih-room.sel .ih-leaf {
    stroke: var(--gold-deep);
  }
  .ihp .ih-room:hover .ih-leaf-f,
  .ihp .ih-room.sel .ih-leaf-f {
    fill: var(--gold);
  }
  .ihp .ih-room:hover .ih-tree,
  .ihp .ih-room.sel .ih-tree {
    fill-opacity: 0.45;
  }
  .ihp .ih-room:hover .ih-hood,
  .ihp .ih-room.sel .ih-hood {
    fill-opacity: 0.5;
  }
  .ihp .ih-room:hover .ih-fly-f,
  .ihp .ih-room.sel .ih-fly-f {
    fill: var(--gold);
  }

  /* highlight panels */
  .ihp .ih-cell-hi {
    fill: transparent;
    stroke: transparent;
    stroke-width: 1.4;
  }
  .ihp .ih-room:hover .ih-cell-hi,
  .ihp .ih-room.sel .ih-cell-hi {
    fill: #f6ead0;
    stroke: var(--gold);
    filter: url(#ihGlow);
  }
  .ihp .ih-garden-bg {
    fill: #e9efe6;
    stroke: var(--line-gold);
    stroke-width: 1.3;
  }
  .ihp .ih-room:hover .ih-garden-bg,
  .ihp .ih-room.sel .ih-garden-bg {
    fill: #e2ebdd;
    stroke: var(--gold-deep);
    stroke-width: 2;
    filter: url(#ihGlow);
  }
  .ihp .ih-garage-bg {
    fill: #efe1c0;
    stroke: var(--line-gold);
    stroke-width: 1.3;
  }
  .ihp .ih-room:hover .ih-garage-bg,
  .ihp .ih-room.sel .ih-garage-bg {
    fill: #ecdcb4;
    stroke: var(--gold-deep);
    stroke-width: 2;
    filter: url(#ihGlow);
  }
  .ihp .ih-ic-hi {
    fill: #f7ecca;
    stroke: var(--gold-deep);
    stroke-width: 1.6;
  }
  .ihp .ih-room:hover .ih-ic-hi,
  .ihp .ih-room.sel .ih-ic-hi {
    fill: #f3e1b2;
    stroke-width: 2.4;
    filter: url(#ihGlow);
  }
  .ihp .ih-ic-glow {
    opacity: 0.1;
  }
  .ihp .ih-room:hover .ih-ic-glow,
  .ihp .ih-room.sel .ih-ic-glow {
    opacity: 0.18;
  }

  /* door */
  .ihp .ih-door-arch {
    fill: var(--gold-deep);
  }
  .ihp .ih-room:hover .ih-door-arch,
  .ihp .ih-room.sel .ih-door-arch {
    fill: var(--gold);
    filter: url(#ihGlow);
  }
  .ihp .ih-door-gold {
    fill: var(--gold-deep);
  }
  .ihp .ih-room:hover .ih-door-gold,
  .ihp .ih-room.sel .ih-door-gold {
    fill: var(--gold);
  }
  .ihp .ih-door-navy {
    fill: var(--byz);
    stroke: var(--gold-deep);
  }
  .ihp .ih-room:hover .ih-door-navy,
  .ihp .ih-room.sel .ih-door-navy {
    fill: #2c5a8a;
    stroke: var(--gold);
  }
  .ihp .ih-door-stroke {
    stroke: var(--gold-deep);
  }
  .ihp .ih-room:hover .ih-door-stroke,
  .ihp .ih-room.sel .ih-door-stroke {
    stroke: var(--gold);
  }

  /* card animation + close button + caret + hovers */
  @keyframes ihCardIn {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.99);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .ihp .ih-card-shell:not([hidden]) {
    animation: ihCardIn 0.42s cubic-bezier(0.2, 0.7, 0.3, 1) both;
  }
  .ihp .ih-caret {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 18px;
    height: 18px;
    background: var(--paper);
    border-left: 1px solid var(--gold-deep);
    border-top: 1px solid var(--gold-deep);
    z-index: 2;
  }
  .ihp .ih-card-x {
    transition:
      background 0.15s,
      color 0.15s;
  }
  .ihp .ih-card-x:hover {
    background: var(--gold-deep);
    color: var(--ivory);
  }
  .ihp .ih-related,
  .ihp .ih-subject {
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
    color: inherit;
  }
  .ihp .ih-related:hover,
  .ihp .ih-subject:hover {
    border-color: var(--gold) !important;
    box-shadow: 0 2px 14px rgba(15, 34, 56, 0.1);
  }
  .ihp .ih-faq-q:hover span:first-child {
    color: var(--byz) !important;
  }
  /* gilded saint name → links to its database page */
  .ihp .ih-slink {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--line-gold);
    transition:
      color 0.15s,
      border-color 0.15s;
  }
  .ihp .ih-slink:hover {
    color: var(--gold-deep);
    border-bottom-color: var(--gold);
  }
  .ihp .ih-faq-plus {
    transition: transform 0.2s;
  }
  .ihp .ih-faq-q[aria-expanded="true"] .ih-faq-plus {
    transform: rotate(45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .ihp .ih-card-shell:not([hidden]) {
      animation: none;
    }
    .ihp .ih-room {
      transition: none;
    }
  }

  /* responsive: collapse the desktop multi-column grids on narrow screens */
  @media (max-width: 820px) {
    .ihp section {
      padding-left: 22px !important;
      padding-right: 22px !important;
    }
    .ihp .ih-card {
      padding: 28px 22px !important;
    }
    .ihp .ih-grid2,
    .ihp .ih-grid3,
    .ihp .ih-facts,
    .ihp .ih-callout,
    .ihp .ih-entry-cols {
      grid-template-columns: 1fr !important;
    }
    .ihp h1 {
      font-size: 52px !important;
    }
  }
</style>
