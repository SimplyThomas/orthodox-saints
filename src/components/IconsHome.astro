---
/* "Icons in the Home — Building a House of Prayer".
   A faithful port of the Cloud-of-Witnesses design mockup (IconsHome.jsx): an
   interactive elevation of the home (the "Little Church"), room-by-room icon
   customs, a pastoral FAQ, and traditions around the world. All content is
   pre-rendered; the icons-home island handles the interactivity (house hover /
   select, card swap, FAQ accordion, conditional sections). Saints in the
   "in our database" cards resolve to real OS-#### records via lib/icons-home. */
import { withBase, esc } from "../lib/format";
import { saintAvatar, domeMark } from "../lib/icons";
import {
  IH_RICH,
  IH_ENTRY,
  IH_SUBJECTS,
  IH_FAQ,
  IH_TRADITIONS,
  resolveSaint,
  linkSaint,
  type IhRichCard,
  type IhEntry,
  type ResolvedSaint,
} from "../lib/icons-home";

/* Gild a saint's name as a link to its database page; plain text otherwise.
   Mirrors the mockup's SaintLink — only saints actually in the DB are linked. */
function slink(name: string, s: ResolvedSaint | null, sub = ""): string {
  if (!s) return esc(name) + sub;
  return `<a class="ih-slink" href="${withBase("saint/" + s.id)}">${esc(name)}</a>${sub}`;
}

/* ---------- small line glyphs for each room (minimal, gold) ---------- */
const GLYPH_P: Record<string, string> = {
  corner:
    '<path d="M5 5h14M5 5v14"/><path d="M9 9l3 3 3-3"/><path d="M12 12v6"/><path d="M9 18h6"/>',
  door: '<rect x="6" y="3" width="12" height="18" rx="1"/><circle cx="14.5" cy="12" r="1"/><path d="M9 3v18"/>',
  pot: '<path d="M5 10h14l-1.4 8.5a2 2 0 0 1-2 1.5H8.4a2 2 0 0 1-2-1.5Z"/><path d="M9 7c0-2 6-2 6 0"/><path d="M12 3v3"/>',
  table: '<path d="M3 9h18"/><path d="M5 9v10M19 9v10"/><path d="M12 4v5"/>',
  crib: '<path d="M4 9v10M20 9v10M4 14h16"/><path d="M4 9c0-3 16-3 16 0"/><path d="M8 9v5M12 9v5M16 9v5"/>',
  bed: '<path d="M3 18v-6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6"/><path d="M3 15h18"/><path d="M7 10V8a1 1 0 0 1 1-1h3v3"/><path d="M3 18v2M21 18v2"/>',
  book: '<path d="M12 6c-2-1.4-5-1.4-7 0v12c2-1.4 5-1.4 7 0 2-1.4 5-1.4 7 0V6c-2-1.4-5-1.4-7 0Z"/><path d="M12 6v12"/>',
  tools:
    '<path d="M4 20l7-7"/><path d="M14 6a3 3 0 1 0 4 4l-2 2 2 2 4-4-2-2a3 3 0 0 0-4-4Z"/><path d="M10 8L6 4H4v2l4 4"/>',
  guest:
    '<circle cx="9" cy="8" r="3"/><path d="M4 20c0-3 2.5-5 5-5s5 2 5 5"/><circle cx="17" cy="13" r="2"/><path d="M14.5 20c0-2 1.2-3 2.5-3s2.5 1 2.5 3"/>',
  leaf: '<path d="M5 19C5 11 11 5 19 5c0 8-6 14-14 14Z"/><path d="M5 19c4-4 7-7 11-9"/>',
  car: '<path d="M3 14l2-5a2 2 0 0 1 2-1.3h10A2 2 0 0 1 19 9l2 5"/><path d="M3 14h18v3a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1M3 14v3a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1"/>',
};
function ihGlyph(
  kind: string,
  size = 30,
  color = "var(--gold-deep)",
  stroke = 1.5,
): string {
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="${stroke}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${GLYPH_P[kind] || ""}</svg>`;
}

/* ---------- centered section heading (eyebrow + rule) ---------- */
function ihHeading(o: {
  eyebrow?: string;
  title: string;
  lede?: string;
  light?: boolean;
  max?: number;
}): string {
  const max = o.max ?? 760;
  const eb = o.eyebrow
    ? `<div class="eyebrow-rule" style="margin-bottom:16px"><span class="ln"></span><span class="dm"></span><span class="lbl" style="letter-spacing:.3em;font-weight:600;color:${o.light ? "var(--gold-soft)" : "var(--gold-deep)"}">${esc(o.eyebrow)}</span><span class="dm"></span><span class="ln"></span></div>`
    : "";
  const lede = o.lede
    ? `<p style="font-family:var(--serif);font-style:italic;font-size:19px;color:${o.light ? "var(--gold-soft)" : "var(--celest)"};line-height:1.5;margin:0 0 20px;text-wrap:balance">${o.lede}</p>`
    : "";
  return `<div style="text-align:center;max-width:${max}px;margin:0 auto 30px">${eb}<h2 style="font-size:38px;color:${o.light ? "var(--ivory)" : "var(--byz-deep)"};line-height:1.06;margin-bottom:${o.lede ? 14 : 18}px">${esc(o.title)}</h2>${lede}<div class="rule" style="max-width:220px;margin:0 auto;color:${o.light ? "var(--gold-soft)" : "var(--line-gold)"}"><span class="dot"></span></div></div>`;
}

/* ---------- saint marker / avatar inside a card ---------- */
function marker(s: ResolvedSaint | null, w: number, h: number): string {
  if (s)
    return saintAvatar({ name: s.name, image: s.image, type: s.type }, w, h);
  return `<span style="flex:0 0 auto;width:${w}px;height:${h}px;border-radius:6px;background:var(--ivory-2);border:1px solid var(--line-gold);display:flex;align-items:center;justify-content:center"><span style="width:8px;height:8px;transform:rotate(45deg);background:var(--gold)"></span></span>`;
}

function chip(label: string): string {
  return `<span style="font-size:12px;color:var(--byz);background:var(--paper);border:1px solid var(--line-gold);border-radius:20px;padding:3px 11px">${esc(label)}</span>`;
}
function diamondLi(text: string, color = "var(--byz-deep)"): string {
  return `<li style="display:flex;gap:10px;align-items:baseline;font-size:15.5px;color:${color};font-family:var(--serif)"><span style="flex:0 0 auto;width:5px;height:5px;transform:rotate(45deg);background:var(--gold);margin-top:2px"></span>${slink(text, linkSaint(text))}</li>`;
}
function ebHtml(txt: string, mb = 14): string {
  return `<div class="eyebrow" style="margin-bottom:${mb}px">${esc(txt)}</div>`;
}

/* a single saint "in our database" card */
function relatedCard(slug: string, w = 40, h = 50): string {
  const s = resolveSaint(slug);
  if (!s) return "";
  return `<a class="ih-related" href="${withBase("saint/" + s.id)}" style="display:flex;align-items:center;gap:12px;background:var(--ivory);border:1px solid var(--line-gold);border-radius:8px;padding:8px 16px 8px 8px;text-decoration:none">${saintAvatar({ name: s.name, image: s.image, type: s.type }, w, h)}<span><span style="display:block;font-family:var(--serif);font-size:18px;color:var(--byz-deep);line-height:1.05">${esc(s.name)} <span style="font-style:italic;color:var(--celest);font-size:15px">${esc(s.epithet)}</span></span><span style="display:block;font-size:11.5px;color:var(--ink-soft)">Feast · ${esc(s.feast)}</span></span></a>`;
}

/* ---------- a rich-card entry ---------- */
function entryHtml(e: IhEntry): string {
  const s = linkSaint(e.n, e.id);
  const sub = e.sub
    ? ` <span style="font-style:italic;color:var(--celest);font-size:17px">&mdash; ${esc(e.sub)}</span>`
    : "";
  const dbline = s
    ? `<div style="font-size:12px;color:var(--ink-soft);margin-top:2px">Feast · ${esc(s.feast)} · in our database</div>`
    : "";
  const foot = e.foot
    ? `<div style="font-size:12.5px;color:var(--ink-soft);margin-top:9px"><span class="eyebrow" style="font-size:11px">${esc(e.footLabel || "")}</span>&nbsp; ${esc(e.foot)}</div>`
    : "";
  const foot2 = e.foot2
    ? `<div style="font-size:12.5px;color:var(--ink-soft);margin-top:5px"><span class="eyebrow" style="font-size:11px">${esc(e.footLabel2 || "")}</span>&nbsp; ${esc(e.foot2)}</div>`
    : "";
  const best = e.bestFor
    ? `<div style="margin-top:12px"><div class="eyebrow" style="font-size:11px;margin-bottom:7px">Best for</div><div style="display:flex;flex-wrap:wrap;gap:5px 7px">${e.bestFor.map(chip).join("")}</div></div>`
    : "";
  return `<div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:9px;padding:18px 20px;display:flex;flex-direction:column"><div style="display:flex;gap:13px;align-items:flex-start;margin-bottom:9px">${marker(s, 42, 52)}<div style="text-align:left"><div style="font-family:var(--serif);font-size:21px;color:var(--byz-deep);line-height:1.08">${slink(e.n, s, sub)}</div>${dbline}</div></div><p style="font-size:15px;color:var(--ink);line-height:1.58;margin:0;text-align:left">${esc(e.why)}</p>${foot}${foot2}${best}</div>`;
}

/* ---------- a full rich card (everything inside .ih-card) ---------- */
function richCardHtml(D: IhRichCard): string {
  const related = D.related.map((id) => resolveSaint(id)).filter(Boolean);
  const closeBtn = `<button type="button" aria-label="Close" class="ih-card-x" style="position:absolute;top:16px;right:16px;width:34px;height:34px;border-radius:50%;border:1px solid var(--line-gold);background:var(--ivory);color:var(--gold-deep);font-size:22px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:3">&times;</button>`;

  const header = `<div style="display:flex;align-items:center;gap:14px;margin-bottom:14px"><span style="display:flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;background:var(--ivory-2);border:1px solid var(--line-gold)">${ihGlyph(D.glyph)}</span><div class="eyebrow">${esc(D.kicker)}</div></div><h3 style="font-size:38px;color:var(--byz-deep);line-height:1.03;margin-bottom:14px">${esc(D.title)}</h3>`;

  const facts = `<div style="margin-bottom:34px"><p style="font-size:17.5px;color:var(--ink);line-height:1.66;margin:0 0 22px;text-align:left;max-width:900px">${esc(D.intro)}</p><div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:10px;padding:18px 24px">${ebHtml("Quick facts", 12)}<div class="ih-facts" style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px 28px">${D.facts.map((f) => `<div style="display:flex;flex-direction:column;gap:1px"><span style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);font-weight:600">${esc(f[0])}</span><span style="font-family:var(--serif);font-size:17px;color:var(--byz-deep);line-height:1.2">${esc(f[1])}</span></div>`).join("")}</div></div></div>`;

  const callout = D.callout
    ? `<div style="margin-bottom:30px;background:var(--byz);border-radius:10px;padding:24px 28px"><div class="eyebrow on-blue" style="margin-bottom:12px">${esc(D.callout.title)}</div><ul class="ih-callout" style="list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(2,1fr);gap:9px 26px">${D.callout.lines.map((ln) => `<li style="display:flex;gap:11px;align-items:baseline;font-size:16px;color:#dbe6f1;line-height:1.5"><span style="flex:0 0 auto;width:6px;height:6px;transform:rotate(45deg);background:var(--gold);margin-top:7px"></span>${esc(ln)}</li>`).join("")}</ul>${D.callout.foot ? `<p style="font-family:var(--serif);font-style:italic;font-size:17px;color:var(--gold-soft);margin:16px 0 0;text-align:left">${esc(D.callout.foot)}</p>` : ""}</div>`
    : "";

  const groups = `<div style="display:flex;flex-direction:column;gap:30px">${D.groups.map((g) => `<div>${ebHtml(g.label)}<div class="ih-grid2" style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px">${g.entries.map(entryHtml).join("")}</div></div>`).join("")}</div>`;

  const relatedBlock = related.length
    ? `<div style="margin-top:32px">${ebHtml(D.relatedLabel || "In our database")}<div style="display:flex;gap:14px;flex-wrap:wrap">${D.related.map((id) => relatedCard(id)).join("")}</div></div>`
    : "";

  const recs = D.recs
    ? `<div style="margin-top:38px;padding-top:32px;border-top:1px solid var(--line-gold)">${ebHtml("A quick reference")}<h4 style="font-size:27px;color:var(--byz-deep);line-height:1.05;margin:0 0 20px">${esc(D.recsTitle || "")}</h4><div class="ih-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">${D.recs.map((r) => `<div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:9px;padding:18px 20px"><div class="eyebrow" style="margin-bottom:10px">${esc(r.label)}</div><ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:7px">${r.saints.map((sn) => diamondLi(sn)).join("")}</ul></div>`).join("")}</div></div>`
    : "";

  const regions = `<div style="margin-top:38px;padding-top:32px;border-top:1px solid var(--line-gold)">${ebHtml("One faith, many homes")}<h4 style="font-size:27px;color:var(--byz-deep);line-height:1.05;margin:0 0 20px">${esc(D.regionsTitle)}</h4><div class="ih-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">${D.regions.map((r) => `<div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:10px;padding:20px 22px 22px;display:flex;flex-direction:column"><div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">${domeMark(34, "var(--gold-deep)")}<h5 style="font-size:23px;color:var(--byz-deep);margin:0">${esc(r.place)}</h5></div><div style="display:flex;flex-wrap:wrap;gap:5px 8px;margin-bottom:12px">${r.icons.map(chip).join("")}</div><p style="font-size:14.5px;color:var(--ink);line-height:1.6;margin:0;text-align:left">${esc(r.custom)}</p></div>`).join("")}<div style="background:var(--byz);border-radius:10px;padding:22px 24px;display:flex;align-items:center"><p style="font-family:var(--serif);font-style:italic;font-size:17.5px;color:var(--gold-soft);line-height:1.5;margin:0;text-align:left;text-wrap:pretty">&ldquo;${esc(D.note)}&rdquo;</p></div></div></div>`;

  const historical = D.historical
    ? `<div style="margin-top:38px;padding-top:32px;border-top:1px solid var(--line-gold)">${ebHtml("For the curious")}<h4 style="font-size:27px;color:var(--byz-deep);line-height:1.05;margin:0 0 20px">${esc(D.historical.title)}</h4><div class="ih-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">${D.historical.items.map((r) => `<div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:9px;padding:18px 20px"><div class="eyebrow" style="margin-bottom:10px">${esc(r.label)}</div><ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:7px">${r.list.map((sn) => diamondLi(sn)).join("")}</ul></div>`).join("")}</div></div>`
    : "";

  const sources = D.sources
    ? `<div style="margin-top:32px;padding-top:22px;border-top:1px solid var(--line)">${ebHtml("Sources", 10)}<ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px">${D.sources.map((s) => `<li style="font-size:13px;color:var(--ink-soft);line-height:1.5;text-align:left">${esc(s)}</li>`).join("")}</ul></div>`
    : "";

  return `${closeBtn}${header}${facts}${callout}${groups}${relatedBlock}${recs}${regions}${historical}${sources}`;
}

/* ---------- the bespoke entryway card ---------- */
function entrywayCardHtml(): string {
  const D = IH_ENTRY;
  const closeBtn = `<button type="button" aria-label="Close" class="ih-card-x" style="position:absolute;top:16px;right:16px;width:34px;height:34px;border-radius:50%;border:1px solid var(--line-gold);background:var(--ivory);color:var(--gold-deep);font-size:22px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:3">&times;</button>`;
  const iconEntry = (o: {
    idx?: number;
    n: string;
    sub?: string;
    why: string;
    footLabel: string;
    foot: string;
    avatar?: string;
  }) => {
    const left = o.avatar
      ? saintAvatar(
          {
            name: resolveSaint(o.avatar)!.name,
            image: resolveSaint(o.avatar)!.image,
            type: resolveSaint(o.avatar)!.type,
          },
          48,
          60,
        )
      : `<span style="flex:0 0 auto;width:38px;height:38px;border-radius:50%;background:var(--ivory-2);border:1px solid var(--line-gold);display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:18px;font-weight:600;color:var(--gold-deep)">${o.idx}</span>`;
    const sub = o.sub
      ? ` <span style="font-style:italic;color:var(--celest);font-size:18px">&nbsp;&mdash; ${esc(o.sub)}</span>`
      : "";
    return `<div style="display:flex;gap:16px;align-items:flex-start">${left}<div style="text-align:left"><div style="font-family:var(--serif);font-size:23px;color:var(--byz-deep);line-height:1.08">${slink(o.n, linkSaint(o.n), sub)}</div><p style="font-size:15.5px;color:var(--ink);line-height:1.6;margin:6px 0 7px">${esc(o.why)}</p><div style="font-size:12.5px;color:var(--ink-soft)"><span class="eyebrow" style="font-size:11px">${esc(o.footLabel)}</span>&nbsp; ${esc(o.foot)}</div></div></div>`;
  };
  const nick = resolveSaint("nicholas");
  const header = `<div style="display:flex;align-items:center;gap:14px;margin-bottom:14px"><span style="display:flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;background:var(--ivory-2);border:1px solid var(--line-gold)">${ihGlyph("door")}</span><div class="eyebrow">The Threshold</div></div><h3 style="font-size:38px;color:var(--byz-deep);line-height:1.03;margin-bottom:14px">Front Door &amp; Entryway</h3><p style="font-size:17.5px;color:var(--ink);line-height:1.66;margin:0 0 30px;max-width:820px;text-align:left">${esc(D.intro)}</p>`;

  const left = `<div>${ebHtml("Primary icons · the most universal")}<div style="display:flex;flex-direction:column;gap:22px;margin-bottom:34px">${D.primary.map((p, i) => iconEntry({ idx: i + 1, n: p.n, sub: p.sub, why: p.why, footLabel: "Traditions", foot: p.trad })).join("")}</div>${ebHtml("Common additional saints")}<div style="display:flex;flex-direction:column;gap:22px">${D.additional.map((p, i) => iconEntry({ idx: i + 3, n: p.n, why: p.why, footLabel: "Most common in", foot: p.where, avatar: p.id === "nicholas" ? "nicholas" : undefined })).join("")}</div></div>`;

  const right = `<div style="display:flex;flex-direction:column;gap:20px"><div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:10px;padding:18px 22px"><div class="eyebrow" style="margin-bottom:12px">Quick facts</div><div style="display:flex;flex-direction:column;gap:11px">${D.facts.map((f, i) => `<div style="display:flex;flex-direction:column;gap:1px;border-top:${i ? "1px solid var(--line)" : "none"};padding-top:${i ? 10 : 0}px"><span style="font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);font-weight:600">${esc(f[0])}</span><span style="font-family:var(--serif);font-size:18px;color:var(--byz-deep);line-height:1.2">${esc(f[1])}</span></div>`).join("")}</div></div>${nick ? `<a class="ih-related" href="${withBase("saint/" + nick.id)}" style="display:flex;align-items:center;gap:12px;background:var(--paper);border:1px solid var(--line-gold);border-radius:8px;padding:8px 16px 8px 8px;text-decoration:none">${saintAvatar({ name: nick.name, image: nick.image, type: nick.type }, 42, 52)}<span><span class="eyebrow" style="display:block;margin-bottom:2px">In our database</span><span style="display:block;font-family:var(--serif);font-size:19px;color:var(--byz-deep);line-height:1.05">${esc(nick.name)} <span style="font-style:italic;color:var(--celest);font-size:16px">${esc(nick.epithet)}</span></span></span></a>` : ""}</div>`;

  const regions = `<div style="margin-top:38px;padding-top:32px;border-top:1px solid var(--line-gold)">${ebHtml("One faith, many homes")}<h4 style="font-size:27px;color:var(--byz-deep);line-height:1.05;margin:0 0 20px">Regional customs at the door</h4><div class="ih-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">${D.regions.map((r) => `<div style="background:var(--ivory);border:1px solid var(--line-gold);border-radius:10px;padding:20px 22px 22px;display:flex;flex-direction:column"><div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">${domeMark(34, "var(--gold-deep)")}<h5 style="font-size:23px;color:var(--byz-deep);margin:0">${esc(r.place)}</h5></div><div style="display:flex;flex-wrap:wrap;gap:5px 8px;margin-bottom:12px">${r.icons.map(chip).join("")}</div><p style="font-size:14.5px;color:var(--ink);line-height:1.6;margin:0;text-align:left">${esc(r.custom)}</p></div>`).join("")}<div style="background:var(--byz);border-radius:10px;padding:22px 24px;display:flex;align-items:center"><p style="font-family:var(--serif);font-style:italic;font-size:17.5px;color:var(--gold-soft);line-height:1.5;margin:0;text-align:left;text-wrap:pretty">&ldquo;${esc(D.tooltip)}&rdquo;</p></div></div></div>`;

  return `${closeBtn}${header}<div class="ih-entry-cols" style="display:grid;grid-template-columns:1fr 372px;gap:44px;align-items:start">${left}${right}</div>${regions}`;
}

/* ---------- the interactive house (the "Little Church") ---------- */
function rmIcon(
  cx: number,
  top: number,
  w = 14,
  h = 17,
  kind = "single",
): string {
  const x = cx - w / 2,
    y = top;
  const halos = kind === "pair" ? [cx - w * 0.2, cx + w * 0.2] : [cx];
  const hy = y + h * 0.36,
    r = Math.min(w * (kind === "pair" ? 0.15 : 0.24), 4);
  let out = `<g stroke-linejoin="round"><line x1="${cx}" y1="${y - 3}" x2="${cx}" y2="${y}" stroke="var(--gold-deep)" stroke-width="0.7"/><rect x="${x}" y="${y}" width="${w}" height="${h}" rx="1.4" fill="var(--ivory)" stroke="var(--gold-deep)" stroke-width="1.3"/><rect x="${x + 1.5}" y="${y + 1.5}" width="${w - 3}" height="${h - 3}" fill="#f3e7c8" stroke="var(--line-gold)" stroke-width="0.5"/>`;
  for (const hx of halos) {
    out += `<path d="M${hx - r * 1.5} ${y + h - 1.5} Q${hx} ${hy + r * 0.4} ${hx + r * 1.5} ${y + h - 1.5} Z" fill="var(--celest)" opacity="0.75"/><circle cx="${hx}" cy="${hy}" r="${r}" fill="#f3e7c8" stroke="var(--gold)" stroke-width="0.9"/>`;
    if (kind === "christ")
      out += `<g stroke="var(--gold)" stroke-width="0.6"><line x1="${hx}" y1="${hy - r}" x2="${hx}" y2="${hy + r}"/><line x1="${hx - r}" y1="${hy}" x2="${hx + r}" y2="${hy}"/></g>`;
  }
  return out + "</g>";
}

