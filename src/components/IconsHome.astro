function cellHtml(c: (typeof CELLS)[number]): string {
  const x = IH_BX + c.col * IH_CW;
  const [y, h] = BANDS[c.band];
  const cx = x + IH_CW / 2;
  const floorY = y + h - (c.label.length > 1 ? 50 : 44);
  const labelTopY = floorY + 24;
  const labels = c.label
    .map(
      (ln, i) =>
        `<text x="${cx}" y="${labelTopY + i * 16}" text-anchor="middle" font-family="Cormorant Garamond, serif" font-weight="600" font-size="16" fill="var(--byz-deep)">${esc(ln)}</text>`,
    )
    .join("");
  return `<g class="ih-room ih-lift" data-room="${c.id}" style="cursor:pointer"><rect x="${x}" y="${y}" width="${IH_CW}" height="${h}" fill="transparent"/><rect class="ih-cell-hi" x="${x + 5}" y="${y + 5}" width="${IH_CW - 10}" height="${h - 10}" rx="7"/><rect x="${x + 9}" y="${floorY}" width="${IH_CW - 18}" height="6" fill="rgba(150,120,55,.10)"/><line x1="${x + 9}" y1="${floorY}" x2="${x + IH_CW - 9}" y2="${floorY}" stroke="rgba(150,120,55,.4)" stroke-width="1"/>${roomArt(c.kind, cx, floorY)}${labels}</g>`;
}

