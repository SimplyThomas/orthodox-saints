---
import DomeMark from "./icons/DomeMark.astro";
import SearchGlyph from "./icons/SearchGlyph.astro";
import EyebrowRule from "./EyebrowRule.astro";
import { withBase } from "../lib/format";
import logo from "../assets/logo.svg";

// The hero search is a GET form that lands on /search?q=… with no JavaScript
// required; the site-search island progressively enhances it into the same
// live typeahead as the header pill (jump straight to a saint or page). The
// browse-by chips are links that open the matching facet group on the search page.
const searchUrl = withBase("search");
const browse = [
  ["rank", "Type"],
  ["intercession", "Intercession"],
  ["origin", "Region"],
  ["century", "Century"],
  ["experience", "Life Experience"],
] as const;
---

<section class="hero">
  <div class="dome-clip" aria-hidden="true">
    <div class="dome-bg" id="hero-dome">
      <DomeMark w={460} color="var(--byz)" />
    </div>
  </div>
  <div class="hero-inner">
    <EyebrowRule label="The Orthodox Saint Finder" />
    <img class="hero-logo" src={logo.src} alt="Cloud of Witnesses" />
    <blockquote>
      &ldquo;Therefore, since we are surrounded by so great a cloud of
      witnesses, let us also lay aside every weight, and sin which clings so
      closely, and let us run with endurance the race that is set
      before&nbsp;us&hellip;&rdquo;
      <cite>Hebrews 12 : 1</cite>
    </blockquote>
    <form
      class="search"
      id="hero-search"
      role="search"
      action={searchUrl}
      method="get"
      data-typeahead
    >
      <span class="ico" id="hero-search-ico" aria-hidden="true">
        <SearchGlyph size={22} color="var(--celest)" />
      </span>
      <input
        type="search"
        name="q"
        id="q"
        class="hs-input"
        placeholder="Search saints, feasts, and commemorations…"
        autocomplete="off"
        aria-label="Search saints"
        role="combobox"
        aria-expanded="false"
        aria-controls="hero-hs-results"
        aria-autocomplete="list"
      />
      <button type="submit" class="btn btn--gold" id="hero-search-btn"
        >Search</button
      >
      <div class="hs-panel" id="hero-hs-results" role="listbox" hidden></div>
    </form>
    <div class="browse-by">
      <span class="label">Browse by</span>
      {
        browse.map(([key, label]) => (
          <a class="chip" href={`${searchUrl}?browse=${key}`}>
            {label}
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* The typeahead panel is absolutely positioned and overhangs the hero's
     bottom edge, so the hero must NOT clip it. The dome silhouette is the only
     thing the hero's clip was containing, so give it its own clip layer and
     let the hero itself overflow freely. */
  .hero {
    overflow: visible;
  }
  .dome-clip {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  /* The hero box is the panel's positioning context and must not clip it. */
  .hero .search {
    position: relative;
    overflow: visible;
  }
</style>
