---
/* Full saint detail card. Reused by the static /saint/[id] page and (via fetch +
   extraction) by the quick-look modal island, so the detail markup lives in ONE
   place. Mirrors app.js openDetail(). Astro auto-escapes interpolations. */
import type { Saint } from "../lib/types";

interface Props {
  saint: Saint;
  /** heading tag for the saint name: h1 on the standalone page, h2 in the modal */
  as?: "h1" | "h2";
}
const { saint, as = "h2" } = Astro.props;
const NameHeading = as;

// [label, value, isArray] facet rows, in display order (app.js facetDefs).
const facetDefs: [string, string | string[]][] = [
  ["Feast Day(s)", saint.feast],
  ["Rank / Type", saint.rank],
  ["Church Status", saint.church],
  ["Family / Life State", saint.family],
  ["Vocation", saint.vocation],
  ["Commonly Asked Intercessions", saint.intercession],
  ["Life Experience", saint.experience],
  ["Virtue", saint.virtue],
  ["Region of Origin", saint.origin],
  ["Tradition of Veneration", saint.tradition],
  ["Era", saint.era],
  ["Century", saint.century],
  ["Gender", saint.gender],
];

const linkDefs: [string, string][] = (
  [
    ["Hymn / Apolytikion", saint.hymn],
    ["Icon", saint.icon],
    ["Video / Media", saint.video],
  ] as [string, string][]
).filter(([, url]) => url);
---

<div class="detail-card" id="saint-detail" data-id={saint.id}>
  <NameHeading>{saint.name}</NameHeading>

  {
    saint.aka.length > 0 && (
      <p class="aka">Also known as: {saint.aka.join("; ")}</p>
    )
  }

  {saint.prayer && <p class="prayer">{saint.prayer}</p>}

  {
    saint.brief && (
      <div class="facet-row">
        <span class="label">Brief Life</span>
        <span>{saint.brief}</span>
      </div>
    )
  }

  {
    facetDefs.map(([label, val]) =>
      Array.isArray(val) ? (
        val.length > 0 && (
          <div class="facet-row">
            <span class="label">{label}</span>
            <div>
              {val.map((v) => (
                <span class="tag">{v}</span>
              ))}
            </div>
          </div>
        )
      ) : val ? (
        <div class="facet-row">
          <span class="label">{label}</span>
          <span>{val}</span>
        </div>
      ) : null,
    )
  }

  {
    saint.customs && (
      <div class="facet-row">
        <span class="label">Customs & Traditions</span>
        <span>{saint.customs}</span>
      </div>
    )
  }

  {
    saint.notes && (
      <div class="facet-row">
        <span class="label">Notes</span>
        <span>{saint.notes}</span>
      </div>
    )
  }

  {
    saint.works.length > 0 && (
      <div class="facet-row">
        <span class="label">Works by the Saint</span>
        <div>
          {saint.works.map((w) => (
            <a
              class="worklink"
              href={w.u}
              target="_blank"
              rel="noopener noreferrer"
            >
              {w.t}
            </a>
          ))}
        </div>
      </div>
    )
  }

  {
    saint.about.length > 0 && (
      <div class="facet-row">
        <span class="label">Works About the Saint</span>
        <div>
          {saint.about.map((w) => (
            <a
              class="worklink"
              href={w.u}
              target="_blank"
              rel="noopener noreferrer"
            >
              {w.t}
            </a>
          ))}
        </div>
      </div>
    )
  }

  {
    linkDefs.length > 0 && (
      <div class="facet-row">
        <span class="label">Links</span>
        <div class="linkouts">
          {linkDefs.map(([text, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer">
              {text}
            </a>
          ))}
        </div>
      </div>
    )
  }

  {
    saint.sources && (
      <div class="facet-row">
        <span class="label">Sources</span>
        <span>{saint.sources}</span>
      </div>
    )
  }
</div>
