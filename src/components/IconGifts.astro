---
/* "Giving Icons as Gifts" — a practical guide to which icons are given for
   which occasion, why, and where they end up in the home.

   All content lives in lib/icon-gifts.ts; this file is presentation only. Every
   named icon subject resolves through resolveGiftRef(), so a suggestion links
   to a live record when one exists and renders as plain text when it doesn't —
   see the future-proofing note at the top of that file.

   The hero composes a real icon corner out of database portraits. Most of those
   are vendor-permission images (§9), so the hero carries the grant's required
   attribution and links each icon back to its own vendor page. If the vendor is
   ever revoked, build.py drops `image` from the records and the corner falls
   back to monogram avatars on its own — see heroIcons below. */

import EyebrowRule from "./EyebrowRule.astro";
import DomeMark from "./icons/DomeMark.astro";
import { saintAvatar } from "../lib/icons";
import { withBase } from "../lib/format";
import {
  IG_HERO,
  IG_INTRO,
  IG_OCCASIONS,
  IG_VOCATIONS,
  IG_TIERS,
  IG_RECIPIENTS,
  IG_TIPS,
  resolveGiftRef,
  type GiftIcon,
  type GiftTier,
} from "../lib/icon-gifts";

/* ---------- small line glyphs (gold, 24×24 stroke) ---------- */
const GLYPH: Record<string, string> = {
  infant:
    '<circle cx="12" cy="6.8" r="3.1"/><path d="M6.4 20.5c0-3.6 2.5-6.6 5.6-6.6s5.6 3 5.6 6.6"/><path d="M9.2 17.8h5.6"/>',
  font: '<path d="M12 1.8v4.4M10 3.9h4"/><path d="M5 8.4h14"/><path d="M6.6 8.4v5.4a5.4 5.4 0 0 0 10.8 0V8.4"/><path d="M12 19.2v2.6M9 21.8h6"/>',
  candle:
    '<rect x="9.4" y="8.6" width="5.2" height="12.8" rx="1"/><path d="M12 8.6c0-2 1.9-2.5 1.9-4.3C13.9 3 12 1.8 12 1.8s-1.9 1.2-1.9 2.5C10.1 6.1 12 6.6 12 8.6Z"/>',
  crown:
    '<path d="M4.4 18.6h15.2"/><path d="M4.4 18.6 2.8 8.4l4.9 3.7L12 5.2l4.3 6.9 4.9-3.7-1.6 10.2"/>',
  house:
    '<path d="M3.6 11.4 12 3.8l8.4 7.6"/><path d="M5.8 10.2v10h12.4v-10"/><path d="M10.2 20.2v-5.1h3.6v5.1"/>',
  scroll:
    '<path d="M6.2 2.8h8.6l3.4 3.4v15H6.2z"/><path d="M14.8 2.8v3.4h3.4"/><path d="M9 9.6h6.4M9 13.2h6.4M9 16.8h4"/>',
  tools:
    '<path d="M3.4 20.6 11 13"/><path d="M10 8.6 13.8 4.8l1.6 1.6L19.2 2.6l2.2 2.2-3.8 3.8 1.6 1.6-3.8 3.8-5.4-5.4Z"/>',
  star: '<path d="M12 1.8v20.4M1.8 12h20.4M4.8 4.8l14.4 14.4M19.2 4.8 4.8 19.2"/>',
  dove: '<path d="M2.6 13.4c4.4-.8 7-3.8 9.2-7.4 1.2 3.4 3.4 5.4 6.6 5.4-.8 4.6-4.6 8.2-9.2 8.2-3.2 0-5.6-2.4-6.6-6.2Z"/><path d="M11.8 6 15 2.8"/>',
  vial: '<path d="M9 2.4h6"/><path d="M10.2 2.4v6.4L6.6 16a3.6 3.6 0 0 0 3.1 5.6h4.6a3.6 3.6 0 0 0 3.1-5.6l-3.6-7.2V2.4"/><path d="M8.2 14.6h7.6"/>',
  chalice:
    '<path d="M6.8 2.8h10.4"/><path d="M7.8 2.8v5.4a4.2 4.2 0 0 0 8.4 0V2.8"/><path d="M12 12.4v6.6"/><path d="M8.4 21.4h7.2"/>',
};

function glyph(kind: string, size = 26, color = "var(--gold-deep)") {
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${GLYPH[kind] ?? GLYPH.candle}</svg>`;
}

/* ---------- the hero icon corner ---------- */
/* Resolve first: a revoked vendor (§9) strips `image` from every record, so the
   corner must never assume a portrait is there. Icons with a portrait render it;
   the rest fall back to the monogram avatar; if the whole corner comes back
   empty we drop to the site's DomeMark ornament rather than show a bare shelf. */
const heroIcons = IG_HERO.map((h) => {
  const r = resolveGiftRef(h.ref);
  return { ...h, r, portrait: r?.image ? withBase(r.image) : null };
}).filter((h) => h.r);
const heroHasPortraits = heroIcons.some((h) => h.portrait);

/* The grant's condition: each image links back to its own icon page. */
const heroCredits = heroIcons.filter(
  (h) => h.r?.imagePermission && h.r?.imageSource,
);
const heroVendor = heroCredits[0]?.r?.imageVendor ?? "";
const heroAttribution = heroCredits[0]?.r?.imageAttribution ?? "";

const TIER_LABEL: Record<GiftTier, string> = {
  traditional: "Most traditional",
  regional: "Regional custom",
  modern: "Modern suggestion",
};

/* A suggestion renders as a link when its subject is a record, plain text when
   it isn't (Christ Pantocrator as an icon *subject* is not a database row). */
function iconHref(i: GiftIcon): string | null {
  return resolveGiftRef(i.ref)?.href ?? null;
}
---

<div class="igp">
  {/* ============================ HERO ============================ */}
  <section class="sr-hero ig-hero">
    {
      heroHasPortraits ? (
        <div class="ig-corner">
          <ul class="ig-corner-row">
            {heroIcons.map((h) => (
              <li class={`ig-corner-item${h.center ? " is-center" : ""}`}>
                <a class="ig-corner-link" href={h.r!.href}>
                  <span class="ig-frame">
                    {h.portrait ? (
                      <img
                        class="ig-frame-img"
                        src={h.portrait}
                        alt={`Icon of ${h.label}`}
                        loading="eager"
                        decoding="async"
                      />
                    ) : (
                      <Fragment
                        set:html={saintAvatar({ name: h.label }, 92, 116)}
                      />
                    )}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <span class="ig-shelf" aria-hidden="true" />
        </div>
      ) : (
        <div class="dome-bg" aria-hidden="true">
          <DomeMark w={460} color="var(--byz)" />
        </div>
      )
    }

    <div class="sr-hero-inner">
      <EyebrowRule label="The Orthodox Home" />
      <h1 class="sr-title">Giving Icons as Gifts</h1>
      <p class="sr-lede">
        Throughout the Orthodox Christian life, icons are given to mark the
        milestones. Whether you are celebrating a birth, a baptism, a marriage,
        or another turning point, an icon is a lasting reminder that Christ and
        His saints accompany us through every stage of life.
      </p>
    </div>

    {
      /* The grant's condition is that each image links back to its own icon
         page, so every icon above is named here and linked individually — the
         vendor is credited once rather than repeated four times. */
      heroCredits.length > 0 && (
        <p class="ig-credit">
          {heroAttribution.replace(/^Icon /, "Icons ")} Original icons on{" "}
          {heroVendor}:{" "}
          {heroCredits.map((h, n) => (
            <>
              {n > 0 && <span aria-hidden="true"> · </span>}
              <a
                href={h.r!.imageSource}
                target="_blank"
                rel="noopener noreferrer"
              >
                {h.label}
              </a>
            </>
          ))}
        </p>
      )
    }
  </section>

  {/* ============================ INTRO ============================ */}
  <section class="ig-sec ig-intro-sec">
    <div class="ig-wrap ig-wrap--narrow">
      {IG_INTRO.map((p) => <p class="ig-lede-prose">{p}</p>)}
    </div>
  </section>

  {
    /* ========================== OCCASIONS ==========================
      Each occasion is itself the <details>: the closed tile is a compact
      glyph + title + one line; open, it spans the whole grid row so its
      detail never leaves empty cells beside it. Native <details> — the
      grid reflows with :has([open]), no JS. */
  }
  <section class="ig-sec ig-sec--ivory" id="occasions">
    <div class="ig-wrap">
      <div class="ig-sec-head">
        <div class="eyebrow">Occasions</div>
        <h2>Which icon, for which moment</h2>
        <p>Pick a moment to see what is given, and why.</p>
      </div>

      <div class="ig-grid">
        {
          IG_OCCASIONS.map((o) => (
            <details
              class={`ig-tile${o.key ? " is-key" : ""}`}
              id={`occasion-${o.id}`}
              name="occasion"
            >
              <summary class="ig-tile-face">
                <span class="ig-tile-glyph" set:html={glyph(o.glyph, 24)} />
                <span class="ig-tile-text">
                  <span class="ig-tile-title">{o.title}</span>
                  <span class="ig-tile-blurb">{o.blurb}</span>
                </span>
                <svg
                  class="ig-tile-chev"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </summary>

              <div class="ig-tile-body">
                <p class="ig-prose">{o.intro}</p>

                {o.icons.length > 0 && (
                  <ul class="ig-icons">
                    {o.icons.map((i) => {
                      const href = iconHref(i);
                      return (
                        <li class="ig-icon">
                          <div class="ig-icon-head">
                            {href ? (
                              <a class="ig-icon-name" href={href}>
                                {i.name}
                              </a>
                            ) : (
                              <span class="ig-icon-name is-plain">
                                {i.name}
                              </span>
                            )}
                            <span class={`ig-tier is-${i.tier}`}>
                              {TIER_LABEL[i.tier]}
                            </span>
                          </div>
                          <p class="ig-icon-why">{i.why}</p>
                          {i.where && <p class="ig-icon-where">{i.where}</p>}
                        </li>
                      );
                    })}
                  </ul>
                )}

                {o.id === "vocation" && (
                  <div class="ig-vocs">
                    {IG_VOCATIONS.map((v) => {
                      const r = resolveGiftRef(v.ref);
                      return (
                        <a class="ig-voc" href={r!.href}>
                          <span class="ig-voc-label">{v.label}</span>
                          <span class="ig-voc-note">{v.note}</span>
                        </a>
                      );
                    })}
                  </div>
                )}

                {o.note && (
                  <aside class="ig-note">
                    <div class="corner tl" aria-hidden="true" />
                    <div class="corner tr" aria-hidden="true" />
                    <div class="corner bl" aria-hidden="true" />
                    <div class="corner br" aria-hidden="true" />
                    <h4 class="ig-note-title">{o.note.title}</h4>
                    <p class="ig-note-body">{o.note.body}</p>
                  </aside>
                )}
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  {
    /* ====================== WHO ARE YOU BUYING FOR ======================
      Moved up to sit beside the occasions: the two ways in (by moment, by
      person) are the approachable entry points, ahead of the explainer. */
  }
  <section class="ig-sec" id="who">
    <div class="ig-wrap">
      <div class="ig-sec-head">
        <div class="eyebrow">A place to start</div>
        <h2>Who are you buying for?</h2>
        <p>
          Choose the person and see what is usually given &mdash; and what is
          better left to their godparent.
        </p>
      </div>

      <div class="ig-who" data-who>
        <div class="ig-who-tabs" role="list">
          {
            IG_RECIPIENTS.map((r, n) => (
              <button
                type="button"
                class="ig-who-tab"
                role="listitem"
                data-who-tab={r.id}
                aria-expanded={n === 0 ? "true" : "false"}
                aria-controls={`who-${r.id}`}
              >
                <span class="ig-who-glyph" set:html={glyph(r.glyph, 18)} />
                {r.label}
              </button>
            ))
          }
        </div>

        {
          /* Every panel renders visible; the island hides all but one. Without
            JS this stays a complete, readable list rather than an empty box. */
        }
        <div class="ig-who-panels">
          {
            IG_RECIPIENTS.map((r) => (
              <div
                class="ig-who-panel"
                id={`who-${r.id}`}
                data-who-panel={r.id}
              >
                <h3 class="ig-who-title">{r.label}</h3>
                <p class="ig-who-intro">{r.intro}</p>
                <ul class="ig-icons ig-icons--tight">
                  {r.icons.map((i) => {
                    const href = iconHref(i);
                    return (
                      <li class="ig-icon">
                        <div class="ig-icon-head">
                          {href ? (
                            <a class="ig-icon-name" href={href}>
                              {i.name}
                            </a>
                          ) : (
                            <span class="ig-icon-name is-plain">{i.name}</span>
                          )}
                          <span class={`ig-tier is-${i.tier}`}>
                            {TIER_LABEL[i.tier]}
                          </span>
                        </div>
                        <p class="ig-icon-why">{i.why}</p>
                        {i.where && <p class="ig-icon-where">{i.where}</p>}
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* ============================ TIERS ============================ */}
  <section class="ig-sec ig-sec--deep" id="tiers">
    <div class="ig-wrap">
      <div class="ig-sec-head is-light">
        <div class="eyebrow on-blue">Knowing the difference</div>
        <h2>Tradition, custom, and good ideas</h2>
        <p>
          Not everything an Orthodox Christian does is a tradition of the
          Church, and not every tradition is kept everywhere. Telling them apart
          is a courtesy to inquirers &mdash; and the surest way to keep the real
          ones intact.
        </p>
      </div>

      <div class="ig-tiers">
        {
          IG_TIERS.map((t) => (
            <article class={`ig-tier-card is-${t.tier}`}>
              <div class="ig-tier-star" aria-hidden="true">
                <span class="dm" />
              </div>
              <div class="ig-tier-label">{t.label}</div>
              <p class="ig-tier-lede">{t.lede}</p>
              <ul class="ig-tier-list">
                {t.examples.map((e) => (
                  <li>{e}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* ============================= TIPS ============================= */}
  <section class="ig-sec ig-sec--ivory" id="tips">
    <div class="ig-wrap">
      <div class="ig-sec-head">
        <div class="eyebrow">Before you buy</div>
        <h2>Choosing well</h2>
      </div>
      <div class="ig-tips">
        {
          IG_TIPS.map((t) => (
            <article class="ig-tip">
              <span class="ig-tip-dm" aria-hidden="true" />
              <h3 class="ig-tip-title">{t.title}</h3>
              <p class="ig-tip-body">{t.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</div>

<style>
  /* ---------------- layout ---------------- */
  .ig-wrap {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
  }
  .ig-wrap--narrow {
    max-width: 720px;
  }
  .ig-sec {
    padding: clamp(40px, 5.5vw, 60px) 0;
  }
  .ig-intro-sec {
    padding-top: clamp(28px, 4vw, 44px);
    padding-bottom: clamp(28px, 4vw, 44px);
  }
  .ig-sec--ivory {
    background: var(--ivory-2);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .ig-sec--deep {
    background: var(--byz-deep);
  }

  .ig-sec-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto clamp(22px, 3vw, 34px);
  }
  .ig-sec-head h2 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(30px, 4.4vw, 42px);
    color: var(--byz-deep);
    margin: 10px 0 0;
  }
  .ig-sec-head p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 14px 0 0;
    text-wrap: balance;
  }
  .ig-sec-head.is-light h2 {
    color: var(--ivory);
  }
  .ig-sec-head.is-light p {
    color: var(--celest-soft);
  }

  .ig-prose {
    font-size: 17px;
    line-height: 1.72;
    color: var(--ink);
    margin: 0 0 18px;
  }
  .ig-prose:last-child {
    margin-bottom: 0;
  }
  /* the single-paragraph intro, set a touch larger and centered as a lede */
  .ig-lede-prose {
    font-size: clamp(17px, 2vw, 19px);
    line-height: 1.7;
    color: var(--ink);
    text-align: center;
    text-wrap: pretty;
    margin: 0;
  }

  /* ---------------- hero icon corner ---------------- */
  .ig-hero {
    padding-bottom: 34px;
  }
  .ig-corner {
    width: min(560px, 92vw);
    margin: 0 auto 26px;
  }
  .ig-corner-row {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: clamp(8px, 2vw, 16px);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .ig-corner-item {
    flex: 0 0 auto;
  }
  /* The link is only as tall as its frame, so the icons bottom-align and the
     shelf sits directly beneath them. The icons are deliberately unlabelled —
     an icon corner has no placards, and the credit line below names and links
     all four in order (each icon also carries alt text and its own link). */
  .ig-corner-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .ig-frame {
    display: block;
    padding: 3px;
    background: linear-gradient(160deg, var(--gold-soft), var(--gold-deep));
    border-radius: 4px;
    box-shadow: var(--shadow-card);
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .ig-frame-img {
    display: block;
    width: 62px;
    height: 78px;
    object-fit: cover;
    object-position: center top;
    border-radius: 2px;
    background: #16304c;
  }
  .is-center .ig-frame-img {
    width: 84px;
    height: 106px;
  }
  .ig-corner-link:hover .ig-frame {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .ig-shelf {
    display: block;
    height: 2px;
    margin: 5px auto 0;
    width: min(460px, 84vw);
    background: linear-gradient(
      90deg,
      transparent,
      var(--gold-deep) 12%,
      var(--gold-deep) 88%,
      transparent
    );
    border-radius: 2px;
  }
  .ig-credit {
    position: relative;
    max-width: 760px;
    margin: 26px auto 0;
    font-size: 11.5px;
    line-height: 1.6;
    color: var(--ink-soft);
    text-align: center;
  }
  .ig-credit a {
    color: var(--celest);
  }
  .ig-credit a:hover {
    color: var(--gold-deep);
  }

  /* ---------------- occasion tiles ----------------
     Each tile is a <details>. Closed, it is a compact glyph + title + line.
     Open, it spans the full grid row (grid-column: 1/-1) so the detail never
     leaves empty cells beside it — the grid reflows with no JS. */
  .ig-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr));
    gap: 12px;
    align-items: start;
  }
  .ig-tile {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-soft);
    transition:
      border-color 0.15s,
      box-shadow 0.15s,
      transform 0.1s;
  }
  .ig-tile:not([open]):hover {
    border-color: var(--gold-deep);
    box-shadow: var(--shadow-card);
    transform: translateY(-1px);
  }
  .ig-tile.is-key {
    border-color: var(--line-gold);
    background: linear-gradient(180deg, var(--paper), var(--ivory));
  }
  /* an open tile takes the whole row and stands out from the grid */
  .ig-tile[open] {
    grid-column: 1 / -1;
    border-color: var(--gold-deep);
    box-shadow: var(--shadow-card);
  }

  .ig-tile-face {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 16px 18px;
    cursor: pointer;
    list-style: none;
  }
  .ig-tile-face::-webkit-details-marker {
    display: none;
  }
  .ig-tile-glyph {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--ivory-2);
    border: 1px solid var(--line-gold);
  }
  .ig-tile-text {
    flex: 1 1 auto;
    min-width: 0;
  }
  .ig-tile-title {
    display: block;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 19px;
    line-height: 1.15;
    color: var(--byz-deep);
  }
  .ig-tile-blurb {
    display: block;
    font-size: 13px;
    line-height: 1.45;
    color: var(--ink-soft);
    margin-top: 3px;
  }
  .ig-tile-chev {
    flex: 0 0 auto;
    color: var(--celest);
    transition: transform 0.2s ease;
  }
  .ig-tile[open] .ig-tile-chev {
    transform: rotate(180deg);
  }
  .ig-tile-face:hover .ig-tile-title {
    color: var(--byz);
  }

  .ig-tile-body {
    padding: 4px clamp(18px, 3vw, 30px) 26px;
    animation: igOpen 0.34s cubic-bezier(0.2, 0.7, 0.3, 1) both;
  }
  @keyframes igOpen {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
  }

  /* ---------------- icon suggestion list ---------------- */
  .ig-icons {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 16px 26px;
  }
  .ig-icons--tight {
    margin-top: 16px;
  }
  .ig-icon {
    padding-left: 15px;
    border-left: 2px solid var(--line-gold);
  }
  .ig-icon-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px 10px;
    margin-bottom: 5px;
  }
  .ig-icon-name {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 19px;
    color: var(--byz-deep);
    text-decoration: none;
