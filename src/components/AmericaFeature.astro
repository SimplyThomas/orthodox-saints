---
import { SAINTS } from "../lib/data";
import {
  AMERICA_LEAD,
  AMERICA_GLORIFIED,
  AMERICA_AWAITING,
  findAmerican,
} from "../lib/america";
import { withBase } from "../lib/format";
import { saintIcon } from "../lib/icons";
import DomeMark from "./icons/DomeMark.astro";
import ByzCross from "./icons/ByzCross.astro";

const lead = AMERICA_LEAD;
const leadHit = findAmerican(SAINTS, lead.name, lead.epithet);

// Resolve each glorified saint to a canonical row (build-time) for a real link.
const glorified = AMERICA_GLORIFIED.map((s) => ({
  s,
  hit: findAmerican(SAINTS, s.name, s.epithet),
  catSlug: "t-" + s.cat.toLowerCase().replace(/[^a-z]+/g, "-"),
}));

const awaiting = AMERICA_AWAITING.map((s) => ({
  s,
  reposed: (s.years.split("–").pop() || "").trim(),
}));

const LeadTag = leadHit ? "a" : "div";
---

<section class="am-hero">
  <div class="dome-bg"><DomeMark w={460} color="var(--byz)" /></div>
  <div class="inner">
    <div class="eyebrow">The Faith Planted in the New World</div>
    <h1>Saints of America</h1>
    <p>
      From the shores of Alaska to the cities of the East, these holy men and
      women carried Orthodoxy to this continent — and tended it through
      hardship, mission, and martyrdom.
    </p>
  </div>
</section>

<section class="am-section">
  <LeadTag
    class={`am-lead${leadHit ? " clickable" : ""}`}
    data-saint={leadHit?.id}
    href={leadHit ? withBase(`saint/${leadHit.id}`) : undefined}
  >
    <div class="frame" set:html={saintIcon(160, 196, "gold", true, true)} />
    <div>
      <span class="badge">{lead.badge}</span>
      <h2>{lead.name} <span class="epithet">{lead.epithet}</span></h2>
      <div class="years">{lead.years}</div>
      <p>{lead.contribution}</p>
      <div class="facts">
        <span><span class="k">Feast</span> · {lead.feast}</span>
        <span class="sep"></span>
        <span><span class="k">Glorified</span> · {lead.glorified}</span>
      </div>
    </div>
  </LeadTag>

  <div class="am-grid-head">
    <div>
      <div class="eyebrow" style="margin-bottom:8px">
        Glorified by the Church
      </div>
      <h2>Saints of North America</h2>
    </div>
    <span class="stat"
      >{glorified.length + 1} commemorated · Alaska to the Atlantic</span
    >
  </div>

  <div class="am-grid">
    {
      glorified.map(({ s, hit, catSlug }) => {
        const Tag = hit ? "a" : "div";
        return (
          <Tag
            class={`am-card${hit ? " clickable" : ""}`}
            data-saint={hit?.id}
            href={hit ? withBase(`saint/${hit.id}`) : undefined}
          >
            <div class="portrait" set:html={saintIcon(88, 108, "blue")} />
            <div class="body">
              <div class="card-head">
                <h3>{s.name}</h3>
                <span class="years">{s.years}</span>
              </div>
              <div class="epithet">{s.epithet}</div>
              <span class={`tag ${catSlug}`}>
                <i />
                {s.cat}
              </span>
              <p>{s.contribution}</p>
              <div class="card-foot">
                <span class="feast">Feast · {s.feast}</span>
                <span class="glor">Glorified {s.glorified}</span>
              </div>
            </div>
          </Tag>
        );
      })
    }
  </div>

  <div class="am-awaiting">
    <div class="panel">
      <div class="note">
        <ByzCross size={22} color="var(--gold-deep)" />
        <div>
          <div class="eyebrow" style="margin-bottom:8px">
            Awaiting Glorification
          </div>
          <h2>Remembered with Love</h2>
          <p>
            These reposed servants of God have not yet been formally glorified
            by the Church. They are gathered here with reverence — held in
            living memory by the faithful whose lives they shaped on this soil,
            and are not presented as canonized saints.
          </p>
        </div>
      </div>
      <div class="pair">
        {
          awaiting.map(({ s, reposed }) => (
            <div class="am-await-card">
              <div
                class="portrait-await"
                set:html={saintIcon(108, 132, "blue", false)}
              />
              <div>
                <div class="head">
                  <h3>{s.name}</h3>
                  <span class="years">{s.years}</span>
                </div>
                <div class="epithet">{s.epithet}</div>
                <div class="badges">
                  <span class="tag t-venerated">
                    <i />
                    {s.role}
                  </span>
                  <span class="tag t-venerated">Not yet glorified</span>
                </div>
                <p>{s.contribution}</p>
                <div class="repose">
                  ✝ Reposed {reposed} · {s.place}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
