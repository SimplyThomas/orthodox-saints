---
/* Grouped feast rows — the design's reusable calendar-list renderer, shared
   by the Full Calendar, "Every Feast in Order", and "Every Fast in Order"
   sections of /feasts. Rows are not links yet (per-feast pages are a
   follow-up); each row still carries the legend dot, dateline, fasting badge,
   and kind label from the mockup. */
import type { Feast } from "../lib/feasts";
import { KIND_LABEL, fastTone, feastKind } from "../lib/feasts";
import { tokenLabel } from "../lib/feast-dates";
import FastPill from "./FastPill.astro";

export interface FeastGroup {
  title: string;
  note?: string;
  movable?: boolean;
  rows: Feast[];
}

interface Props {
  groups: FeastGroup[];
}

const { groups } = Astro.props;

/** Dateline sub-label: span end for seasons ("→ Jun 28"), else the cycle. */
function sub(f: Feast): string {
  if (f.ends) return `→ ${tokenLabel(f.ends)}`;
  if (f.begins.type === "paschal") return "Movable";
  if (f.begins.type === "anchored") return "Anchored";
  return "Fixed";
}
---

{
  groups.map((g) => (
    <>
      <div class={`ff-cal-month${g.movable ? " movable" : ""}`}>
        <h3>{g.title}</h3>
        {g.note && <span class="note">{g.note}</span>}
        <span class="rule" />
      </div>
      <div class="ff-cal-list">
        {g.rows.map((f) => (
          <div class="ff-cal-row">
            <span class="ff-cal-date">
              {tokenLabel(f.begins)}
              <small>{sub(f)}</small>
            </span>
            <span class="ff-cal-main">
              <span class={`dot dot--${feastKind(f)}`} />
              <span class="ff-cal-name">{f.name}</span>
              <span class="ff-cal-note">{f.brief}</span>
            </span>
            <span class="ff-cal-fast on-ivory">
              {f.fasting && (
                <FastPill tone={fastTone(f.fasting)} label={f.fasting} />
              )}
            </span>
            <span class="ff-cal-kind">{KIND_LABEL[feastKind(f)]}</span>
          </div>
        ))}
      </div>
    </>
  ))
}
