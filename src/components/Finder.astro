---
import FacetSidebar from "./FacetSidebar.astro";
import { FINDER_SAINTS } from "../lib/data";
import { reviewedIds } from "../lib/saint-profiles";
import { sortSaints, PER_PAGE } from "../lib/filter";
import { finderRowHTML } from "../lib/finder-row";

/* SSR the first page of results (feast order — the island's default sort) so
   the reader sees saints at first paint, crawlers index a real list, and the
   page shows something meaningful without JS. The island re-renders the list
   once the fetched dataset arrives (see lib/finder-data.client). */
const reviewed = await reviewedIds();
const total = FINDER_SAINTS.length;
const firstPage = sortSaints(FINDER_SAINTS, "feast")
  .slice(0, PER_PAGE)
  .map((s) => (reviewed.has(s.id) ? { ...s, humanReviewed: true } : s));
---

<section class="finder" id="finder">
  {/* Backdrop for the mobile filter drawer (inert on desktop). */}
  <div class="facets-overlay" id="facets-overlay"></div>
  <div class="finder-layout">
    <FacetSidebar />

    <section class="results-pane">
      <div class="results-head">
        <div>
          <h2 id="results-title">All saints</h2>
          <div class="count" id="count" role="status">
            <b>{total}</b> commemorations
          </div>
        </div>
        <div class="results-controls">
          <button
            type="button"
            id="filters-toggle"
            class="filters-toggle"
            aria-expanded="false"
            aria-controls="facets-drawer"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M3 5h18M6 12h12M10 19h4"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
            Filters
            <span class="filter-count" id="filter-count"></span>
          </button>
          <div class="sortbox">
            <span>Show</span>
            <select id="per-page" aria-label="Saints per page">
              <option value="12">12 per page</option>
              <option value="24" selected>24 per page</option>
              <option value="48">48 per page</option>
              <option value="96">96 per page</option>
              <option value="all">Show all</option>
            </select>
          </div>
          <div class="sortbox">
            <span>Sort</span>
            <select id="sort" aria-label="Sort results">
              <option value="feast">Feast day</option>
              <option value="name">Name (A–Z)</option>
              <option value="century">Earliest first</option>
            </select>
          </div>
        </div>
      </div>
      <div class="theme-suggest" id="theme-suggest" hidden></div>
      <div class="active-chips" id="active-chips"></div>
      <ol class="results" id="results">
        {firstPage.map((s) => <li set:html={finderRowHTML(s)} />)}
      </ol>
      <div class="pager" id="pager"></div>
      <noscript>
        <p class="count">
          Showing the first {PER_PAGE} of {total} saints — searching and filtering
          need JavaScript.
        </p>
      </noscript>
    </section>
  </div>
</section>
