---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import CloudBand from "../components/CloudBand.astro";
import ProjectStatus from "../components/ProjectStatus.astro";
import { CARD_SAINTS } from "../lib/data";

// The home page is a landing page: hero search (submits to /search), saint of
// the day, the "From the Cloud" shuffle, and the news band. The full faceted
// finder lives on /search. Only the light card projection ships here — enough
// for the saint-of-the-day island and the shuffle deck.
const cardJson = JSON.stringify(CARD_SAINTS).replace(/</g, "\\u003c");
---

<BaseLayout active="home">
  <div id="home">
    <HomeHero />
    <ProjectStatus />
    <CloudBand />
  </div>

  <script
    type="application/json"
    id="card-data"
    set:html={cardJson}
    is:inline
  />
  <script>
    import "../islands/cloud-band.client.ts";
  </script>
</BaseLayout>
