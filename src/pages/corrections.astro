---
import BaseLayout from "../layouts/BaseLayout.astro";
import ByzCross from "../components/icons/ByzCross.astro";
import SearchGlyph from "../components/icons/SearchGlyph.astro";

// Corrections — report a correction. On submit it builds a pre-filled GitHub
// "new issue" URL for SimplyThomas/orthodox-saints and opens it; the visitor
// reviews and presses "Submit new issue". No backend/secrets. Ported from the
// Claude Design "Corrections" mock into the project's Byzantine system.
const FIX_TYPES = [
  { id: "feast", label: "Feast date" },
  { id: "name", label: "Name / spelling" },
  { id: "bio", label: "Biography" },
  { id: "image", label: "Image / icon" },
  { id: "link", label: "Broken link" },
  { id: "other", label: "Other" },
];
const CONTACT = "shelby.e.krug@gmail.com";
---

<BaseLayout
  active=""
  title="Suggest a Correction"
  description="Spotted a wrong feast day, a misspelled name, or a broken link? Report a correction to Cloud of Witnesses — it opens a pre-filled GitHub issue."
>
  <div class="cr">
    {/* ---------- hero ---------- */}
    <section class="cr-hero">
      <div class="eyebrow">Help Us Keep the Record True</div>
      <h1 class="cr-title">Suggest a Correction</h1>
      <p class="cr-lede">
        Spotted a wrong feast day, a misspelled name, or a broken link? Tell us,
        and we’ll set it right.
      </p>
    </section>

    {/* ---------- body ---------- */}
    <section class="cr-body">
      <div class="cr-wrap">
        {/* how it works */}
        <div class="cr-how">
          <svg
            width="22"
            height="22"
            viewBox="0 0 16 16"
            fill="var(--byz)"
            aria-hidden="true"
            class="gh"
          >
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          <p>
            Submissions are tracked publicly on GitHub. When you submit, we’ll
            open a new issue with everything filled in &mdash; you just review
            it and press <strong>Submit new issue</strong>. A free GitHub
            account is required to post.
          </p>
        </div>

        {/* form */}
        <form class="cr-card" id="cr-form" novalidate>
          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">Which saint or page?</span>
              <span class="req">REQUIRED</span>
            </div>
            <div class="search cr-search">
              <span class="ico" aria-hidden="true"
                ><SearchGlyph size={19} color="var(--celest)" /></span
              >
              <input
                id="cr-subject"
                type="text"
                placeholder="Search a saint, or paste a page URL…"
                autocomplete="off"
              />
            </div>
            <div class="hint">
              Type the saint’s name, or paste the URL of the page with the
              error.
            </div>
            <div class="err" data-for="cr-subject" hidden>
              Please tell us which saint or page this is about.
            </div>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">Type of correction</span><span class="req"
                >REQUIRED</span
              >
            </div>
            <div class="cr-chips" id="cr-types">
              {
                FIX_TYPES.map((t, i) => (
                  <button
                    type="button"
                    class={`chip${i === 0 ? " on" : ""}`}
                    data-type={t.id}
                    data-label={t.label}
                  >
                    {t.label}
                  </button>
                ))
              }
            </div>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">What needs fixing?</span><span class="req"
                >REQUIRED</span
              >
            </div>
            <textarea
              id="cr-desc"
              class="cr-input cr-area"
              rows="4"
              placeholder="e.g. The feast day is listed as Dec 6 but should be Dec 19 (Old Calendar)…"
            ></textarea>
            <div class="hint">Describe what’s wrong as clearly as you can.</div>
            <div class="err" data-for="cr-desc" hidden>
              A short description helps us fix it faster.
            </div>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">Suggested correction</span><span class="opt"
                >OPTIONAL</span
              >
            </div>
            <textarea
              id="cr-suggest"
              class="cr-input cr-area"
              rows="2"
              placeholder="The corrected text or value…"></textarea>
            <div class="hint">If you know what it should say, put it here.</div>
          </div>

          <div class="cr-grid2">
            <div class="fld">
              <div class="fld-lab">
                <span class="eyebrow">Source or citation</span><span class="opt"
                  >OPTIONAL</span
                >
              </div>
              <input
                id="cr-source"
                class="cr-input"
                type="text"
                placeholder="e.g. OCA.org · the Prologue…"
              />
              <div class="hint">A book, link, or reference we can check.</div>
            </div>
            <div class="fld">
              <div class="fld-lab">
                <span class="eyebrow">Your name</span><span class="opt"
                  >OPTIONAL</span
                >
              </div>
              <input
                id="cr-name"
                class="cr-input"
                type="text"
                placeholder="Optional"
                autocomplete="name"
              />
              <div class="hint">For the record, if you’d like credit.</div>
            </div>
          </div>

          <div class="cr-actions">
            <button type="submit" class="btn btn--blue cr-send">
              <svg
                width="18"
                height="18"
                viewBox="0 0 16 16"
                fill="var(--ivory)"
                aria-hidden="true"
              >
                <path
                  d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                ></path>
              </svg>
              Open pre-filled issue on GitHub
            </button>
            <span class="cr-note"
              >Opens in a new tab. Nothing is posted until you confirm on
              GitHub.</span
            >
          </div>
        </form>

        <p class="cr-alt" id="cr-alt">
          No GitHub account? You can also email corrections to{" "}
          <a href={`mailto:${CONTACT}`}>{CONTACT}</a>.
        </p>

        {/* thanks */}
        <div class="cr-thanks" id="cr-thanks" hidden>
          <div class="cr-thanks-cross">
            <ByzCross size={26} color="var(--gold-deep)" />
          </div>
          <div class="eyebrow">Thank You</div>
          <h2>Your correction is on its way</h2>
          <p>
            We’ve opened a pre-filled issue on GitHub in a new tab. Give it a
            glance and press <strong>Submit new issue</strong> to send it. Every report
            is reviewed by hand &mdash; thank you for helping keep the record true.
          </p>
          <div class="rule"><span class="dot"></span></div>
          <div class="cr-thanks-actions">
            <a
              class="btn btn--gold cr-reopen"
              id="cr-reopen"
              href="#"
              target="_blank"
              rel="noopener noreferrer">Reopen the issue</a
            >
            <button type="button" class="btn btn--ghost" id="cr-again"
              >Submit another</button
            >
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    import "../islands/corrections.client.ts";
  </script>
</BaseLayout>

<style>
  .cr-hero {
    text-align: center;
    padding: 54px clamp(20px, 5vw, 56px) 40px;
    background: var(--ivory);
    border-bottom: 1px solid var(--line-gold);
  }
  .cr-title {
    font-size: var(--page-title-size);
    color: var(--byz-deep);
    line-height: 1;
    margin: 14px 0 16px;
    font-weight: 600;
  }
  .cr-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--page-lede-size);
    color: var(--celest);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.45;
    text-wrap: balance;
  }

  .cr-body {
    padding: 46px clamp(16px, 5vw, 56px) 64px;
    background: var(--paper);
  }
  .cr-wrap {
    max-width: 760px;
    margin: 0 auto;
  }

  .cr-how {
    display: flex;
    align-items: flex-start;
    gap: 13px;
    background: var(--ivory);
    border: 1px solid var(--line-gold);
    border-radius: 8px;
    padding: 15px 18px;
    margin-bottom: 26px;
  }
  .cr-how .gh {
    flex: 0 0 auto;
    margin-top: 1px;
  }
  .cr-how p {
    margin: 0;
    font-size: 14.5px;
    color: var(--ink-soft);
    line-height: 1.55;
  }

  .cr-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: var(--shadow-card);
    padding: 34px clamp(20px, 4vw, 36px) 36px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .fld {
    display: block;
  }
  .fld-lab {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 8px;
  }
  .req {
    font-size: 11px;
    color: #8d3a2f;
    letter-spacing: 0.08em;
  }
  .opt {
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    opacity: 0.7;
  }
  .hint {
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 7px;
    line-height: 1.45;
  }
  .err {
    font-size: 13px;
    color: #8d3a2f;
    margin-top: 7px;
  }
  .cr-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }
  .cr-grid2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .cr-search input {
    font-size: 16.5px;
    padding: 13px 12px;
  }
  .cr-input {
    width: 100%;
    box-sizing: border-box;
    font-family: var(--text);
    font-size: 16.5px;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 13px 15px;
    outline: none;
  }
  .cr-input:focus {
    border-color: var(--gold);
  }
  .cr-area {
    resize: vertical;
    line-height: 1.5;
  }
  .cr-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    padding-top: 6px;
    border-top: 1px solid var(--line);
  }
  .cr-send {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    padding: 14px 26px;
  }
  .cr-note {
    font-size: 13.5px;
    color: var(--ink-soft);
    line-height: 1.45;
  }
  .cr-alt {
    text-align: center;
    font-size: 14.5px;
    color: var(--ink-soft);
    margin-top: 22px;
  }
  .cr-alt a {
    color: var(--gold-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--line-gold);
  }

  .cr-thanks {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: var(--shadow-card);
    padding: 48px 44px 44px;
    text-align: center;
  }
  .cr-thanks-cross {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(212, 175, 55, 0.16);
    border: 1px solid var(--line-gold);
    margin-bottom: 22px;
  }
  .cr-thanks h2 {
    font-size: 36px;
    color: var(--byz-deep);
    line-height: 1.1;
    margin: 8px 0 14px;
    font-weight: 600;
  }
  .cr-thanks p {
    font-size: 17px;
    color: var(--ink-soft);
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto;
  }
  .cr-thanks .rule {
    max-width: 200px;
    margin: 24px auto;
  }
  .cr-thanks-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cr-reopen {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
  }

  @media (max-width: 560px) {
    .cr-grid2 {
      grid-template-columns: 1fr;
    }
  }
</style>
