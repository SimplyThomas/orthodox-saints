---
import BaseLayout from "../layouts/BaseLayout.astro";
import ByzCross from "../components/icons/ByzCross.astro";
import SearchGlyph from "../components/icons/SearchGlyph.astro";

// Corrections — report a data-quality problem. On submit the form POSTs to a
// Cloudflare Worker (workers/report/), which verifies a Turnstile token and
// files a GitHub issue labelled `data-quality` on our behalf. The visitor never
// needs a GitHub account. No secrets live here; the Worker holds the token.
const FIX_TYPES = [
  { id: "feast", label: "Feast date" },
  { id: "name", label: "Name / spelling" },
  { id: "bio", label: "Biography" },
  { id: "image", label: "Image / icon" },
  { id: "link", label: "Broken link" },
  { id: "missing", label: "Missing saint" },
  { id: "other", label: "Other" },
];

// Optional email alternative for visitors who'd rather not use the form.
const CONTACT = "contact@orthodoxsaintfinder.com";

// --- Backend wiring ----------------------------------------------------------
// Same-origin route (preferred — no CORS). Map orthodoxsaintfinder.com/api/report
// to the Worker in Cloudflare (see workers/report/README.md). To use the
// workers.dev URL instead, set ENDPOINT to it and add the origin to the Worker's
// ALLOWED_ORIGIN.
const ENDPOINT = "/api/report";
// Public Cloudflare Turnstile SITE key (safe to commit). Paired secret lives as
// the Worker secret TURNSTILE_SECRET_KEY (see workers/report/README.md).
const SITE_KEY = "0x4AAAAAADtmMTW7VjPxtg_5";
---

<BaseLayout
  active=""
  title="Suggest a Correction"
  description="Spotted a wrong feast day, a misspelled name, or a broken link? Report a correction to Cloud of Witnesses — no account needed."
>
  <div class="cr">
    {/* ---------- hero ---------- */}
    <section class="cr-hero">
      <div class="eyebrow">Help Us Keep the Record True</div>
      <h1 class="cr-title">Suggest a Correction</h1>
      <p class="cr-lede">
        Spotted a wrong feast day, a misspelled name, or a broken link? Tell us,
        and we’ll set it right.
      </p>
    </section>

    {/* ---------- body ---------- */}
    <section class="cr-body">
      <div class="cr-wrap">
        {/* how it works */}
        <div class="cr-how">
          <svg
            width="22"
            height="22"
            viewBox="0 0 16 16"
            fill="var(--byz)"
            aria-hidden="true"
            class="gh"
          >
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
          <p>
            No account needed — just fill this out and submit. Each report is
            recorded as a <strong>public issue on GitHub</strong> and reviewed by
            hand, so please <strong>don’t include private information</strong>.
          </p>
        </div>

        {/* form */}
        <form class="cr-card" id="cr-form" novalidate data-endpoint={ENDPOINT}>
          {/* honeypot — hidden from people, tempting to bots. Leave empty. */}
          <div class="cr-hp" aria-hidden="true">
            <label
              >Leave this field empty
              <input
                type="text"
                name="website"
                tabindex="-1"
                autocomplete="off"
              />
            </label>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">Which saint or page?</span>
              <span class="req">REQUIRED</span>
            </div>
            <div class="search cr-search">
              <span class="ico" aria-hidden="true"
                ><SearchGlyph size={19} color="var(--celest)" /></span
              >
              <input
                id="cr-subject"
                type="text"
                placeholder="Search a saint, or paste a page URL…"
                autocomplete="off"
              />
            </div>
            <div class="hint">
              Type the saint’s name, or paste the URL of the page with the
              error. (We’ll fill this in for you if you came from a saint’s
              page.)
            </div>
            <div class="err" data-for="cr-subject" hidden>
              Please tell us which saint or page this is about.
            </div>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">Type of correction</span><span class="req"
                >REQUIRED</span
              >
            </div>
            <div class="cr-chips" id="cr-types">
              {
                FIX_TYPES.map((t, i) => (
                  <button
                    type="button"
                    class={`chip${i === 0 ? " on" : ""}`}
                    data-type={t.id}
                    data-label={t.label}
                  >
                    {t.label}
                  </button>
                ))
              }
            </div>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">What needs fixing?</span><span class="req"
                >REQUIRED</span
              >
            </div>
            <textarea
              id="cr-desc"
              class="cr-input cr-area"
              rows="4"
              placeholder="e.g. The feast day is listed as Dec 6 but should be Dec 19 (Old Calendar)…"
            ></textarea>
            <div class="hint">Describe what’s wrong as clearly as you can.</div>
            <div class="err" data-for="cr-desc" hidden>
              A short description helps us fix it faster.
            </div>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">Suggested correction</span><span class="opt"
                >OPTIONAL</span
              >
            </div>
            <textarea
              id="cr-suggest"
              class="cr-input cr-area"
              rows="2"
              placeholder="The corrected text or value…"></textarea>
            <div class="hint">If you know what it should say, put it here.</div>
          </div>

          <div class="cr-grid2">
            <div class="fld">
              <div class="fld-lab">
                <span class="eyebrow">Source or citation</span><span class="opt"
                  >OPTIONAL</span
                >
              </div>
              <input
                id="cr-source"
                class="cr-input"
                type="text"
                placeholder="e.g. OCA.org · the Prologue…"
              />
              <div class="hint">A book, link, or reference we can check.</div>
            </div>
            <div class="fld">
              <div class="fld-lab">
                <span class="eyebrow">Your name</span><span class="opt"
                  >OPTIONAL</span
                >
              </div>
              <input
                id="cr-name"
                class="cr-input"
                type="text"
                placeholder="Optional"
                autocomplete="name"
              />
              <div class="hint">For the record, if you’d like credit.</div>
            </div>
          </div>

          <div class="fld">
            <div class="fld-lab">
              <span class="eyebrow">Your email</span><span class="opt"
                >OPTIONAL</span
              >
            </div>
            <input
              id="cr-email"
              class="cr-input"
              type="email"
              inputmode="email"
              placeholder="So we can follow up if we have a question"
              autocomplete="email"
            />
            <div class="hint">
              Only used to follow up on this report. It becomes part of the
              public issue, so leave it blank if you’d rather stay anonymous.
            </div>
            <div class="err" data-for="cr-email" hidden>
              That email address doesn’t look right.
            </div>
          </div>

          {/* Turnstile — proves you’re human; no puzzles for most visitors. */}
          <div class="fld cr-turnstile-fld">
            <div
              class="cf-turnstile"
              data-sitekey={SITE_KEY}
              data-theme="light"
            >
            </div>
            <div class="err" data-for="cr-turnstile" hidden>
              Please complete the verification challenge.
            </div>
          </div>

          <div class="cr-actions">
            <button type="submit" class="btn btn--blue cr-send" id="cr-submit">
              <ByzCross size={17} color="var(--ivory)" />
              <span class="cr-send-label">Send report</span>
            </button>
            <span class="cr-note"
              >Your report is filed for us automatically — no GitHub account
              needed.</span
            >
          </div>

          {/* submission-level error (network / server) */}
          <div class="cr-formerr" id="cr-formerr" role="alert" hidden></div>
        </form>

        <p class="cr-alt" id="cr-alt">
          Prefer email? You can also send corrections to{" "}
          <a href={`mailto:${CONTACT}`}>{CONTACT}</a>.
        </p>

        {/* thanks */}
        <div class="cr-thanks" id="cr-thanks" hidden>
          <div class="cr-thanks-cross">
            <ByzCross size={26} color="var(--gold-deep)" />
          </div>
          <div class="eyebrow">Thank You</div>
          <h2>Your correction is on its way</h2>
          <p>
            We’ve filed your report and it’s now in our queue. Every report is
            reviewed by hand &mdash; thank you for helping keep the record true.
          </p>
          <div class="rule"><span class="dot"></span></div>
          <div class="cr-thanks-actions">
            <a
              class="btn btn--gold cr-issue-link"
              id="cr-issue-link"
              href="#"
              hidden
              target="_blank"
              rel="noopener noreferrer">View the issue</a
            >
            <button type="button" class="btn btn--ghost" id="cr-again"
              >Submit another</button
            >
          </div>
        </div>
      </div>
    </section>
  </div>

  {
    /* Cloudflare Turnstile loader (third-party; kept inline so Astro won't bundle it) */
  }
  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>

  <script>
    import "../islands/corrections.client.ts";
  </script>
</BaseLayout>

<style>
  .cr-hero {
    text-align: center;
    padding: 54px clamp(20px, 5vw, 56px) 40px;
    background: var(--ivory);
    border-bottom: 1px solid var(--line-gold);
  }
  .cr-title {
    font-size: var(--page-title-size);
    color: var(--byz-deep);
    line-height: 1;
    margin: 14px 0 16px;
    font-weight: 600;
  }
  .cr-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--page-lede-size);
    color: var(--celest);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.45;
    text-wrap: balance;
  }

  .cr-body {
    padding: 46px clamp(16px, 5vw, 56px) 64px;
    background: var(--paper);
  }
  .cr-wrap {
    max-width: 760px;
    margin: 0 auto;
  }

  .cr-how {
    display: flex;
    align-items: flex-start;
    gap: 13px;
    background: var(--ivory);
    border: 1px solid var(--line-gold);
    border-radius: 8px;
    padding: 15px 18px;
    margin-bottom: 26px;
  }
  .cr-how .gh {
    flex: 0 0 auto;
    margin-top: 1px;
  }
  .cr-how p {
    margin: 0;
    font-size: 14.5px;
    color: var(--ink-soft);
    line-height: 1.55;
  }

  .cr-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: var(--shadow-card);
    padding: 34px clamp(20px, 4vw, 36px) 36px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .fld {
    display: block;
  }
  .fld-lab {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 8px;
  }
  .req {
    font-size: 11px;
    color: #8d3a2f;
    letter-spacing: 0.08em;
  }
  .opt {
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    opacity: 0.7;
  }
  .hint {
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 7px;
    line-height: 1.45;
  }
  .err {
    font-size: 13px;
    color: #8d3a2f;
    margin-top: 7px;
  }
  .cr-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }
  .cr-grid2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .cr-search input {
    font-size: 16.5px;
    padding: 13px 12px;
  }
  .cr-input {
    width: 100%;
    box-sizing: border-box;
    font-family: var(--text);
    font-size: 16.5px;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 13px 15px;
    outline: none;
  }
  .cr-input:focus {
    border-color: var(--gold);
  }
  .cr-area {
    resize: vertical;
    line-height: 1.5;
  }

  /* honeypot: visually + assistively hidden, but not display:none (some bots
     skip display:none fields). Real users never see or tab to it. */
  .cr-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .cr-turnstile-fld {
    min-height: 65px;
  }

  .cr-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    padding-top: 6px;
    border-top: 1px solid var(--line);
  }
  .cr-send {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    padding: 14px 26px;
  }
  .cr-send[disabled] {
    opacity: 0.6;
    cursor: progress;
  }
  .cr-note {
    font-size: 13.5px;
    color: var(--ink-soft);
    line-height: 1.45;
  }
  .cr-formerr {
    font-size: 14px;
    color: #8d3a2f;
    background: rgba(141, 58, 47, 0.07);
    border: 1px solid rgba(141, 58, 47, 0.25);
    border-radius: 6px;
    padding: 12px 14px;
    line-height: 1.45;
  }
  .cr-alt {
    text-align: center;
    font-size: 14.5px;
    color: var(--ink-soft);
    margin-top: 22px;
  }
  .cr-alt a {
    color: var(--gold-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--line-gold);
  }

  .cr-thanks {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: var(--shadow-card);
    padding: 48px 44px 44px;
    text-align: center;
  }
  .cr-thanks-cross {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(212, 175, 55, 0.16);
    border: 1px solid var(--line-gold);
    margin-bottom: 22px;
  }
  .cr-thanks h2 {
    font-size: 36px;
    color: var(--byz-deep);
    line-height: 1.1;
    margin: 8px 0 14px;
    font-weight: 600;
  }
  .cr-thanks p {
    font-size: 17px;
    color: var(--ink-soft);
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto;
  }
  .cr-thanks .rule {
    max-width: 200px;
    margin: 24px auto;
  }
  .cr-thanks-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cr-issue-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
  }

  @media (max-width: 560px) {
    .cr-grid2 {
      grid-template-columns: 1fr;
    }
  }
</style>
