---
import type { GetStaticPaths } from "astro";
import { FEASTS, KIND_LABEL, feastKind, fastTone } from "../../lib/feasts";
import { loadFeastProfileMap } from "../../lib/feast-profiles";
import { tokenLabel } from "../../lib/feast-dates";
import { byId as saintById } from "../../lib/data";
import { withBase } from "../../lib/format";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FastPill from "../../components/FastPill.astro";

const feastById = new Map(FEASTS.map((f) => [f.id, f]));

export const getStaticPaths = (() => {
  return FEASTS.map((f) => ({ params: { id: f.id }, props: { feast: f } }));
}) satisfies GetStaticPaths;

const { feast: f } = Astro.props;
const profiles = await loadFeastProfileMap();
const p = profiles[f.id];

const desc = f.brief || `${f.name} — a feast of the Orthodox Church year.`;
const kind = feastKind(f);

// Header badges: the design's kind label + the dedication (Lord / Theotokos /
// Cross / …). The fasting discipline renders as its own tone-coded pill.
const badges = [KIND_LABEL[kind], f.dedication].filter(Boolean) as string[];

// The dateline shown under the title: the primary date, then the span end (for
// seasons), plus the cycle. Uses the same tokenLabel vocabulary as the rest of
// the site so movable feasts read consistently (Pascha, P+49, …).
const primaryDate = f.ends
  ? `${tokenLabel(f.begins)} → ${tokenLabel(f.ends)}`
  : tokenLabel(f.begins);
const cycleLabel =
  f.begins.type === "paschal"
    ? "Movable · Paschal cycle"
    : f.begins.type === "anchored"
      ? "Anchored to a weekday"
      : "Fixed date";

// The dates block in the rail — forefeast, feast/span, apodosis — only the
// tokens that are present.
const dateRows = [
  f.forefeast ? { label: "Forefeast", value: tokenLabel(f.forefeast) } : null,
  { label: f.ends ? "Begins" : "Feast", value: tokenLabel(f.begins) },
  f.ends ? { label: "Ends", value: tokenLabel(f.ends) } : null,
  f.apodosis ? { label: "Apodosis", value: tokenLabel(f.apodosis) } : null,
].filter(Boolean) as { label: string; value: string }[];

// Ordered collapsible prose blocks from the profile. History + Meaning are the
// two first-class axes of the feasts database, so they lead.
const proseBlocks: { heading: string; body: string[] }[] = [];
if (p) {
  if (p.history?.length)
    proseBlocks.push({ heading: "History", body: p.history });
  if (p.meaning?.length)
    proseBlocks.push({ heading: "Meaning", body: p.meaning });
  if (p.iconography?.length)
    proseBlocks.push({ heading: "Iconography", body: p.iconography });
  if (p.hymnography?.length)
    proseBlocks.push({ heading: "Hymnography", body: p.hymnography });
  if (p.fastingPractice?.length)
    proseBlocks.push({
      heading: "Fasting in Practice",
      body: p.fastingPractice,
    });
  if (p.customs?.length)
    proseBlocks.push({ heading: "Customs & Traditions", body: p.customs });
}

const relatedSaints = f.relatedSaints ?? [];
const relatedFeasts = f.relatedFeasts ?? [];

// Hero festal icon + "Depictions & Icons" carousel — self-hosted, validated
// festal images join here (data/feast_images.csv, data/feast_depictions.csv)
// once collected; until then the frame shows a placeholder and the carousel is
// omitted. Same render shape as the saint/host pages so icons drop in later.
const heroImage: string | null = f.image ?? null;
const depictions = f.depictions ?? [];

// Sources are a mix of URLs and plain citations (e.g. "OCA", "GOARCH"). Render
// a URL as a link labelled by its host; leave a citation as plain text.
function sourceLink(s: string): { href: string | null; label: string } {
  if (/^https?:\/\//i.test(s)) {
    try {
      return { href: s, label: new URL(s).hostname.replace(/^www\./, "") };
    } catch {
      return { href: s, label: s };
    }
  }
  return { href: null, label: s };
}
---

<BaseLayout title={f.name} description={desc} ogType="article">
  <article class="feast2">
    <section class="feast-hero">
      <div class="feast-hero-inner">
        <nav class="feast-crumb" aria-label="Breadcrumb">
          <a class="feast-back" href={withBase("feasts")}
            >← Feasts &amp; Fasts</a
          >
        </nav>

        <div class="feast-hero-grid">
          <div class="feast-hero-icon">
            <div class="feast-icon-frame">
              {
                heroImage ? (
                  <img
                    src={withBase(heroImage)}
                    alt={`Festal icon of ${f.name}`}
                  />
                ) : (
                  <div class="feast-icon-ph" aria-hidden="true">
                    <span class="feast-icon-cross">☦</span>
                  </div>
                )
              }
            </div>
            <div class="feast-icon-cap">
              {heroImage ? f.imageCredit : "Icon forthcoming"}
            </div>
          </div>

          <div class="feast-hero-id">
            <h1>{f.name}</h1>
            {
              f.aka?.length && (
                <p class="aka">Also known as: {f.aka.join(", ")}</p>
              )
            }
            <p class="dateline">
              <span class={`dot dot--${kind}`} aria-hidden="true"></span>
              <strong>{primaryDate}</strong>
              <span class="cycle">· {cycleLabel}</span>
            </p>
            <div class="badges">
              {badges.map((b) => <span class="badge">{b}</span>)}
              {
                f.fasting && (
                  <FastPill tone={fastTone(f.fasting)} label={f.fasting} />
                )
              }
            </div>
            {f.brief && <p class="brief">{f.brief}</p>}
          </div>
        </div>
      </div>
    </section>

    {
      p && p.status !== "reviewed" && (
        <div class={`draft-banner ${p.status}`}>
          <strong>{p.status === "flagged" ? "Flagged draft" : "Draft"}</strong>{" "}
          — this profile is unreviewed and not yet published. Shown here for
          review.
          {p.status === "flagged" && p.flagReasons?.length && (
            <ul>
              {p.flagReasons.map((fr) => (
                <li>
                  <strong>{fr.claim}</strong> — {fr.detail}
                </li>
              ))}
            </ul>
          )}
        </div>
      )
    }

    <div class="feast-wrap">
      {
        depictions.length > 0 && (
          <section class="feast-deps" aria-label="Depictions and icons">
            <div class="feast-deps-head">
              <h2>Depictions &amp; Icons</h2>
              <p class="feast-deps-sub">
                How the Church has written this feast — festal icons across the
                centuries.
              </p>
            </div>
            <div class="feast-deps-track">
              {depictions.map((d) => (
                <figure class="dep-card">
                  <div class="dep-frame">
                    <img src={withBase(d.image)} alt={d.title} loading="lazy" />
                  </div>
                  <figcaption class="dep-meta">
                    <span class="dep-title">{d.title}</span>
                    {(d.credit || d.source) && (
                      <span class="dep-attr">
                        {d.source ? (
                          <a
                            href={d.source}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            {d.credit || "source"}
                          </a>
                        ) : (
                          d.credit
                        )}
                        {d.license ? ` · ${d.license}` : ""}
                      </span>
                    )}
                  </figcaption>
                </figure>
              ))}
            </div>
          </section>
        )
      }

      <div class="layout">
        <main class="body">
          {
            !p && (
              <p class="stub">
                No rich profile yet — this feast carries its catalogue record
                only.
              </p>
            )
          }

          {
            p?.overview?.length && (
              <section class="sec sec-static">
                <h2>Overview</h2>
                <div class="sec-body">
                  {p.overview.map((para) => (
                    <p>{para}</p>
                  ))}
                </div>
              </section>
            )
          }

          {
            p?.timeline?.length && (
              <details class="sec">
                <summary>Timeline</summary>
                <div class="sec-body">
                  {p.timeline.map((t) => (
                    <div class="phase">
                      <h3>
                        {t.when} — {t.title}
                      </h3>
                      <p>{t.body}</p>
                    </div>
                  ))}
                </div>
              </details>
            )
          }

          {
            proseBlocks.map((blk) => (
              <details class="sec">
                <summary>{blk.heading}</summary>
                <div class="sec-body">
                  {blk.body.map((para) => (
                    <p>{para}</p>
                  ))}
                </div>
              </details>
            ))
          }

          {
            p?.celebration && (
              <details class="sec sec-celebrate" open>
                <summary>Ideas for Celebrating This Feast</summary>
                <div class="sec-body">
                  {p.celebration.intro && (
                    <p class="celebrate-intro">{p.celebration.intro}</p>
                  )}
                  <ul class="celebrate-ideas">
                    {p.celebration.ideas.map((it) => (
                      <li>
                        <span class="ci-idea">{it.idea}</span>
                        {it.detail && (
                          <span class="ci-detail"> {it.detail}</span>
                        )}
                      </li>
                    ))}
                  </ul>
                  {p.celebration.sources?.length && (
                    <p class="celebrate-credit">
                      Ideas gathered and adapted from Orthodox family resources
                      —{" "}
                      {p.celebration.sources.map((s, i) => (
                        <>
                          {i > 0 && ", "}
                          <a href={s.url} target="_blank" rel="noopener">
                            {s.label}
                          </a>
                        </>
                      ))}
                      . These are optional, inviting ideas, not liturgical
                      requirements.
                    </p>
                  )}
                </div>
              </details>
            )
          }

          {
            p?.scripture?.length && (
              <details class="sec">
                <summary>Scripture</summary>
                <div class="sec-body">
                  <ul class="refs">
                    {p.scripture.map((s) => (
                      <li>
                        <strong>{s.ref}</strong>
                        {s.note ? ` — ${s.note}` : ""}
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            )
          }

          {
            p?.sections?.map((s) => (
              <details class="sec">
                <summary>{s.heading}</summary>
                <div class="sec-body">
                  {s.body.map((para) => (
                    <p>{para}</p>
                  ))}
                </div>
              </details>
            ))
          }

          {
            (f.fasting || p?.fastingPractice?.length) && (
              <p class="fast-disclaimer">
                Fasting is described here at the season-summary level and
                differs by jurisdiction and person — please consult your parish
                priest about how to keep the fasts.
              </p>
            )
          }
        </main>

        <aside class="rail">
          <div class="rail-block">
            <h4>The Dates</h4>
            <ul class="dates">
              {
                dateRows.map((d) => (
                  <li>
                    <span class="dl">{d.label}</span>
                    <span class="dv">{d.value}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          {
            f.fasting && (
              <div class="rail-block">
                <h4>Fasting</h4>
                <p class="rail-note">{f.fasting}</p>
                {f.fastingNotes && <p class="rail-note">{f.fastingNotes}</p>}
              </div>
            )
          }

          {
            f.observance?.length && (
              <div class="rail-block">
                <h4>Tradition of Observance</h4>
                <ul>
                  {f.observance.map((o) => (
                    <li>{o}</li>
                  ))}
                </ul>
              </div>
            )
          }

          {
            relatedSaints.length > 0 && (
              <div class="rail-block">
                <h4>Related Saints</h4>
                <ul>
                  {relatedSaints.map((id) => {
                    const s = saintById.get(id);
                    return (
                      <li>
                        <a href={withBase(`saint/${id}`)}>{s ? s.name : id}</a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )
          }

          {
            relatedFeasts.length > 0 && (
              <div class="rail-block">
                <h4>Related Feasts</h4>
                <ul>
                  {relatedFeasts.map((id) => {
                    const rf = feastById.get(id);
                    return (
                      <li>
                        <a href={withBase(`feast/${id}`)}>
                          {rf ? rf.name : id}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )
          }

          {
            p?.sources?.length && (
              <div class="rail-block">
                <h4>Sources</h4>
                <ul class="sources">
                  {p.sources.map((s) => {
                    const { href, label } = sourceLink(s);
                    return (
                      <li>
                        {href ? (
                          <a
                            href={href}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            {label}
                          </a>
                        ) : (
                          label
                        )}
                      </li>
                    );
                  })}
                </ul>
              </div>
            )
          }
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  /* Blue hero band — matches the saint- and host-profile heroes (radial navy →
     ink, ivory text, gold-tinted lower edge). */
  .feast-hero {
    background: radial-gradient(
      120% 140% at 18% 0%,
      #1d3e62 0%,
      var(--byz-ink) 62%
    );
    color: var(--ivory);
    border-bottom: 1px solid rgba(212, 175, 55, 0.28);
  }
  .feast-hero-inner {
    max-width: 62rem;
    margin: 0 auto;
    padding: 1rem clamp(16px, 4vw, 40px) 1.9rem;
  }
  .feast-crumb {
    padding: 0.9rem 0 0.3rem;
  }
  .feast-back {
    color: var(--gold-soft);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .feast-back:hover {
    text-decoration: underline;
  }

  .feast-hero-grid {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: clamp(24px, 4vw, 48px);
    align-items: start;
    padding-top: 0.4rem;
  }
  .feast-hero-icon {
    min-width: 0;
  }
  .feast-icon-frame {
    width: 100%;
    aspect-ratio: 286 / 358;
    border-radius: 4px;
    border: 1px solid rgba(212, 175, 55, 0.5);
    background: #16304c;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.32);
  }
  .feast-icon-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .feast-icon-ph {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .feast-icon-cross {
    font-size: clamp(3.5rem, 9vw, 5rem);
    color: var(--gold-soft);
    opacity: 0.85;
  }
  .feast-icon-cap {
    margin-top: 10px;
    font-size: 11.5px;
    letter-spacing: 0.06em;
    color: var(--celest-soft);
    text-align: center;
    line-height: 1.5;
  }

  .feast-hero-id {
    min-width: 0;
  }
  .feast-hero-id h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 2.8rem);
    line-height: 1.08;
    margin: 0.4rem 0 0.3rem;
    color: var(--ivory);
  }
  .feast-hero-id .aka {
    font-style: italic;
    opacity: 0.82;
    margin: 0 0 0.7rem;
  }
  .dateline {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0.4rem 0 0.2rem;
    font-family: var(--serif);
    font-size: 1.05rem;
    color: var(--gold-soft);
  }
  .dateline strong {
    color: var(--ivory);
  }
  .cycle {
    font-family: var(--text);
    font-size: 0.82rem;
    color: var(--celest-soft);
  }
  .badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin: 0.6rem 0 0.9rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.28rem 0.6rem;
    line-height: 1;
    border-radius: 999px;
    color: var(--ivory);
    border: 1px solid rgba(212, 175, 55, 0.55);
    background: rgba(255, 255, 255, 0.06);
  }
  /* Match the fasting pill to the other hero badges — its glyph otherwise makes
     it taller/larger than the kind/dedication pills beside it. */
  .badges :global(.ff-fast) {
    font-size: 0.72rem;
    padding: 0.28rem 0.6rem;
    gap: 5px;
  }
  .badges :global(.ff-fast .glyph) {
    width: 12px;
    height: 12px;
  }
  .feast-hero-id .brief {
    font-size: 1.12rem;
    line-height: 1.55;
    margin: 0.4rem 0;
    max-width: 46rem;
  }
  @media (max-width: 760px) {
    .feast-hero-grid {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    .feast-hero-icon {
      max-width: 220px;
    }
    .badges {
      justify-content: center;
    }
    .feast-hero-id .brief {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Legend dot — reuse the feasts-index colour vocabulary. */
  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    display: inline-block;
    flex: none;
  }
  .dot--great {
    background: var(--gold-soft);
  }
  .dot--feast {
    background: var(--celest-soft);
  }
  .dot--fast {
    background: #8fceb4;
  }
  .dot--observance {
    background: var(--ivory);
    opacity: 0.7;
  }

  .feast-wrap {
    max-width: 62rem;
    margin: 0 auto;
    padding: 1.5rem clamp(16px, 4vw, 40px) 4rem;
  }

  /* "Depictions & Icons" carousel — native horizontal scroll-snap track,
     matching the saint/host pages. */
  .feast-deps {
    margin-bottom: 2.2rem;
  }
  .feast-deps-head {
    margin-bottom: 0.9rem;
  }
  .feast-deps-head > h2 {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--byz-deep);
    margin: 0 0 0.2rem;
  }
  .feast-deps-sub {
    font-size: 0.9rem;
    opacity: 0.75;
    margin: 0;
    max-width: 40rem;
  }
  .feast-deps-track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0.4rem 0.2rem 1rem;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }
  .dep-card {
    flex: 0 0 auto;
    width: 13.5rem;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    margin: 0;
  }
  .dep-frame {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 6px;
    overflow: hidden;
    background: #16304c;
    border: 1px solid rgba(212, 175, 55, 0.4);
    box-shadow: var(--shadow-soft, 0 4px 14px rgba(0, 0, 0, 0.18));
  }
  .dep-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .dep-meta {
    padding: 0.55rem 0.1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .dep-title {
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--byz-deep);
  }
  .dep-attr {
    font-size: 0.75rem;
    line-height: 1.45;
    opacity: 0.82;
  }
  .dep-attr a {
    color: var(--byz);
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.8rem;
    align-items: start;
  }
  @media (min-width: 60rem) {
    /* Rail on the LEFT, matching the saint/host profiles (rail | content). */
    .layout {
      grid-template-columns: 16rem minmax(0, 1fr);
      gap: 2.2rem;
    }
    .rail {
      order: -1;
      background: var(--ivory-2);
      border: 1px solid var(--line-gold);
      border-radius: 8px;
      padding: 1.4rem 1.3rem 1.6rem;
    }
  }

  /* Collapsible sections — identical treatment to the saint/host pages. */
  .sec {
    border-bottom: 1px solid rgba(128, 128, 128, 0.22);
  }
  .sec > summary {
    cursor: pointer;
    list-style: none;
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--byz-deep);
    padding: 0.8rem 0;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .sec > summary::-webkit-details-marker {
    display: none;
  }
  .sec > summary::before {
    content: "\25B8";
    color: var(--gold-deep);
    font-size: 0.8em;
    transition: transform 0.15s ease;
    flex: none;
  }
  .sec[open] > summary::before {
    transform: rotate(90deg);
  }
  .sec > summary:hover {
    color: var(--byz);
  }
  .sec-static > h2 {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--byz-deep);
    padding: 0.8rem 0;
    margin: 0;
  }
  .sec-body {
    padding: 0 0 1.1rem 1.3rem;
  }
  .sec-body p {
    line-height: 1.65;
    margin: 0 0 0.7rem;
  }
  .sec-body h3 {
    font-size: 1.05rem;
    margin: 1rem 0 0.3rem;
    color: var(--byz-deep);
  }
  .phase {
    margin-bottom: 0.8rem;
  }
  .refs {
    padding-left: 1.1rem;
  }
  .refs li {
    margin-bottom: 0.4rem;
    line-height: 1.5;
  }
  .stub {
    font-style: italic;
    opacity: 0.7;
  }
  /* "Ideas for Celebrating This Feast" — a warm, inviting family section,
     visually set apart from the scholarly prose blocks above it. */
  .sec-celebrate {
    margin: 0.5rem 0;
    border: 1px solid var(--line-gold);
    border-radius: 12px;
    background: var(--ivory-2);
    padding: 0.1rem 1.1rem;
  }
  .sec-celebrate > summary {
    color: var(--gold-deep);
  }
  .celebrate-intro {
    font-style: italic;
    color: var(--ink-soft);
    margin-bottom: 0.9rem !important;
  }
  .celebrate-ideas {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .celebrate-ideas li {
    position: relative;
    padding-left: 1.6rem;
    line-height: 1.6;
