---
import { HOSTS, isBiblicalEncounter } from "../lib/hosts";
import { withBase } from "../lib/format";
import BaseLayout from "../layouts/BaseLayout.astro";
import DomeMark from "../components/icons/DomeMark.astro";
import EyebrowRule from "../components/EyebrowRule.astro";

// Guardian Angels & Titled Figures — the angels known by office or title rather
// than by personal name: the guardian angels, and the titled scriptural figures
// (the Angel of the Lord, the Commander of the Lord's Army, the angels of the
// seven churches). These have no owning rank page (their order is the ninth rank
// or is left unassigned), so this hub is their home — the archangels, by
// contrast, are reached from the Archangels rank page. HOSTS arrives sorted by
// hostlib._sort_key.
// Event-anchored angels (carrying the Biblical Encounter tag) belong to the
// sibling /biblical-encounters hub, not here — exclude them.
const figures = HOSTS.filter(
  (h) =>
    ["Angelic Class", "Scriptural Angel", "Collective"].includes(
      h.entityType,
    ) && !isBiblicalEncounter(h),
);
---

<BaseLayout
  active="guardian-angels"
  title="Guardian Angels & Titled Figures"
  description="Our appointed guardians and the titled angelic figures of Scripture — the Angel of the Lord, the Commander of the Lord's Army, and the angels of the seven churches."
>
  <div class="wrap">
    <header class="hosts-hero">
      <div class="dome-bg" aria-hidden="true">
        <DomeMark w={460} color="var(--byz)" />
      </div>
      <div class="hosts-hero-inner">
        <EyebrowRule label="Heavenly Hosts" />
        <h1 class="hosts-title">Guardian Angels &amp; Titled Figures</h1>
        <p class="hosts-lede">
          Our appointed guardians and the titled angelic figures of Scripture.
        </p>
      </div>
    </header>

    <section class="hosts-intro">
      <p class="intro-body">
        Not every angel of Scripture is a named archangel. Some are known by
        their <em>office</em> or <em>title</em> rather than a personal name — the
        guardian angels who watch over the faithful, and the mysterious titled figures
        of the Old and New Testaments: the Angel of the Lord, the Commander of the
        Lord’s army before Jericho, and the angels of the seven churches. Orthodox
        tradition reads several of these with care, since more than one interpretation
        has always been held.
      </p>
    </section>

    {
      figures.length === 0 && (
        <p class="empty">
          No figures catalogued yet. Records will appear here as they are added.
        </p>
      )
    }

    <div class="grid">
      {
        figures.map((h) => (
          <a class="card" href={withBase(`host/${h.id}`)}>
            <span class="cthumb">
              {h.imageThumb || h.image ? (
                <img
                  src={withBase(h.imageThumb || h.image!)}
                  alt={h.name}
                  loading="lazy"
                />
              ) : (
                <span class="cmono" aria-hidden="true">
                  {h.name.charAt(0)}
                </span>
              )}
            </span>
            <span class="cname">{h.name}</span>
            <span class="cmeta">
              {h.order && h.order !== h.entityType ? h.order : h.entityType}
            </span>
            <span class="cbrief">{h.brief}</span>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .wrap {
    max-width: 60rem;
    margin: 0 auto;
    padding: 0 1.25rem 4rem;
  }
  /* Page hero — matches /nine-orders and the host hub hero: dome mark,
     diamond-flanked eyebrow, serif title, serif lede, centered. */
  .hosts-hero {
    position: relative;
    text-align: center;
    padding: clamp(64px, 12vw, 120px) 20px clamp(30px, 5vw, 52px);
    overflow: hidden;
  }
  .hosts-hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .hosts-title {
    font-family: var(--serif);
    font-size: var(--page-title-size);
    color: var(--byz-deep);
    margin: 18px 0 0;
    line-height: 1.05;
  }
  .hosts-lede {
    font-family: var(--serif);
    font-size: var(--page-lede-size);
    color: var(--ink-soft);
    margin: 16px auto 0;
    max-width: 46ch;
  }
  .empty {
    font-style: italic;
    opacity: 0.7;
    margin-top: 2rem;
  }

  .hosts-intro {
    max-width: 44rem;
    margin: 0 auto 0.5rem;
    text-align: center;
  }
  .intro-body {
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16.5rem, 1fr));
    gap: 0.9rem;
    margin-top: 2rem;
  }
  .card {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.85rem;
    row-gap: 0.15rem;
    align-items: start;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(128, 128, 128, 0.25);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s,
      box-shadow 0.15s,
      transform 0.1s;
  }
  .card:hover {
    border-color: var(--gold-deep);
    box-shadow: var(--shadow-card);
    transform: translateY(-1px);
  }
  .cthumb {
    grid-row: 1 / 4;
    width: 4rem;
    height: 4rem;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
    background: radial-gradient(120% 120% at 30% 15%, #1d3e62, var(--byz-ink));
  }
  .cthumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cmono {
    font-family: var(--serif);
    font-size: 1.7rem;
    color: var(--gold-soft);
  }
  .cname {
    grid-column: 2;
    align-self: end;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--byz-deep);
  }
  .cmeta {
    grid-column: 2;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.65;
  }
  .cbrief {
    grid-column: 2;
    font-size: 0.86rem;
    line-height: 1.4;
    opacity: 0.85;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
