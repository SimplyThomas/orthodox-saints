---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/format";

// Parish Resources — implemented from the Claude Design mock
// "Churches & Bookstores.html": a dark hero, a "why display them" pitch,
// the nine-card QR gallery (color/B&W + per-row controls, download-all,
// print sheet — wired by src/islands/parish-cards.client.ts), a four-step
// guidance section, and a contact card. The card PNGs are self-hosted
// under static/parish-cards/ and print as a clean two-up sheet.
const CARDS = [
  { base: "search-the-saints", name: "Search the Saints" },
  { base: "saint-of-the-day", name: "Saint of the Day" },
  { base: "orthodox-calendar", name: "Orthodox Calendar" },
  { base: "Feast-Day", name: "Browse by Feast Day" },
  { base: "feast-fasts", name: "Feasts & Fasts" },
  { base: "liturgical-living", name: "Liturgical Living" },
  { base: "patron-saint-quiz", name: "Patron Saint Quiz" },
  { base: "heavenly-hosts", name: "Heavenly Hosts" },
  { base: "icons-in-the-home", name: "Icons in the Home" },
];
// Full-res originals (1200×1800, print-quality) are the download targets;
// the gallery displays ~600px thumbs (static/parish-cards/thumbs/) at ~1/5
// the weight. The island swaps both when the color mode changes.
const cardDir = withBase("parish-cards/");
const cardSrc = (base: string) => `${cardDir}QR-${base}-Color.png`;
const cardThumb = (base: string) => `${cardDir}thumbs/QR-${base}-Color.png`;

const PITCH = [
  {
    icon: "M12 21s-7-4.5-7-10a4.2 4.2 0 0 1 7-3 4.2 4.2 0 0 1 7 3c0 5.5-7 10-7 10z",
    title: "Meet seekers where they stand",
    body: "A visitor lingering in the narthex can learn the saint of the day, the meaning of a feast, or find their own patron — right from their phone, without a word.",
  },
  {
    icon: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20 M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z",
    title: "Deepen the bookstore visit",
    body: "Set a card beside the icons and books. A shopper can read the full life of a saint before they buy, and carry the reference home with them.",
  },
  {
    icon: "M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7 M2 7h20v5H2z M12 22V7 M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z",
    title: "Freely given, freely shared",
    body: "Every card is free to download and print, in color or black & white. No account, no cost — only an open reference offered to the whole Church.",
  },
];

const STEPS = [
  {
    title: "Print at postcard or half-page size",
    body: "The cards are high-resolution and print beautifully anywhere from a 4×6 card up to a full A4/Letter poster. Color cards suit a printed sheet; the black & white versions photocopy cleanly and save on toner.",
  },
  {
    title: "Place them where people pause",
    body: "The narthex table, the candle stand, the bulletin board, the bookstore counter, or beside a particular icon. Anywhere a visitor waits is a good place to invite a scan.",
  },
  {
    title: "Laminate or frame for longevity",
    body: "A small acrylic sign holder or a simple laminate keeps a card fresh on a busy candle desk. The arched design is made to sit upright like a little window.",
  },
  {
    title: "Hand them out freely",
    body: "Include one in a welcome packet for newcomers, a catechumen folder, or a feast-day bulletin. Each is a small doorway into the life of the Church.",
  },
];
---

<BaseLayout
  active="parish-resources"
  title="Parish Resources"
  description="Free, print-ready QR cards for parishes and bookstores — post them in the narthex or by the register and point your community to the saints, the calendar, and the feasts of the Church."
>
  <div class="pc">
    {/* ---------- hero ---------- */}
    <section class="pc-hero">
      <div class="pc-hero-inner">
        <div>
          <div class="pc-crumb">
            <a href={withBase("")}>Home</a><span class="sep">/</span><span
              class="here">Parish Resources</span
            >
          </div>
          <div class="eyebrow on-blue">For Parishes &amp; Bookstores</div>
          <h1>Bring the saints<br />to your parish wall.</h1>
          <p class="sub">
            Free, print-ready cards that point your community to the whole Cloud
            of Witnesses — one scan away.
          </p>
          <p class="lede">
            Post them in the narthex, tuck them into a bulletin, or set them by
            the bookstore register. Each card carries a QR code to a living
            reference of the saints, the calendar, and the feasts of the Church
            — freely given, and yours to share.
          </p>
          <div class="cta">
            <a class="btn btn--gold" href="#cards">Browse the cards</a>
            <a class="btn btn--ghost pc-ghost-dark" href="#how"
              >How to use them</a
            >
          </div>
        </div>
        <div class="pc-arches" aria-hidden="true">
          <div class="pc-arch"></div>
          <div class="pc-arch"></div>
          <div class="pc-arch"></div>
        </div>
      </div>
    </section>

    {/* ---------- pitch — why display ---------- */}
    <section class="pc-sec pc-pitch">
      <div class="pc-wrap">
        <div class="pc-sec-head">
          <div class="eyebrow">Why display them</div>
          <h2>A quiet invitation, always open</h2>
          <p>
            A single card asks nothing and offers much — a doorway for the
            visitor, the inquirer, and the faithful alike.
          </p>
        </div>
        <div class="pc-pitch-grid">
          {
            PITCH.map((p) => (
              <div class="pc-point">
                <div class="ico">
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d={p.icon} />
                  </svg>
                </div>
                <h3>{p.title}</h3>
                <p>{p.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ---------- gallery ---------- */}
    <section class="pc-sec pc-gallery" id="cards" data-card-dir={cardDir}>
      <div class="pc-wrap">
        <div class="pc-sec-head">
          <div class="eyebrow">The Cards</div>
          <h2>Nine cards, one Cloud</h2>
          <p>
            Each points to a different corner of the site. Choose color or black
            &amp; white, download the ones you want, or print the whole set.
          </p>
        </div>

        <div class="pc-controls">
          <span class="pc-ctl-label">Color</span>
          <div
            class="pc-seg"
            data-seg="color"
            role="group"
            aria-label="Color mode"
          >
            <button type="button" data-value="color" data-on="true"
              >In color</button
            >
            <button type="button" data-value="bw">Black &amp; white</button>
          </div>
          <span class="sp"></span>
          <span class="pc-ctl-label">Per row</span>
          <div
            class="pc-seg"
            data-seg="cols"
            role="group"
            aria-label="Cards per row"
          >
            <button type="button" data-value="2">2</button>
            <button type="button" data-value="3" data-on="true">3</button>
            <button type="button" data-value="4">4</button>
          </div>
          <span class="sp"></span>
          <button type="button" class="btn btn--gold" id="pc-download-all"
            >Download all</button
          >
          <button type="button" class="btn btn--ghost" id="pc-print"
            >Print sheet</button
          >
        </div>

        <div class="pc-grid" data-cols="3">
          {
            CARDS.map((c) => (
              <figure class="pc-card" data-base={c.base}>
                <div class="plaque">
                  <img
                    src={cardThumb(c.base)}
                    alt={`${c.name} — scan to open on orthodoxsaintfinder.com`}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <a
                  class="dl"
                  href={cardSrc(c.base)}
                  download={`CloudOfWitnesses-${c.base}-color.png`}
                >
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M12 3v12M7 11l5 5 5-5M5 21h14" />
                  </svg>
                  <span class="dl-label">Download color</span>
                </a>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    {/* ---------- guidance ---------- */}
    <section class="pc-sec pc-guide" id="how">
      <div class="pc-wrap">
        <div class="pc-sec-head">
          <div class="eyebrow on-blue">A little guidance</div>
          <h2>From download to wall</h2>
          <p>
            A few simple ways to put the cards to work in your parish or shop.
          </p>
        </div>
        <div class="pc-guide-grid">
          {
            STEPS.map((s, i) => (
              <div class="pc-step">
                <span class="n">{i + 1}</span>
                <div>
                  <h4>{s.title}</h4>
                  <p>{s.body}</p>
                </div>
              </div>
            ))
          }
        </div>
        <p class="pc-note">
          Every card links to <b>orthodoxsaintfinder.com</b> — a free, open reference.
          Reprint and share as widely as you like.
        </p>
      </div>
    </section>

    {/* ---------- help ---------- */}
    <section class="pc-sec pc-help">
      <div class="pc-wrap">
        <div class="card">
          <div class="eyebrow">Need something else?</div>
          <h3>Custom sizes, banners &amp; social graphics</h3>
          <p>
            Planning a feast-day flyer, a pull-up banner for a festival, or a
            graphic for your parish social media? We're glad to help prepare it.
            Reach out and tell us what you have in mind.
          </p>
          <div class="pc-help-cta">
            <a
              class="btn btn--blue"
              href="mailto:contact@orthodoxsaintfinder.com?subject=Parish%20Resources%20materials"
              >Get in touch</a
            >
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    import "../islands/parish-cards.client.ts";
  </script>
</BaseLayout>

<style>
  /* ---- hero ---- */
  .pc-hero {
    background: var(--byz-ink);
    color: var(--ivory);
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(212, 175, 55, 0.22);
  }
  .pc-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      120% 92% at 82% -12%,
      rgba(212, 175, 55, 0.18),
      transparent 56%
    );
  }
  .pc-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
    padding: 22px 56px 62px;
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    gap: 40px;
    align-items: center;
  }
  .pc-crumb {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--celest-soft);
    margin-bottom: 34px;
  }
  .pc-crumb a {
    color: var(--celest-soft);
    text-decoration: none;
  }
  .pc-crumb a:hover {
    color: var(--gold-soft);
  }
  .pc-crumb .sep {
    color: rgba(212, 175, 55, 0.4);
  }
  .pc-crumb .here {
    color: #cdd9e6;
  }
  .pc-hero h1 {
    font-family: var(--serif);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.01em;
    font-size: clamp(42px, 5.5vw, 66px);
    margin: 14px 0 0;
    color: var(--ivory);
  }
  .pc-hero .sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 23px;
    color: var(--celest-soft);
    margin: 18px 0 0;
    max-width: 560px;
  }
  .pc-hero .lede {
    font-size: 17px;
    line-height: 1.65;
    color: #c6d3e0;
    margin: 20px 0 0;
    max-width: 560px;
  }
  .pc-hero .cta {
    display: flex;
    gap: 14px;
    margin-top: 30px;
    flex-wrap: wrap;
  }
  .pc-ghost-dark {
    color: var(--gold-soft);
    border-color: rgba(212, 175, 55, 0.4);
  }

  /* decorative arched window motif */
  .pc-arches {
    display: flex;
    justify-content: center;
    gap: 14px;
  }
  .pc-arch {
    width: 78px;
    height: 150px;
    border-radius: 39px 39px 6px 6px;
    position: relative;
    background: linear-gradient(
      180deg,
      rgba(212, 175, 55, 0.14),
      rgba(212, 175, 55, 0.03)
    );
    border: 1px solid rgba(212, 175, 55, 0.4);
    box-shadow: inset 0 0 0 6px rgba(35, 76, 122, 0.35);
  }
  .pc-arch::before {
    content: "";
    position: absolute;
    inset: 14px;
    border-radius: 26px 26px 4px 4px;
    border: 1px solid rgba(212, 175, 55, 0.3);
  }
  .pc-arch:nth-child(2) {
    height: 180px;
    margin-top: -15px;
  }

  /* ---- generic section frame ---- */
  .pc-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 56px;
  }
  .pc-sec {
    padding: 64px 0;
  }
  .pc-sec-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 40px;
  }
  .pc-sec-head h2 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(32px, 4.5vw, 42px);
    color: var(--byz-deep);
    margin: 10px 0 0;
  }
  .pc-sec-head p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 14px 0 0;
  }

  /* ---- pitch ---- */
  .pc-pitch {
    background: var(--paper);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .pc-pitch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
  }
  .pc-point {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 30px 28px;
    box-shadow: var(--shadow-soft);
  }
  .pc-point .ico {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212, 175, 55, 0.14);
    color: var(--gold-deep);
    border: 1px solid var(--line-gold);
    margin-bottom: 18px;
  }
  .pc-point h3 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 23px;
    color: var(--byz-deep);
    margin: 0;
  }
  .pc-point p {
    font-size: 15.5px;
    line-height: 1.62;
    color: var(--ink-soft);
    margin: 10px 0 0;
  }

  /* ---- gallery controls ---- */
  .pc-controls {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    margin: 0 auto 40px;
    padding: 16px 20px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-soft);
    max-width: 940px;
  }
  .pc-seg {
    display: inline-flex;
    background: var(--ivory-2);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 3px;
  }
  .pc-seg button {
    font-family: var(--text);
    font-size: 14px;
    color: var(--ink-soft);
    background: transparent;
    border: 0;
    border-radius: 999px;
    padding: 8px 18px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .pc-seg button[data-on="true"] {
    background: var(--byz);
    color: var(--ivory);
    box-shadow: var(--shadow-soft);
  }
  .pc-ctl-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold-deep);
  }
  .pc-controls .sp {
    flex: 1;
    min-width: 8px;
  }

  /* ---- gallery grid ---- */
  .pc-grid {
    display: grid;
    gap: 38px 30px;
  }
  .pc-grid[data-cols="2"] {
    grid-template-columns: repeat(2, 1fr);
  }
  .pc-grid[data-cols="3"] {
    grid-template-columns: repeat(3, 1fr);
  }
  .pc-grid[data-cols="4"] {
    grid-template-columns: repeat(4, 1fr);
  }
  .pc-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
  }
  .pc-card .plaque {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 6px;
  }
  .pc-card img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 12px 26px rgba(15, 34, 56, 0.16));
  }
  .pc-card .dl {
    margin-top: 14px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--text);
    font-size: 14px;
    font-weight: 500;
    color: var(--byz);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 9px 20px;
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
  }
  .pc-card .dl:hover {
    border-color: var(--gold);
    color: var(--gold-deep);
    background: var(--paper);
  }
  .pc-card .dl svg {
    width: 15px;
    height: 15px;
  }

  /* ---- guidance ---- */
  .pc-guide {
    background: var(--byz-ink);
    color: var(--ivory);
  }
  .pc-guide .pc-sec-head h2 {
    color: var(--ivory);
  }
  .pc-guide .pc-sec-head p {
    color: var(--celest-soft);
  }
  .pc-guide-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px 36px;
    margin-top: 8px;
  }
  .pc-step {
    display: flex;
    gap: 18px;
    padding: 22px;
    border: 1px solid rgba(212, 175, 55, 0.22);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.03);
  }
  .pc-step .n {
    font-family: var(--serif);
    font-size: 30px;
    color: var(--gold);
    line-height: 1;
    flex: 0 0 auto;
    width: 36px;
  }
  .pc-step h4 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 21px;
    color: var(--ivory);
    margin: 2px 0 0;
  }
  .pc-step p {
    font-size: 15px;
    line-height: 1.6;
    color: #c6d3e0;
    margin: 8px 0 0;
  }
  .pc-note {
    margin-top: 34px;
    text-align: center;
    font-size: 15px;
    color: var(--celest-soft);
  }
  .pc-note b {
    color: var(--gold-soft);
    font-weight: 600;
  }

  /* ---- help ---- */
  .pc-help {
    text-align: center;
  }
  .pc-help .card {
    max-width: 720px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 44px 40px;
    box-shadow: var(--shadow-card);
  }
  .pc-help h3 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 30px;
    color: var(--byz-deep);
    margin: 0;
  }
  .pc-help p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 14px auto 0;
    max-width: 520px;
  }
  .pc-help-cta {
    margin-top: 26px;
  }

  /* ---- responsive ---- */
  @media (max-width: 960px) {
    .pc-hero-inner {
      grid-template-columns: 1fr;
    }
    .pc-arches {
      display: none;
    }
    .pc-pitch-grid {
      grid-template-columns: 1fr;
    }
    .pc-guide-grid {
      grid-template-columns: 1fr;
    }
    .pc-grid[data-cols="3"],
    .pc-grid[data-cols="4"] {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 620px) {
    .pc-wrap {
      padding: 0 24px;
    }
    .pc-hero-inner {
      padding: 22px 24px 52px;
    }
    .pc-grid[data-cols="2"],
    .pc-grid[data-cols="3"],
    .pc-grid[data-cols="4"] {
      grid-template-columns: 1fr;
    }
  }

  /* ---- print: a clean sheet of the current cards ---- */
  @media print {
    @page {
      margin: 12mm;
    }
    :global(.site-header),
    :global(.cw-footer),
    .pc-hero,
    .pc-pitch,
    .pc-guide,
    .pc-help,
    .pc-controls,
    .pc-sec-head,
    .pc-card .dl {
      display: none !important;
    }
    .pc-gallery {
      padding: 0 !important;
    }
    .pc-wrap {
      padding: 0;
      max-width: none;
    }
    .pc-grid {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10mm !important;
    }
    .pc-card {
      break-inside: avoid;
    }
    .pc-card img {
      filter: none;
    }
  }
</style>
