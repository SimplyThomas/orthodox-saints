---
import BaseLayout from "../layouts/BaseLayout.astro";
import QuizForm from "../components/QuizForm.astro";
import DetailModal from "../components/DetailModal.astro";
import DomeMark from "../components/icons/DomeMark.astro";
import { withBase } from "../lib/format";
import { FINDER_SAINTS } from "../lib/data";

const finderJson = JSON.stringify(FINDER_SAINTS).replace(/</g, "\\u003c");
---

<BaseLayout
  active="quiz"
  title="Find Your Patron Saint"
  description="A guided finder that matches you with Orthodox saints whose lives and intercessions echo your own."
>
  <div id="quiz" class="quiz-wrap">
    <section class="quiz-hero">
      <div class="dome-bg" id="quiz-dome" aria-hidden="true">
        <DomeMark w={460} color="var(--byz)" />
      </div>
      <div class="inner">
        <div class="eyebrow">A Short Pilgrimage of the Heart</div>
        <h1>Find Your Patron Saint</h1>
        <p>
          Choose what speaks to you &mdash; a companion in the great cloud of
          witnesses whose life and intercessions may shed light on your own.
        </p>
      </div>
    </section>
    <div class="quiz-back">
      <a href={withBase("")} class="link-btn">&larr; Back to the saints</a>
    </div>
    <section class="quiz-body">
      <p class="quiz-intro">
        Pick as many as you like in each question, and leave any blank to skip
        it. We&rsquo;ll match you with saints whose lives and intercessions echo
        yours.
      </p>
      <QuizForm />
      <div class="quiz-actions">
        <button type="button" id="quiz-submit" class="btn btn--gold"
          >Show my patrons</button
        >
        <button type="button" id="quiz-reset" class="link-btn"
          >Reset answers</button
        >
      </div>
      <div id="quiz-results" class="quiz-results" role="status"></div>
    </section>
  </div>
  <DetailModal />

  <script
    type="application/json"
    id="finder-data"
    set:html={finderJson}
    is:inline
  />
  <script>
    import "../islands/quiz.client.ts";
  </script>
</BaseLayout>
