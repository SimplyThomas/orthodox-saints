---
import BaseLayout from "../layouts/BaseLayout.astro";
import DomeMark from "../components/icons/DomeMark.astro";
import { withBase, MONTHS, MONTHS_FULL } from "../lib/format";
import { SAINTS } from "../lib/data";
import { feastDates, primaryRank, rankSlug } from "../lib/saints";
import { splitName } from "../lib/names";
import { FEASTS, PASCHA } from "../lib/feasts";
import { LITURGICAL_COLORS, FASTING_LEVELS } from "../lib/liturgical";

// Every saint grouped onto each fixed feast date they hold. Movable-cycle
// commemorations (no fixed Mon-D) collect separately. The grid + "today" are
// built client-side (islands/calendar) because a build-time new Date() would
// freeze to the deploy day; this page renders the full day-lists as the SEO +
// no-JS source the island reads from.
// TODO(scale): like /search, this pre-renders the whole corpus on one page;
// comfortable at today's size, split per-month if the calendar grows heavy.

interface Entry {
  id: string;
  title: string;
  epithet: string;
  rank: string;
  slug: string;
  w: number;
}

const RANK_W: Record<string, number> = {
  Theotokos: 10,
  Apostle: 9,
  Forerunner: 9,
  "Equal-to-the-Apostles": 8,
  Prophet: 7,
  "Great Martyr": 7,
  Enlightener: 6,
  Hierarch: 6,
  Hieromartyr: 6,
  Wonderworker: 5,
  Unmercenary: 5,
  Confessor: 4,
  "New Martyr": 4,
  "Venerable-Martyr": 4,
  "Passion-Bearer": 4,
  Martyr: 3,
  "Venerable (Monastic)": 2,
  Righteous: 2,
};
const weight = (rank: string[]): number =>
  rank.length ? Math.max(...rank.map((r) => RANK_W[r] ?? 1)) : 1;

const months: Map<number, Entry[]>[] = Array.from(
  { length: 13 },
  () => new Map<number, Entry[]>(),
);
const movable: Entry[] = [];

for (const s of SAINTS) {
  const sn = splitName(s.name);
  const entry: Entry = {
    id: s.id,
    title: sn.title,
    epithet: sn.epithet,
    rank: primaryRank(s),
    slug: rankSlug(s),
    w: weight(s.rank),
  };
  const dates = feastDates(s);
  if (!dates.length) {
    movable.push(entry);
    continue;
  }
  const seen = new Set<string>();
  for (const { m, d } of dates) {
    if (m < 1 || m > 12 || d < 1 || d > 31) continue;
    const key = `${m}-${d}`;
    if (seen.has(key)) continue;
    seen.add(key);
    const map = months[m];
    if (!map.has(d)) map.set(d, []);
    map.get(d)!.push(entry);
  }
}

const byRank = (a: Entry, b: Entry) =>
  b.w - a.w || a.title.localeCompare(b.title);
for (const map of months) for (const arr of map.values()) arr.sort(byRank);
movable.sort(byRank);

const monthData = MONTHS.map((abbr, i) => {
  const m = i + 1;
  const map = months[m];
  const days = [...map.keys()]
    .sort((a, b) => a - b)
    .map((d) => ({ d, entries: map.get(d)! }));
  const count = days.reduce((n, day) => n + day.entries.length, 0);
  return { m, abbr, full: MONTHS_FULL[i], days, count };
});

const totalEntries =
  monthData.reduce((n, mo) => n + mo.count, 0) + movable.length;

// Trimmed Feasts & Fasts payload for the island's liturgical-color layer
// (lib/liturgical) — colors attach to feast records, so the New/Old toggle
// shifts fixed feasts and their colors together. Same inline-JSON pattern
// as the /feasts island (~12 KB).
const litJson = JSON.stringify({
  feasts: FEASTS.map((f) => ({
    id: f.id,
    name: f.name,
    category: f.category,
    ...(f.dedication ? { dedication: f.dedication } : {}),
    ...(f.fasting ? { fasting: f.fasting } : {}),
    begins: f.begins,
    ...(f.ends ? { ends: f.ends } : {}),
    ...(f.forefeast ? { forefeast: f.forefeast } : {}),
    ...(f.apodosis ? { apodosis: f.apodosis } : {}),
  })),
  pascha: PASCHA,
});

// Legend rows (server-rendered so the guide reads without JS).
const legendColors: { key: string; label: string; use: string }[] = [
  {
    key: "gold",
    label: "Gold",
    use: "bright or festal use — ordinary Sundays and general festal days",
  },
  {
    key: "white",
    label: "White",
    use: "Pascha, the paschal season, and major feasts of the Lord",
  },
  { key: "blue", label: "Blue", use: "feasts of the Theotokos" },
  {
    key: "red",
    label: "Red",
    use: "martyrs, Cross observances, and other assigned days",
  },
  {
    key: "green",
    label: "Green",
    use: "Pentecost and assigned observances of the Holy Spirit",
  },
  {
    key: "purple",
    label: "Purple",
    use: "Great Lent, repentance, and Holy Week",
  },
  { key: "dark", label: "Dark", use: "the most solemn Passion services" },
  {
    key: "neutral",
    label: "Neutral",
    use: "no special color assigned, or local custom varies",
  },
];
const legendFasting = Object.values(FASTING_LEVELS);
const swatch = (key: string) =>
  LITURGICAL_COLORS[key as keyof typeof LITURGICAL_COLORS];
---

<BaseLayout
  active="calendar"
  title="The Calendar"
  description="A month-by-month Orthodox calendar of the saints — browse every commemoration by date, plus the movable cycle."
>
  <div id="calendar-page">
    <section class="cal-hero">
      <div class="dome-bg" aria-hidden="true">
        <DomeMark w={460} color="var(--byz)" />
      </div>
      <div class="cal-hero-inner">
        <div class="eyebrow-rule" aria-hidden="true">
          <span class="ln"></span><span class="dm"></span>
          <span class="lbl">The Church Year</span>
          <span class="dm"></span><span class="ln"></span>
        </div>
        <h1 class="cal-title">The Calendar</h1>
        <p class="cal-lede">
          {totalEntries.toLocaleString()} commemorations across the fixed calendar,
          with the movable cycle alongside.
        </p>
        <span id="cal-today-label" class="cal-today-label" aria-live="polite"
        ></span>
      </div>
    </section>

    {/* interactive month grid — revealed by the island on enhancement */}
    <div class="cal-app" hidden>
      <div class="cal-bar">
        <div class="cal-month-label" id="cal-month-label"></div>
        <div
          class="cal-style-toggle"
          role="group"
          aria-label="Calendar reckoning"
        >
          <button
            type="button"
            id="cal-style-new"
            aria-pressed="true"
            title="Revised Julian — fixed feasts fall on the civil date"
            >New Calendar</button
          >
          <button
            type="button"
            id="cal-style-old"
            aria-pressed="false"
            title="Julian — fixed feasts fall 13 days later on the civil calendar"
            >Old Calendar</button
          >
        </div>
        <div class="cal-ctrls">
          <button type="button" id="cal-today-btn">Today</button>
          <button
            type="button"
            id="cal-prev"
            class="cal-nav-arrow"
            aria-label="Previous month">‹</button
          >
          <select id="cal-month-picker" aria-label="Jump to month">
            {
              MONTHS_FULL.map((full, i) => (
                <option value={i + 1}>{full}</option>
              ))
            }
          </select>
          <button
            type="button"
            id="cal-next"
            class="cal-nav-arrow"
            aria-label="Next month">›</button
          >
        </div>
      </div>

      <p class="cal-style-note" id="cal-style-note" hidden>
        Old Calendar (Julian): the grid shows civil dates; each day carries the
        church date kept 13 days earlier. The Paschal cycle is the same on both
        calendars.
      </p>

      <div class="cal-main">
        <div class="cal-grid-wrap">
          <div class="cal-dow" aria-hidden="true">
            <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span>
            <span>Thu</span><span>Fri</span><span>Sat</span>
          </div>
          <div class="cal-grid" id="cal-grid"></div>
        </div>
        <aside class="cal-panel" id="cal-panel" aria-live="polite"></aside>
      </div>

      <div class="cal-foot">
        {
          movable.length > 0 && (
            <button type="button" id="cal-movable-btn" class="cal-pill">
              ✶ Movable commemorations ({movable.length.toLocaleString()}) →
            </button>
          )
        }
        <div class="cal-legend">
          <span><b class="lg-n">5</b>saints commemorated that day</span>
          <span><i style="background:#b7912b"></i>Apostles · Hierarchs</span>
          <span><i style="background:#8d3a2f"></i>Martyrs</span>
          <span><i style="background:#3d6157"></i>Monastics</span>
        </div>
      </div>

      {/* ——— Liturgical Colors & Fasting Guide (collapsible legend) ——— */}
      <details class="cal-lit-legend" id="cal-lit-legend">
        <summary>Liturgical Colors &amp; Fasting Guide</summary>
        <div class="cal-lit-legend-body">
          <p class="cal-lit-legend-lede">
            Day tints show <strong
              >liturgical colors commonly used in Orthodox practice</strong
            >. The Church broadly distinguishes bright, festal colors from dark,
            penitential ones; more detailed assignments vary widely.
          </p>
          <ul class="cal-lit-colors" role="list">
            {
              legendColors.map((c) => (
                <li>
                  <span
                    class={`cal-lit-swatch lcs-${c.key}`}
                    style={`--sw-bg:${swatch(c.key).background};--sw-ac:${swatch(c.key).accent}`}
                    aria-hidden="true"
                  />
                  <b>{c.label}</b> — {c.use}
                </li>
              ))
            }
          </ul>
          <h3>Fasting badges</h3>
          <p class="cal-lit-legend-note">
            Fasting is shown separately from the liturgical color, as a small
            corner badge; days without a recorded rule carry no badge. Fasting
            summaries are descriptive, not prescriptive — consult your parish
            priest.
          </p>
          <ul class="cal-lit-fasts" role="list">
            {
              legendFasting.map((f) => (
                <li>
                  <span class="fast-glyph" aria-hidden="true">
                    {f.glyph}
                  </span>
                  <span>
                    {f.label}
                    {f.note && <i class="cal-lit-fastnote"> — {f.note}</i>}
                  </span>
                </li>
              ))
            }
            <li>
              <span class="lc-svc-glyph" aria-hidden="true"></span>
              Color changes by service — open the day for details
            </li>
          </ul>
          <blockquote class="cal-lit-disclaimer">
            Liturgical color customs vary among Orthodox jurisdictions and
            parishes. The colors shown here are a general visual guide based
            primarily on commonly observed Greek Orthodox practice and other
            established Orthodox customs. Individual parishes may use different
            colors.
          </blockquote>
          <blockquote class="cal-lit-disclaimer">
            Orthodox liturgical color customs are not completely uniform. Colors
            may differ by jurisdiction, diocese, parish, feast, or individual
            service. This calendar provides a general educational guide and does
            not replace the directions of a parish priest or bishop.
          </blockquote>
          <p class="cal-lit-legend-note">
            The small colored dots beside saints' names are organizational
            accents keyed to saint rank (martyr, hierarch, monastic, …) used by
            this website; they do not necessarily indicate the vestment color
            worn for that saint.
          </p>
        </div>
      </details>
    </div>

    {
      /* SEO + no-JS source: every day's full list; the island reads + clones from here */
    }
    <div class="cal-source" id="cal-source">
      {
        monthData.map((mo) => (
          <section data-month={mo.m} aria-label={mo.full}>
            <h2>{mo.full}</h2>
            {mo.days.map((day) => (
              <div class="cal-src-day" data-day={day.d}>
                <h3>
                  {mo.full} {day.d}
                </h3>
                <ul class="cal-list">
                  {day.entries.map((e) => (
                    <li>
                      <a href={withBase(`saint/${e.id}`)}>
                        <span
                          class={`cd ${e.slug}`}
                          title={e.rank}
                          aria-hidden="true"
                        />
                        <span class="nm">
                          {e.title}
                          {e.epithet && <i> {e.epithet}</i>}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        ))
      }
      {
        movable.length > 0 && (
          <div class="cal-src-movable" aria-label="Movable Commemorations">
            <h2>Movable Commemorations</h2>
            <ul class="cal-list">
              {movable.map((e) => (
                <li>
                  <a href={withBase(`saint/${e.id}`)}>
                    <span
                      class={`cd ${e.slug}`}
                      title={e.rank}
                      aria-hidden="true"
                    />
                    <span class="nm">
                      {e.title}
                      {e.epithet && <i> {e.epithet}</i>}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </div>

  <script type="application/json" id="cal-lit-data" set:html={litJson} />
  <script>
    import "../islands/calendar.client.ts";
  </script>
</BaseLayout>
