---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DomeMark from "../../components/icons/DomeMark.astro";
import { withBase } from "../../lib/format";
import { SAINTS } from "../../lib/data";

// A lightweight count so the placeholder still reports the real corpus size
// the news archive will draw on.
const total = SAINTS.length;
---

<BaseLayout
  active="news"
  title="Saints in the News"
  description="Reporting the mighty works of God through His saints — coming soon to Cloud of Witnesses."
>
  <div class="news-soon">
    <section class="hero">
      <div class="dome-bg" aria-hidden="true">
        <DomeMark w={460} color="var(--byz)" />
      </div>
      <div class="hero-inner">
        <div class="eyebrow-rule" aria-hidden="true">
          <span class="ln"></span><span class="dm"></span>
          <span class="lbl">The Saints</span>
          <span class="dm"></span><span class="ln"></span>
        </div>
        <h1 class="news-title">Saints in the News</h1>
        <p class="news-lede">
          A reverent archive of the mighty works of God through His saints
          &mdash; glorifications, relics, and wonders across the centuries.
        </p>

        <div class="news-panel">
          <div class="rule"><span class="dot"></span></div>
          <p class="news-soon-label">Coming soon</p>
          <p class="news-soon-body">
            We&rsquo;re building a living archive alongside the
            <strong>{total.toLocaleString()}</strong> saints already in the database
            &mdash; reported with reverence and verified against the Church&rsquo;s
            own discernment. In the meantime, every saint is searchable today.
          </p>
          <div class="news-actions">
            <a class="btn btn--gold" href={withBase("search")}
              >Browse the saints</a
            >
            <a class="btn btn--ghost" href={withBase("quiz")}
              >Find your patron</a
            >
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .news-title {
    font-size: var(--page-title-size);
    color: var(--byz-deep);
    line-height: 1;
    margin: 14px 0 16px;
    font-weight: 600;
  }
  .news-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--page-lede-size);
    color: var(--celest);
    max-width: 620px;
    margin: 0 auto 36px;
    line-height: 1.45;
    text-wrap: balance;
  }
  .news-panel {
    position: relative;
    max-width: 640px;
    margin: 0 auto;
    background: linear-gradient(168deg, #27537f 0%, #1e426a 55%, #193758 100%);
    border: 1px solid var(--gold-deep);
    border-radius: 12px;
    color: var(--ivory);
    box-shadow: var(--shadow-card);
    padding: 34px clamp(22px, 4vw, 48px) 32px;
    text-align: center;
  }
  .news-panel .rule {
    max-width: 150px;
    margin: 0 auto 16px;
    color: var(--gold-soft);
  }
  .news-soon-label {
    font-family: var(--text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    font-size: 12.5px;
    color: var(--gold-soft);
    margin: 0 0 14px;
  }
  .news-soon-body {
    font-size: 16.5px;
    color: #dbe5ef;
    line-height: 1.6;
    margin: 0 0 24px;
  }
  .news-soon-body strong {
    color: var(--gold-soft);
  }
  .news-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .news-actions .btn--ghost {
    color: var(--gold-soft);
    border-color: rgba(212, 175, 55, 0.45);
  }
  .news-actions .btn--ghost:hover {
    border-color: var(--gold);
    color: var(--gold-soft);
  }
</style>
