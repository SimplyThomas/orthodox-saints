---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { withBase } from "../lib/format";

interface Props {
  title?: string;
  description?: string;
  /** site-relative path to a page-specific share image (e.g. a saint portrait);
      defaults to the brand card. Rendered as an absolute URL in og:image. */
  ogImage?: string;
  ogImageAlt?: string;
  /** OpenGraph object type; saint pages pass "profile". */
  ogType?: "website" | "profile" | "article";
  active?:
    | "home"
    | "search"
    | "calendar"
    | "america"
    | "icons"
    | "news"
    | "quiz"
    | "about"
    | "";
}
const {
  title = "Cloud of Witnesses",
  description = "Find Orthodox saints by feast day, vocation, region, virtue, and intercession.",
  ogImage,
  ogImageAlt = "Cloud of Witnesses — find Orthodox saints",
  ogType = "website",
  active = "",
} = Astro.props;

const pageTitle =
  title === "Cloud of Witnesses" ? title : `${title} — Cloud of Witnesses`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(withBase(ogImage ?? "og-default.png"), Astro.site)
  .href;
// Portrait images (saint icons) read better as a small square card; the wide
// brand card uses the large format.
const twitterCard = ogImage ? "summary" : "summary_large_image";

// Umami Analytics (privacy-friendly, cookie-less, free Hobby tier). Loaded
// production-only — and only once a website id is configured — so the dev server
// never pollutes the dashboard and the script is absent until set up. The id is
// not a secret (it ships in the page source); set PUBLIC_UMAMI_WEBSITE_ID in the
// deploy environment after creating the site at cloud.umami.is. PUBLIC_UMAMI_SRC
// overrides the script host (e.g. a self-hosted instance). The script exposes the
// global `umami.track()` used by lib/analytics.ts.
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID ?? "";
const umamiSrc =
  import.meta.env.PUBLIC_UMAMI_SRC ?? "https://cloud.umami.is/script.js";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content="Cloud of Witnesses" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />
    {
      import.meta.env.PROD && umamiWebsiteId && (
        <script defer src={umamiSrc} data-website-id={umamiWebsiteId} />
      )
    }
  </head>
  <body>
    <SiteHeader active={active} />
    <main id="app">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
