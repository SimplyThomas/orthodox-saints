root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{js,css,html,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # preserve Markdown hard line breaks

[*.csv]
trim_trailing_whitespace = false  # cell values are data; don't auto-edit
insert_final_newline = true
